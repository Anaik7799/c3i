#!/bin/bash
# C3I Gleam Server — one command start
# Usage: ./sa-serve [--bg]
# STAMP: SC-GLM-UI-006 (port 4100)

cd "$(dirname "$0")/lib/cepaf_gleam" || exit 1

if [ "$1" = "--bg" ]; then
  gleam run -- --serve &disown
  echo "Server starting in background on https://0.0.0.0:4100"
else
  gleam run -- --serve
fi
