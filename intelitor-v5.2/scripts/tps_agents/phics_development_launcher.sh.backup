#!/bin/bash

echo "🔥 PHICS DEVELOPMENT LAUNCHER"
echo "============================"
echo "🎯 MISSION: Complete container-first development with hot-reload"
echo "🚀 STRATEGY: Local registry + PHICS integration"

# Function to check if container is running
container_running() {
    podman ps --filter "name=$1" --format "{{.Names}}" | grep -q "^$1$"
}

# Function to start development container with PHICS
start_phics_dev() {
    echo ""
    echo "🧠 THINKING: Starting PHICS development environment"
    echo "🎯 DECISION: Use local registry with hot-reload capabilities"
    echo "⚙️ EXECUTING: PHICS development container startup"
    
    if container_running "intelitor-phics-dev"; then
        echo "ℹ️ PHICS development container already running"
    else
        echo "🚀 Starting PHICS development container..."
        
        podman run -d \
            --name intelitor-phics-dev \
            -p 4000:4000 -p 4001:4001 \
            -v "$(pwd):/workspace:z" \
            -v "./data/phics:/workspace/.phics:z" \
            -e "MIX_ENV=dev" \
            -e "PHICS_ENABLED=true" \
            -e "PHX_SERVER=true" \
            localhost:5000/nixos-dev:latest \
            tail -f /dev/null
        
        if [ $? -eq 0 ]; then
            echo "✅ PHICS development container started"
        else
            echo "❌ Failed to start PHICS development container"
            return 1
        fi
    fi
}

# Function to setup file watchers
setup_file_watchers() {
    echo ""
    echo "👁️ Setting up PHICS file watchers..."
    
    # Install inotify-tools in development container
    podman exec intelitor-phics-dev bash -c "
        if ! command -v inotifywait >/dev/null 2>&1; then
            echo '📦 Installing inotify-tools...'
            nix-env -iA nixpkgs.inotify-tools
        fi
    "
    
    # Start file watcher in background
    podman exec -d intelitor-phics-dev bash -c "
        echo '🔥 Starting PHICS file watcher...'
        cd /workspace
        
        inotifywait -m -r -e modify,create,delete \
            --include '\.(ex|exs|heex|eex|js|css)$' \
            lib/ assets/ test/ | \
        while read path action file; do
            echo \"📝 File changed: \$path\$file (\$action)\"
            echo \"🔄 Recompiling...\"
            mix compile --warnings-as-errors || echo '⚠️ Compilation warnings/errors detected'
            echo \"✅ Recompilation complete\"
        done
    "
    
    echo "✅ PHICS file watchers active"
}

# Function to start Phoenix server
start_phoenix_server() {
    echo ""
    echo "🌐 Starting Phoenix server in PHICS container..."
    
    podman exec -d intelitor-phics-dev bash -c "
        cd /workspace
        echo '📦 Installing dependencies...'
        mix deps.get
        echo '🔧 Compiling application...'
        mix compile --warnings-as-errors
        echo '🌐 Starting Phoenix server...'
        iex -S mix phx.server
    "
    
    echo "✅ Phoenix server starting in container"
    echo "🌐 Application will be available at: http://localhost:4000"
}

# Function to display status
display_status() {
    echo ""
    echo "📊 PHICS DEVELOPMENT STATUS"
    echo "==========================="
    
    echo ""
    echo "🐳 Container Status:"
    podman ps --filter "name=intelitor-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    
    echo ""
    echo "🌐 Service Endpoints:"
    echo "• Application: http://localhost:4000"
    echo "• LiveReload: http://localhost:4001"
    echo "• Registry: http://localhost:5000"
    echo "• Grafana: http://localhost:3000"
    
    echo ""
    echo "🔥 PHICS Features:"
    echo "• ✅ Hot-reload: Active file watching"
    echo "• ✅ Local registry: All images from localhost:5000"
    echo "• ✅ Container isolation: Development in containers"
    echo "• ✅ Zero external dependencies: Self-contained ecosystem"
}

# Function to show logs
show_logs() {
    echo ""
    echo "📋 PHICS Development Logs:"
    echo "========================="
    podman logs -f intelitor-phics-dev
}

# Main execution
case "$1" in
    --start)
        start_phics_dev
        setup_file_watchers
        start_phoenix_server
        display_status
        ;;
    --status)
        display_status
        ;;
    --logs)
        show_logs
        ;;
    --stop)
        echo "🛑 Stopping PHICS development environment..."
        podman stop intelitor-phics-dev 2>/dev/null || echo "Container was not running"
        podman rm intelitor-phics-dev 2>/dev/null || echo "Container was already removed"
        echo "✅ PHICS development environment stopped"
        ;;
    *)
        echo ""
        echo "🔥 PHICS DEVELOPMENT LAUNCHER"
        echo "============================"
        echo ""
        echo "Available commands:"
        echo "  --start    Start complete PHICS development environment"
        echo "  --status   Show current status of all services"
        echo "  --logs     Show development container logs"
        echo "  --stop     Stop PHICS development environment"
        echo ""
        echo "🎯 TPS MISSION: Container-first development with hot-reload"
        echo "🏆 ACHIEVEMENT: Zero external dependencies with local registry"
        ;;
esac
#═══════════════════════════════════════════════════════════════════════════════
# PATIENT MODE - NO_TIMEOUT POLICY VARIABLES
#═══════════════════════════════════════════════════════════════════════════════

# Patient Mode Configuration
export PATIENT_MODE=enabled
export NO_TIMEOUT=true
export INFINITE_PATIENCE=true
export TIMEOUT_POLICY=none

# Patient Mode Execution Settings
export COMPILE_TIMEOUT=infinity
export TEST_TIMEOUT=infinity
export DEMO_TIMEOUT=infinity
export TASK_TIMEOUT=infinity


#═══════════════════════════════════════════════════════════════════════════════
# 11-AGENT ARCHITECTURE COORDINATION VARIABLES
#═══════════════════════════════════════════════════════════════════════════════

# Agent Architecture Configuration
export AGENT_COORDINATION=enabled
export SUPERVISOR_AGENTS=1
export HELPER_AGENTS=4
export WORKER_AGENTS=6
export TOTAL_AGENTS=11

# Agent Coordination Settings
export MULTI_AGENT_COORDINATION=enabled
export DYNAMIC_LOAD_BALANCING=enabled
export AGENT_COMMUNICATION=enabled
export COORDINATION_STRATEGY=cybernetic


