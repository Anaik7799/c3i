#!/bin/bash
echo "🧠 THINKING: PHICS needed for seamless container-host development"
echo "🎯 DECISION: Ensure PHICS file watchers are operational"
echo "⚙️ EXECUTING: PHICS integration verification"

# Check if PHICS is already running
if podman exec intelitor-dev-phics pgrep -f "inotifywait" >/dev/null 2>&1; then
    echo "✅ PHICS file watchers already active"
else
    echo "🔧 Starting PHICS file watchers..."
    podman exec -d intelitor-dev-phics /workspace/.phics/watchers/phics_watcher.sh
    echo "✅ PHICS file watchers started"
fi

# Verify PHICS functionality
echo "📊 VALIDATING: PHICS status"
podman exec intelitor-dev-phics bash -c "
    if [ -f /workspace/.phics/config/phics.exs ]; then
        echo '✅ PHICS configuration present'
    else
        echo '⚠️ PHICS configuration needs setup'
    fi
"
