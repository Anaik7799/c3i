#!/bin/bash
echo "🔍 Starting containerized Docker violation analysis..."

podman exec intelitor-analysis-agent bash -c "
    cd /workspace &&
    echo '🧠 THINKING: Systematic Docker reference scanning' &&
    echo '🎯 DECISION: Use grep and find for comprehensive detection' &&
    echo '⚙️ EXECUTING: Docker violation detection' &&
    
    echo '1. Docker CLI command references:' &&
    grep -r 'docker run\|docker exec\|docker ps\|docker build' --include='*.exs' --include='*.ex' --include='*.md' . | wc -l &&
    
    echo '2. Docker Compose references:' &&
    grep -r 'docker-compose\|docker compose' --include='*.yml' --include='*.yaml' --include='*.exs' . | wc -l &&
    
    echo '3. Dockerfile references:' &&
    find . -name 'Dockerfile*' -o -name '*.dockerfile' | wc -l &&
    
    echo '4. Docker image references:' &&
    grep -r 'docker\.io\|FROM.*docker' --include='*.exs' --include='*.ex' --include='*.md' . | wc -l &&
    
    echo '5. Docker volume references:' &&
    grep -r 'docker.*volume\|volume.*docker' --include='*.exs' --include='*.ex' . | wc -l &&
    
    echo '📊 VALIDATING: Creating detailed violation report' &&
    mkdir -p /workspace/.analysis &&
    grep -r 'docker' --include='*.exs' --include='*.ex' --include='*.md' . > /workspace/.analysis/docker_violations.txt 2>/dev/null &&
    echo "Total violations found: $(wc -l < /workspace/.analysis/docker_violations.txt)" &&
    echo '✅ Analysis complete - report saved to .analysis/docker_violations.txt'
"
