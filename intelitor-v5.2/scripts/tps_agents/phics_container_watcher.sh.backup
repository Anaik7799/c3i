#!/bin/bash
echo "🔥 Starting PHICS container file watcher..."

inotifywait -m -r -e modify,create,delete \
  --include '\.(ex|exs|heex|eex|js|css)$' \
  /workspace/lib /workspace/assets /workspace/test |
while read path action file; do
  echo "📝 File changed: $path$file ($action)"
  echo "🔄 Triggering container rebuild..."
  
  # Rebuild and restart container
  podman build -t localhost:5001/intelitor-phics-dev:latest /workspace
  podman stop intelitor-phics-dev 2>/dev/null || true
  podman rm intelitor-phics-dev 2>/dev/null || true
  podman run -d --name intelitor-phics-dev \
    -p 4000:4000 -p 4001:4001 \
    -v /workspace:/workspace:z \
    localhost:5001/intelitor-phics-dev:latest
  
  echo "✅ Container restarted with changes"
done
