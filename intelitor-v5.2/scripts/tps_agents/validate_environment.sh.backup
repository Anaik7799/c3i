#!/bin/bash
echo "🔍 Comprehensive environment validation..."

echo "1. Container Status:"
podman ps --format "table {{.Names}}\t{{.Status}}"

echo ""
echo "2. Development Container Functionality:"
if podman exec intelitor-dev-phics test -d /workspace; then
    echo "✅ Development container workspace accessible"
else
    echo "❌ Development container workspace not accessible"
fi

echo ""
echo "3. Analysis Container Functionality:"
if podman exec intelitor-analysis-agent test -d /workspace; then
    echo "✅ Analysis container workspace accessible"
else
    echo "❌ Analysis container workspace not accessible"
fi

echo ""
echo "4. Validation Container Functionality:"
if podman exec intelitor-validation-agent test -d /workspace; then
    echo "✅ Validation container workspace accessible"
else
    echo "❌ Validation container workspace not accessible"
fi

echo ""
echo "5. PHICS Integration:"
if podman exec intelitor-dev-phics pgrep -f "inotifywait" >/dev/null 2>&1; then
    echo "✅ PHICS file watchers active"
else
    echo "⚠️ PHICS file watchers not detected"
fi
