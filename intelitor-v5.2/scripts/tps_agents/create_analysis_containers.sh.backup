#!/bin/bash
echo "🔧 Creating specialized analysis containers..."

# Create analysis container for code scanning
if ! podman ps -a --format "{{.Names}}" | grep -q "^intelitor-analysis-agent$"; then
    echo "Creating analysis container..."
    podman run -d \
        --name intelitor-analysis-agent \
        --network intelitor-ecosystem \
        -v /home/an/dev/elixir/ash/intelitor:/workspace:z \
        -v ./data/analysis:/workspace/.analysis:z \
        -e "ANALYSIS_ROLE=docker_violation_scanner" \
        registry.nixos.org/nixos/nix:latest \
        tail -f /dev/null
    echo "✅ Analysis container created"
else
    echo "ℹ️ Analysis container already exists"
fi

# Create validation container for testing
if ! podman ps -a --format "{{.Names}}" | grep -q "^intelitor-validation-agent$"; then
    echo "Creating validation container..."
    podman run -d \
        --name intelitor-validation-agent \
        --network intelitor-ecosystem \
        -v /home/an/dev/elixir/ash/intelitor:/workspace:z \
        -v ./data/validation:/workspace/.validation:z \
        -e "VALIDATION_ROLE=pcis_compliance_checker" \
        registry.nixos.org/nixos/nix:latest \
        tail -f /dev/null
    echo "✅ Validation container created"
else
    echo "ℹ️ Validation container already exists"
fi

echo "📊 Container status after creation:"
podman ps --format "table {{.Names}}\t{{.Status}}"
