#!/bin/bash
echo "🚀 Starting PHICS development workflow..."

# Start development container with hot-reload
podman run -d --name intelitor-phics-dev \
  -p 4000:4000 -p 4001:4001 \
  -v /home/an/dev/elixir/ash/intelitor:/workspace:z \
  localhost:5001/intelitor-phics-dev:latest

# Start file watcher in background
./scripts/tps_agents/phics_container_watcher.sh &

echo "✅ PHICS development environment running"
echo "🌐 Application: http://localhost:4000"
echo "🔥 Hot-reload: Active"
