#!/bin/bash

# Intelitor Demo Container Startup Script
# Comprehensive startup sequence for containerized demo environment

set -e

echo "🚀 INTELITOR DEMO CONTAINER STARTUP"
echo "==================================="
echo "📊 Environment: $MIX_ENV"
echo "🌐 Host: $PHX_HOST:$PHX_PORT"
echo "🗄️ Database: $DATABASE_URL"
echo ""

# Function to wait for database
wait_for_database() {
    echo "⏳ Waiting for database connection..."
    
    DB_HOST=$(echo $DATABASE_URL | sed 's/.*@\([^:]*\):.*/\1/')
    DB_PORT=$(echo $DATABASE_URL | sed 's/.*:\([0-9]*\)\/.*/\1/')
    
    if [ -z "$DB_HOST" ] || [ -z "$DB_PORT" ]; then
        DB_HOST="intelitor-db"
        DB_PORT="5432"
    fi
    
    echo "🔍 Checking database at $DB_HOST:$DB_PORT"
    
    RETRY_COUNT=0
    MAX_RETRIES=30
    
    while ! pg_isready -h "$DB_HOST" -p "$DB_PORT" -U intelitor-postgres-dev; do
        RETRY_COUNT=$((RETRY_COUNT + 1))
        
        if [ $RETRY_COUNT -ge $MAX_RETRIES ]; then
            echo "❌ Database connection timeout after $MAX_RETRIES attempts"
            exit 1
        fi
        
        echo "🔄 Database not ready (attempt $RETRY_COUNT/$MAX_RETRIES), waiting..."
        sleep 2
    done
    
    echo "✅ Database connection established!"
}

# Function to setup database
setup_database() {
    echo "🗄️ Setting up database..."
    
    # Create database if it doesn't exist
    echo "📝 Creating database..."
    mix ecto.create || echo "ℹ️  Database already exists"
    
    # Run migrations
    echo "🔄 Running migrations..."
    mix ecto.migrate || echo "ℹ️  Migrations completed"
    
    # Generate and apply Ash resources
    echo "🔧 Preparing Ash resources..."
    mix ash.codegen --auto-apply || echo "ℹ️  Ash resources ready"
    
    echo "✅ Database setup completed!"
}

# Function to check application health
check_application_health() {
    echo "🏥 Performing application health checks..."
    
    # Check if all required Mix tasks are available
    if ! mix help ecto.create > /dev/null 2>&1; then
        echo "❌ Ecto tasks not available"
        return 1
    fi
    
    if ! mix help ash.codegen > /dev/null 2>&1; then
        echo "❌ Ash tasks not available"
        return 1
    fi
    
    # Check if dependencies are compiled
    if [ ! -d "_build/demo/lib" ]; then
        echo "🔨 Compiling dependencies..."
        mix deps.compile
    fi
    
    # Check if application is compiled
    if [ ! -d "_build/demo/lib/intelitor" ]; then
        echo "🔨 Compiling application..."
        mix compile
    fi
    
    echo "✅ Application health checks passed!"
}

# Function to setup demo data (optional)
setup_demo_data() {
    if [ "$DEMO_DATA" = "true" ]; then
        echo "📊 Setting up demo data..."
        
        # Run demo data setup if available
        if mix help demo.setup > /dev/null 2>&1; then
            mix demo.setup || echo "ℹ️  Demo data setup completed"
        else
            echo "ℹ️  No demo data setup task available"
        fi
    fi
}

# Function to start Phoenix server
start_phoenix_server() {
    echo "🌟 Starting Phoenix server..."
    echo "🌐 Application will be available at: http://$PHX_HOST:$PHX_PORT"
    echo "🏥 Health check available at: http://$PHX_HOST:$PHX_PORT/health"
    echo ""
    
    # Start the Phoenix server
    exec mix phx.server
}

# Main startup sequence
main() {
    echo "🚀 Starting Intelitor demo application startup sequence..."
    
    # Step 1: Wait for database
    wait_for_database
    
    # Step 2: Check application health
    check_application_health
    
    # Step 3: Setup database
    setup_database
    
    # Step 4: Setup demo data (if enabled)
    setup_demo_data
    
    # Step 5: Start Phoenix server
    start_phoenix_server
}

# Handle signals for graceful shutdown
trap 'echo "🛑 Received shutdown signal, exiting gracefully..."; exit 0' SIGTERM SIGINT

# Run main startup sequence
main "$@"
#═══════════════════════════════════════════════════════════════════════════════
# PATIENT MODE - NO_TIMEOUT POLICY VARIABLES
#═══════════════════════════════════════════════════════════════════════════════

# Patient Mode Configuration
export PATIENT_MODE=enabled
export NO_TIMEOUT=true
export INFINITE_PATIENCE=true
export TIMEOUT_POLICY=none

# Patient Mode Execution Settings
export COMPILE_TIMEOUT=infinity
export TEST_TIMEOUT=infinity
export DEMO_TIMEOUT=infinity
export TASK_TIMEOUT=infinity


#═══════════════════════════════════════════════════════════════════════════════
# 11-AGENT ARCHITECTURE COORDINATION VARIABLES
#═══════════════════════════════════════════════════════════════════════════════

# Agent Architecture Configuration
export AGENT_COORDINATION=enabled
export SUPERVISOR_AGENTS=1
export HELPER_AGENTS=4
export WORKER_AGENTS=6
export TOTAL_AGENTS=11

# Agent Coordination Settings
export MULTI_AGENT_COORDINATION=enabled
export DYNAMIC_LOAD_BALANCING=enabled
export AGENT_COMMUNICATION=enabled
export COORDINATION_STRATEGY=cybernetic


