#!/bin/bash

# Intelitor Demo Browser Automation Script
# Generated by Agent 5 - GUI Testing Specialist

echo "🌐 Launching Intelitor Demo Browser Environment"
echo "Date: $(date)"

# Demo landing page path
DEMO_LANDING="file://$(pwd)/priv/demo_pages/demo_landing.html"

# Check if browser is available
if command -v google-chrome &> /dev/null; then
    BROWSER_CMD="google-chrome"
elif command -v firefox &> /dev/null; then
    BROWSER_CMD="firefox"
else
    echo "❌ Error: No supported browser found"
    echo "Please install Chrome or Firefox"
    exit 1
fi

# Launch demo landing page
echo "🚀 Opening demo landing page with $BROWSER_CMD..."
$BROWSER_CMD --new-window "$DEMO_LANDING" &

echo "✅ Demo browser environment launched successfully"
echo "📊 Monitor demo progress in the landing page"
echo "🎭 Use demo controls for guided presentations"
