{
  // Zenoh Router 2 Configuration for Indrajaal SIL-6 Mesh
  // Version: 1.0.0 | STAMP: SC-ZENOH-CFG-001, SC-SIL4-006
  // Purpose: Secondary router in 2oo3 quorum cluster

  mode: "router",

  listen: {
    endpoints: [
      "tcp/0.0.0.0:7447"
    ]
  },

  // Peer connections to other routers in the 2oo3 cluster
  connect: {
    endpoints: [
      "tcp/zenoh-router-1:7447",
      "tcp/zenoh-router-3:7447"
    ]
  },

  plugins: {
    // REST API Plugin (for health checks and debugging)
    rest: {
      http_port: 8000
    }
  },

  // Scouting for peer discovery
  scouting: {
    gossip: {},
    multicast: {
      enabled: true,
      address: "224.0.0.224:7446",
      interface: "auto"
    }
  },

  // Routing configuration for cluster coordination
  routing: {
    router: {
      peers_failover_brokering: true
    }
  }
}
