# Indrajaal SIL-4 Hardened Observability Container
# Version: 1.0.0
# Stack: OTEL Collector + SigNoz (Simplified for Mesh)

FROM docker.io/signoz/signoz-otel-collector:latest

# 1. Security
USER 1000

# 2. Configuration
COPY config/otel-config-fractal.yaml /etc/otel/config.yaml

# 3. Entrypoint
CMD ["--config=/etc/otel/config.yaml"]
