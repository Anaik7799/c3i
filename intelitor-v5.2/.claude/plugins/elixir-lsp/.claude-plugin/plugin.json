{
  "name": "indrajaal-lsp",
  "description": "Multi-language LSP with Elixir framework support (Phoenix, Ecto, Ash, Oban, LiveView, Absinthe)",
  "version": "3.1.0",
  "author": {
    "name": "Indrajaal Team"
  },
  "lspServers": "../.lsp.json",
  "languages": [
    "elixir",
    "erlang",
    "gleam",
    "fsharp",
    "csharp",
    "rust",
    "python",
    "bash",
    "zsh",
    "sql"
  ],
  "elixirFrameworks": [
    "phoenix",
    "ecto",
    "ash",
    "oban",
    "liveview",
    "absinthe"
  ],
  "fileExtensions": {
    "phoenix": [".heex", ".leex"],
    "surface": [".sface"],
    "elixir": [".ex", ".exs"],
    "erlang": [".erl", ".hrl"],
    "gleam": [".gleam"],
    "fsharp": [".fs", ".fsi", ".fsx"],
    "csharp": [".cs", ".csx"],
    "rust": [".rs"],
    "python": [".py"],
    "bash": [".sh", ".bash", ".zsh"],
    "sql": [".sql", ".pgsql"]
  }
}
