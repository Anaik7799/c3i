{
  "title": "System Overview Dashboard",
  "description": "Provides a comprehensive view of all system components and their health status",
  "layout": "grid",
  "variables": [],
  "panels": [
    {
      "title": "Request Rate (All Services)",
      "type": "metric",
      "query": "sum(rate(http_requests_total[5m])) by (service)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "line",
        "aggregation": "sum",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Error Rate",
      "type": "metric",
      "query": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "line",
        "aggregation": "sum",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "P95 Latency",
      "type": "metric",
      "query": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (service, le))",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "line",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Active Users",
      "type": "metric",
      "query": "count(count by (user_id) (user_activity_total))",
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Recent Errors",
      "type": "log",
      "query": "level=error",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 4
      },
      "options": {
        "columns": ["timestamp", "service", "message"],
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Service Traces",
      "type": "trace",
      "query": "duration > 100ms",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 4
      },
      "options": {
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    }
  ]
}