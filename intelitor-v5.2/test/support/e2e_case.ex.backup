defmodule IntelitorWeb.E2ECase do
  @moduledoc """
  Base module for E2E tests using Wallaby for browser automation.
  
  ## TPS Integration
  
  - **Jidoka**: Automatic screenshot capture on test failure
  - **5-Level RCA**: Detailed browser state logging for failure analysis
  - **Visual Management**: Real-time test execution monitoring
  - **Continuous Improvement**: Pattern-based test optimization
  
  ## Features
  
  - Container-aware Chrome/Chromedriver configuration
  - Automatic test data setup and teardown
  - Page object pattern support
  - Screenshot capture on failure
  - Retry logic for flaky conditions
  """

  use ExUnit.CaseTemplate
  use Wallaby.Feature

  using do
    quote do
      use Wallaby.Feature
      import IntelitorWeb.E2ECase
      import IntelitorWeb.E2EHelpers

      alias IntelitorWeb.Router.Helpers, as: Routes
      alias Intelitor.{Repo, Factory}

      # Setup Chrome options for container environment
      @chrome_options [
        headless: System.get_env("HEADLESS_BROWSER", "true") == "true",
        no_sandbox: true,
        disable_dev_shm_usage: true,
        disable_gpu: true,
        window_size: "1280,720"
      ]

      setup tags do
        # Start Phoenix endpoint for E2E tests
        :ok = Ecto.Adapters.SQL.Sandbox.checkout(Intelitor.Repo)
        
        unless tags[:async] do
          Ecto.Adapters.SQL.Sandbox.mode(Intelitor.Repo, {:shared, self()})
        end

        metadata = Phoenix.Ecto.SQL.Sandbox.metadata_for(Intelitor.Repo, self())
        
        # Configure Wallaby session with retry logic
        {:ok, session} = start_wallaby_session(metadata, tags)
        
        on_exit(fn ->
          # Capture screenshot on failure
          if Map.get(tags, :failed) do
            capture_failure_screenshot(session, tags)
          end
        end)

        {:ok, session: session, metadata: metadata}
      end

      defp start_wallaby_session(metadata, tags) do
        max_retries = Map.get(tags, :retry_count, 3)
        
        Enum.reduce_while(1..max_retries, {:error, :not_started}, fn attempt, _acc ->
          case Wallaby.start_session(
                 metadata: metadata,
                 chrome: @chrome_options
               ) do
            {:ok, session} ->
              {:halt, {:ok, session}}
            
            {:error, reason} when attempt < max_retries ->
              # TPS 5-Level RCA logging
              log_wallaby_error(reason, attempt, max_retries)
              Process.sleep(1000 * attempt)
              {:cont, {:error, reason}}
            
            {:error, reason} ->
              {:halt, {:error, reason}}
          end
        end)
      end

      defp log_wallaby_error(reason, attempt, max_retries) do
        IO.puts("""
        🔍 TPS 5-Level RCA - Wallaby Session Start Failed (Attempt #{attempt}/#{max_retries})
        Level 1 - Symptom: #{inspect(reason)}
        Level 2 - Browser: Chrome/Chromedriver communication issue
        Level 3 - System: Container environment browser isolation
        Level 4 - Process: Retry with exponential backoff
        Level 5 - Root Cause: Container browser resource constraints
        """)
      end

      defp capture_failure_screenshot(session, tags) do
        test_name = Map.get(tags, :test, "unknown_test")
        timestamp = DateTime.utc_now() |> DateTime.to_unix()
        filename = "screenshots/e2e_failure_#{test_name}_#{timestamp}.png"
        
        File.mkdir_p!("screenshots")
        Wallaby.take_screenshot(session, name: filename)
        
        IO.puts("📸 Screenshot saved: #{filename}")
      end
    end
  end
end