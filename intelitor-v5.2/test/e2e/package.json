{
  "name": "indrajaal-e2e-tests",
  "version": "21.2.1",
  "description": "Puppeteer E2E tests for Indrajaal LiveView pages (37 pages, 302+ endpoints)",
  "private": true,
  "scripts": {
    "test": "jest --runInBand",
    "test:ci": "jest --ci --runInBand --reporters=default --reporters=jest-junit",
    "test:prajna": "jest --testPathPattern=prajna",
    "test:operations": "jest --testPathPattern=operations",
    "test:admin": "jest --testPathPattern=admin",
    "test:api": "jest --testPathPattern=api",
    "test:zenoh": "jest --testPathPattern=zenoh",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "puppeteer": "^22.0.0",
    "jest": "^29.7.0",
    "jest-puppeteer": "^10.0.0",
    "@types/jest": "^29.5.0",
    "@types/puppeteer": "^7.0.0",
    "jest-junit": "^16.0.0",
    "typescript": "^5.3.0",
    "axios": "^1.6.0",
    "ws": "^8.15.0",
    "@types/ws": "^8.5.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "jest": {
    "preset": "jest-puppeteer",
    "testTimeout": 60000,
    "setupFilesAfterEnv": ["./helpers/setup.ts"],
    "testMatch": ["**/*.test.ts"],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "reporters": [
      "default",
      ["jest-junit", { "outputDirectory": "./reports" }]
    ],
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/node_modules/**",
      "!**/reports/**"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
