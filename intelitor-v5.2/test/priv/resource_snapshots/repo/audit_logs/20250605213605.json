    {
      "code?": false,
      "down": "-- Hypertables cannot be easily reverted\n",
      "name": "create_hypertable",
      "up": "SELECT create_hypertable('audit_logs', 'occurred_at',\n  chunk_time_interval => interval '1 day',\n  if_not_exists => true\n);\n"
    },
    {
      "code?": false,
      "down": "SELECT remove_compression_policy('audit_logs');\n",
      "name": "add_compression_policy",
      "up": "ALTER TABLE audit_logs SET (\n  timescaledb.compress,\n  timescaledb.compress_segmentby = 'tenant_id',\n  timescaledb.compress_orderby = 'occurred_at DESC'\n);\n\nSELECT add_compression_policy('audit_logs', INTERVAL '30 days');\n"
    },
    {
      "code?": false,
      "down": "SELECT remove_retention_policy('audit_logs');\n",
      "name": "add_retention_policy",
