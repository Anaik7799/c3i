export DIRENV_WARN_TIMEOUT=20s

eval "$(devenv direnvrc)"

# Tool Configuration
export RIPGREP_CONFIG_PATH="$PWD/.ripgreprc"
export INTELITOR_CONTAINER_STRATEGY="dev"

# Editor Substrate (SC-SYS-003: Helix Migration for Stability)
export EDITOR="hx"
export VISUAL="hx"
export GIT_EDITOR="hx"

# SOPv5.11 Cybernetic Framework Environment Variables
# Phase 2 Container Infrastructure Integration

# Core SOPv5.11 Framework Settings
export SOPV511_FRAMEWORK_ENABLED=true
export SOPV511_PHASE_EXECUTION=true
export SOPV511_AGENT_COORDINATION=true
export SOPV511_CONTAINER_MODE=development

# 50-Agent Hierarchical Architecture
export AGENT_COORDINATOR_ENABLED=true
export EXECUTIVE_DIRECTOR_AGENTS=1
export DOMAIN_SUPERVISOR_AGENTS=10
export FUNCTIONAL_SUPERVISOR_AGENTS=15
export WORKER_AGENTS=24
export TOTAL_AGENTS=50

# Patient Mode Configuration (MANDATORY)
export NO_TIMEOUT=true
export PATIENT_MODE=enabled
export INFINITE_PATIENCE=true
export ELIXIR_ERL_OPTIONS="+S 16:16 +SDio 16"

# Database Configuration
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=postgres
export DATABASE_URL="ecto://postgres:postgres@localhost:5433/indrajaal_dev"

# PHICS v2.1 Hot-Reloading Integration
export PHICS_ENABLED=true
export PHICS_WATCH_ENABLED=true
export PHICS_CONTAINER_MODE=development
export PHICS_HOT_RELOAD=enabled
export PHICS_BIDIRECTIONAL_SYNC=true
export PHICS_SYNC_LATENCY_TARGET=50

# Phase 2 Container Infrastructure
export SOPV511_CONTAINER_ARCHITECTURE=phase2
export CONTAINER_COUNT=10
export TOTAL_CPU_CORES=35.9
export TOTAL_RAM_GB=66.5
export CONTAINER_REGISTRY=localhost
export CONTAINER_POLICY_ENFORCEMENT=strict

# Container Resource Allocation
export TIMESCALEDB_CPU=4.2
export TIMESCALEDB_RAM=8
export REDIS_CPU=3.0
export REDIS_RAM=5
export APP_CPU=4.0
export APP_RAM=7
export PROMETHEUS_CPU=4.2
export PROMETHEUS_RAM=8
export GRAFANA_CPU=2.8
export GRAFANA_RAM=4
export NGINX_CPU=2.0
export NGINX_RAM=3
export AGENT_SUPERVISOR_CPU=3.5
export AGENT_SUPERVISOR_RAM=6
export PHICS_COORDINATOR_CPU=2.5
export PHICS_COORDINATOR_RAM=4
export SECURITY_MONITOR_CPU=3.0
export SECURITY_MONITOR_RAM=5
export PERFORMANCE_ANALYZER_CPU=3.8
export PERFORMANCE_ANALYZER_RAM=7.5

# Cybernetic Control Configuration
export CYBERNETIC_GOALS_ENABLED=true
export AGENT_HIERARCHY_ACTIVE=true
export AUTONOMOUS_EXECUTION=true
export GOAL_ORIENTED_EXECUTION=true

# Methodology Integration
export TPS_METHODOLOGY_ENABLED=true
export STAMP_SAFETY_ENABLED=true
export TDG_COMPLIANCE_ENABLED=true
export GDE_FRAMEWORK_ENABLED=true

# Phase 6 Monitoring Integration
export COMPREHENSIVE_MONITORING=true
export REAL_TIME_ANALYTICS=true
export PREDICTIVE_MONITORING=true
export PERFORMANCE_OPTIMIZATION=true

# Phase 7 Security Integration
export ENTERPRISE_SECURITY_ENABLED=true
export COMPLIANCE_FRAMEWORKS_ACTIVE=true
export SECURITY_MONITORING_ENABLED=true
export AUDIT_LOGGING_ENABLED=true

# Logging Configuration
export CLAUDE_LOGGING_MANDATORY=true
export LOG_DIRECTORY=./data/tmp
export DUAL_LOGGING_ENABLED=true

# E2E Browser Testing (SC-COV-008)
export WALLABY_CHROME_PATH=google-chrome-unstable

# Claude Code Output Token Limit (prevent truncation)
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=31000

# --- INDRAJAAL UIP PERSISTENCE HOOK ---
# Ensures the Unified Intelligence Plane is active during every session.
export UIP_ACTIVE=true
export OPENROUTER_API_KEY=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

# Self-Verification on Shell Entry
if [ -f "scripts/reporting/uip_command_center.exs" ]; then
    echo -e "\u001b[35m[UIP] OMNIPRESENT INTELLIGENCE ACTIVE\u001b[0m"
fi

# `use devenv` supports the same options as the `devenv shell` command.
#
# To silence the output, use `--quiet`.
#
# Example usage: use devenv --quiet --impure --option services.postgres.enable:bool true
use devenv