# =============================================================================
# Tailscale DNS Centralized Configuration
# =============================================================================
#
# STAMP Compliance:
# - SC-CLU-001: Identity-based networking via Tailscale MagicDNS
# - SC-CLU-002: Minimum 3 nodes for HA
# - SC-CLU-004: EPMD binds to Tailscale IP only
# - SC-CLU-005: Split-brain prevention with consistent naming
#
# Usage:
#   source tailscale.env
#   podman-compose --env-file tailscale.env -f podman-compose.yml up -d
#
# Auto-detection (run once on each host):
#   export TAILSCALE_DNS_SUFFIX=$(tailscale status --json | jq -r '.MagicDNSSuffix // "tailnet.ts.net"')
#   export TS_IP_ADDRESS=$(tailscale ip -4 2>/dev/null || echo "127.0.0.1")
#   export TS_HOSTNAME=$(tailscale status --json | jq -r '.Self.HostName // "localhost"')
#
# =============================================================================

# Tailnet DNS suffix (from tailscale status --json | jq -r '.MagicDNSSuffix')
TAILSCALE_DNS_SUFFIX=${TAILSCALE_DNS_SUFFIX:-tail55d152.ts.net}

# Tailscale IPv4 address for EPMD binding (from tailscale ip -4)
TS_IP_ADDRESS=${TS_IP_ADDRESS:-100.78.98.18}

# Current host's Tailscale hostname (from tailscale status --json | jq -r '.Self.HostName')
TS_HOSTNAME=${TS_HOSTNAME:-vm-1}

# =============================================================================
# Container FQDN Names (Aligned with Host Tailscale Identity)
# =============================================================================
#
# Naming Convention: {service}-{TS_HOSTNAME}.{TAILSCALE_DNS_SUFFIX}
# Example: TS_HOSTNAME=vm-1, TAILSCALE_DNS_SUFFIX=tail55d152.ts.net
#          Results in: timescaledb-vm-1.tail55d152.ts.net
#
# This ensures all containers inherit the host's Tailscale identity,
# enabling proper MagicDNS resolution and identity-based access control.
#
# =============================================================================

# Database containers (host-aligned)
TS_TIMESCALEDB_FQDN=timescaledb-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}
TS_REDIS_FQDN=redis-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}

# Application containers (host-aligned)
# Single-node deployment uses host identity
TS_APP_FQDN=intelitor-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}

# Cluster nodes (for multi-host deployment, set per-host)
# Each cluster node should be on a different Tailscale host
# Node naming: intelitor-{TS_HOSTNAME}.{TAILSCALE_DNS_SUFFIX}
TS_APP_1_FQDN=intelitor-${TS_HOSTNAME:-node1}.${TAILSCALE_DNS_SUFFIX}
TS_APP_2_FQDN=intelitor-${TS_HOSTNAME:-node2}.${TAILSCALE_DNS_SUFFIX}
TS_APP_3_FQDN=intelitor-${TS_HOSTNAME:-node3}.${TAILSCALE_DNS_SUFFIX}

# Observability containers (host-aligned)
TS_PROMETHEUS_FQDN=prometheus-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}
TS_GRAFANA_FQDN=grafana-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}
TS_SIGNOZ_FQDN=signoz-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}
TS_OTEL_FQDN=otel-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}
TS_CLICKHOUSE_FQDN=clickhouse-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}

# Infrastructure containers (host-aligned)
TS_NGINX_FQDN=nginx-${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}

# =============================================================================
# Erlang Distribution Configuration
# =============================================================================

# Erlang release cookie (REQUIRED for cluster)
RELEASE_COOKIE=${RELEASE_COOKIE:-intelitor_secure_cookie}

# Application name for Erlang nodes
RELEASE_NAME=intelitor

# Erlang node naming (long names with FQDN)
# Format: intelitor@hostname.tailnet.ts.net
# Note: ERL_NODE_NAME is constructed at runtime by compose files
# ERL_NODE_NAME=${RELEASE_NAME}@${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}

# EPMD binding to Tailscale interface only (SC-CLU-004)
ERL_EPMD_ADDRESS=${TS_IP_ADDRESS}

# Erlang flags for distributed mode (set in compose files, not here)
# ERL_AFLAGS=-name intelitor@${TS_HOSTNAME}.${TAILSCALE_DNS_SUFFIX}

# =============================================================================
# Cluster Configuration (Host-Aligned)
# =============================================================================

# Minimum nodes for HA (SC-CLU-002)
CLUSTER_SIZE=3

# Cluster node hostnames (set these based on actual Tailscale hosts)
# For multi-host cluster, each host exports its own TS_HOSTNAME
# Example: host1, host2, host3 join as intelitor-host1, intelitor-host2, intelitor-host3
CLUSTER_NODE_1=${CLUSTER_NODE_1:-${TS_HOSTNAME}}
CLUSTER_NODE_2=${CLUSTER_NODE_2:-node2}
CLUSTER_NODE_3=${CLUSTER_NODE_3:-node3}

# Cluster node list (comma-separated, using host Tailscale names)
CLUSTER_NODES=intelitor-${CLUSTER_NODE_1},intelitor-${CLUSTER_NODE_2},intelitor-${CLUSTER_NODE_3}

# Full FQDNs for cluster nodes (used in libcluster config)
CLUSTER_NODE_1_FQDN=intelitor-${CLUSTER_NODE_1}.${TAILSCALE_DNS_SUFFIX}
CLUSTER_NODE_2_FQDN=intelitor-${CLUSTER_NODE_2}.${TAILSCALE_DNS_SUFFIX}
CLUSTER_NODE_3_FQDN=intelitor-${CLUSTER_NODE_3}.${TAILSCALE_DNS_SUFFIX}

# =============================================================================
# Container Resource Limits
# =============================================================================

# Application container resources
APP_CPU_LIMIT=4.0
APP_CPU_RESERVATION=2.0
APP_MEMORY_LIMIT=4G
APP_MEMORY_RESERVATION=2G

# Database container resources
DB_CPU_LIMIT=4
DB_CPU_RESERVATION=2
DB_MEMORY_LIMIT=8G
DB_MEMORY_RESERVATION=4G

# =============================================================================
# SOPv5.11 Compliance
# =============================================================================

PHICS_ENABLED=true
NO_TIMEOUT=true
CONTAINER_OS=nixos
SOPV51_COMPLIANT=true

# =============================================================================
# Container Version Requirements (SC-CNT-V01, SC-CNT-V02)
# =============================================================================
# Formal verification specs: docs/formal_specs/container_verification.agda
# Reference: CLAUDE.md §1 Axiom 2 (Container Isolation Invariant)

# Required Elixir version (1.19.x mandatory)
EXPECTED_ELIXIR_MAJOR=1
EXPECTED_ELIXIR_MINOR=19
EXPECTED_ELIXIR_PATCH=2

# Required OTP version (28.x mandatory)
EXPECTED_OTP_MAJOR=28
EXPECTED_OTP_MINOR=0
EXPECTED_OTP_PATCH=0

# Required ERTS version
EXPECTED_ERTS_MAJOR=16
EXPECTED_ERTS_MINOR=1
EXPECTED_ERTS_PATCH=1

# =============================================================================
# STAMP Container Safety Constraints
# =============================================================================
# Reference: CLAUDE.md §4.2 SC-CNT-009 to SC-CNT-014

# SC-CNT-009: Container OS must be NixOS
STAMP_CNT_009_NIXOS_REQUIRED=true

# SC-CNT-010: Registry must be localhost only
STAMP_CNT_010_LOCALHOST_REGISTRY=true

# SC-CNT-011: PHICS latency < 50ms
STAMP_CNT_011_PHICS_LATENCY_MS=50

# SC-CNT-012: Rootless execution required
STAMP_CNT_012_ROOTLESS=true

# SC-CNT-013: Health verification required before operations
STAMP_CNT_013_HEALTH_CHECK=true

# SC-CNT-014: Resource isolation maintained
STAMP_CNT_014_RESOURCE_ISOLATION=true

# =============================================================================
# Cortex Container Health Verification
# =============================================================================
# Reference: lib/intelitor/cortex/sensors/container_health_sensor.ex

# Enable Cortex container health sensor
CORTEX_CONTAINER_HEALTH_ENABLED=true

# Verification interval (milliseconds)
CORTEX_CONTAINER_HEALTH_INTERVAL_MS=60000

# Maximum verification attempts
CORTEX_CONTAINER_MAX_ATTEMPTS=3

# Failure rate threshold for stress calculation
CORTEX_CONTAINER_FAILURE_THRESHOLD=0.5
