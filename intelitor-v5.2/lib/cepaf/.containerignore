# .containerignore - Cepaf.Podman Container Build
# Excludes files from build context for faster builds

# Build outputs (will be regenerated in container)
**/bin/
**/obj/
artifacts/

# IDE and editor files
.idea/
.vs/
.vscode/
*.user
*.suo

# Test results and coverage
**/TestResults/
coverage/
*.trx

# Benchmark results
benchmarks/results/
BenchmarkDotNet.Artifacts/

# Documentation (not needed in container)
docs/

# Git (not needed in container)
.git/
.gitignore
.gitattributes

# Container files (avoid recursion)
containers/

# OS files
.DS_Store
Thumbs.db

# NuGet packages (will be restored in container)
packages/

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.tmp/
tmp/
