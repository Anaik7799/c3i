# SOPv5.11 Environment Configuration
# Updated: 2025-12-18
# Reference: CLAUDE.md §1 Axiom 2 (Container Isolation Invariant)
# Formal Specs: docs/formal_specs/container_verification.agda

# Agent: Maximum parallelization for Elixir/Erlang
export ELIXIR_ERL_OPTIONS="+S 16 +A 32"
export MAX_PARALLELIZATION=true

# Agent: Container-only execution
export CONTAINER_ENFORCEMENT=true
export CONTAINER_OS=nixos

# Agent: PHICS integration
export PHICS_ENABLED=true

# Agent: No timeout policy
export MIX_TIMEOUT=infinity
export COMPILE_TIMEOUT=0
export TEST_TIMEOUT=0
export BUILD_TIMEOUT=0
export NO_TIMEOUT=true

# Agent: Git-based approach
export GIT_AWARE_BUILDS=true

# Agent: Development paths
export MIX_HOME=/workspace/.mix
export HEX_HOME=/workspace/.hex

# =============================================================================
# Container Version Requirements (SC-CNT-V01, SC-CNT-V02)
# =============================================================================

# Required Elixir version (Elixir 1.19.2 mandatory per Agda proofs)
export EXPECTED_ELIXIR_VERSION="1.19.2"
export EXPECTED_ELIXIR_MAJOR=1
export EXPECTED_ELIXIR_MINOR=19

# Required OTP version (OTP 28 mandatory per Agda proofs)
export EXPECTED_OTP_VERSION="28"
export EXPECTED_OTP_MAJOR=28

# Required ERTS version (ERTS 16.1.1 mandatory)
export EXPECTED_ERTS_VERSION="16.1.1"
export EXPECTED_ERTS_MAJOR=16
export EXPECTED_ERTS_MINOR=1

# =============================================================================
# STAMP Container Safety Constraints (SC-CNT-009 to SC-CNT-014)
# =============================================================================

# Container runtime (Docker FORBIDDEN per AOR-CNT-001)
export CONTAINER_RUNTIME=podman
export DOCKER_FORBIDDEN=true

# Registry source (localhost only per SC-CNT-010)
export CONTAINER_REGISTRY=localhost
export EXTERNAL_REGISTRY_FORBIDDEN=true

# Rootless execution (SC-CNT-012)
export ROOTLESS_EXECUTION=true

# PHICS latency threshold in ms (SC-CNT-011)
export PHICS_LATENCY_THRESHOLD_MS=50

# =============================================================================
# Cortex Container Health Verification
# =============================================================================

# Enable Cortex container health sensor
export CORTEX_CONTAINER_HEALTH_ENABLED=true

# 7-phase verification protocol enabled
export CORTEX_7PHASE_VERIFICATION=true
