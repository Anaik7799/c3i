## Level 3: Behavioral Models

### 3.1 Alarm Lifecycle State Machine (Implemented)

```elixir
# Ash Resource State Machine Implementation
state_machine do
  initial_state :triggered
  
  state :triggered do
    # Available transitions
    on :acknowledge, to: :acknowledged do
      validate :user_authorized
      set :acknowledged_at, &DateTime.utc_now/0
      set :acknowledged_by, :actor_id
    end
    
    on :auto_resolve, to: :resolved do
      validate :low_severity_only
      set :auto_resolved, true
      set :resolved_at, &DateTime.utc_now/0
    end
    
    # Timeout behavior
    after_timeout :escalation_minutes do
      increase_severity()
      notify_next_tier()
    end
  end
  
  state :acknowledged do
    on :investigate, to: :investigating do
      set :investigating_by, :actor_id
    end
    
    on :resolve, to: :resolved do
      require :resolution_notes
      set :resolved_at, &DateTime.utc_now/0
      set :resolved_by, :actor_id
    end
    
    on :false_alarm, to: :false_alarm do
      require :false_alarm_reason
      set :resolved_at, &DateTime.utc_now/0
    end
  end
  
  state :investigating do
    on :resolve, to: :resolved
    on :escalate, to: :triggered  # Re-escalate
    on :false_alarm, to: :false_alarm
  end
  
  state :resolved, terminal: true do
    # No further transitions
    # Triggers metrics update
    # Generates reports
  end
  
  state :false_alarm, terminal: true do
    # Updates device sensitivity
    # Adjusts analytics models
    # Records for ML training
  end
end
```

### 3.2 Notification Cascade (Production Implementation)

```elixir
# Multi-Tier Notification Strategy
NotificationStrategy {
  # Tier 1: Immediate Responders
  tier_1(alarm) do
    recipients = case alarm.severity do
      :critical -> all_available_operators() ++ supervisors()
      :high -> operators_for_location(alarm.location_id)
      _ -> assigned_operators()
    end
    
    channels = case alarm.severity do
      :critical -> [:sms, :voice, :push]  # All channels
      :high -> [:sms, :push]              # Fast channels
      _ -> [:push, :email]                # Standard channels
    end
    
    notify_with_acknowledgment(recipients, channels, timeout: 60)
  end
  
  # Tier 2: Supervisors (after timeout)
  tier_2(alarm) do
    recipients = supervisors() ++ shift_managers()
    channels = [:sms, :email, :teams]
    
    notify_with_acknowledgment(recipients, channels, timeout: 180)
  end
  
  # Tier 3: Management Escalation
  tier_3(alarm) do
    recipients = site_managers() ++ security_directors()
    channels = [:voice, :sms, :email]
    
    # Critical alarms trigger immediate voice calls
    if alarm.severity == :critical do
      initiate_conference_call(recipients)
    end
    
    notify_with_tracking(recipients, channels)
  end
  
  # Quiet Hours Handling
  quiet_hours_adjustment(recipient, channels) do
    if in_quiet_hours?(recipient) && !critical_alarm? do
      channels -- [:voice, :sms]  # Remove intrusive channels
    else
      channels
    end
  end
}
```

### 3.3 Correlation Engine (Advanced Implementation)

```elixir
# 5-Dimensional Correlation Analysis
CorrelationEngine {
  # 1. Spatial Correlation
  spatial_correlation(alarm) do
    nearby_alarms = get_alarms_within_radius(
      alarm.location,
      radius: 50,  # meters
      time_window: 300  # seconds
    )
    
    patterns = [
      adjacent_zones_pattern(alarm, nearby_alarms),
      perimeter_breach_pattern(alarm, nearby_alarms),
      systematic_probe_pattern(alarm, nearby_alarms)
    ]
    
    {confidence, pattern_type} = max_confidence(patterns)
  end
  
  # 2. Temporal Correlation
  temporal_correlation(alarm) do
    time_patterns = [
      rapid_succession(alarm),      # Multiple alarms quickly
      time_of_day_pattern(alarm),   # Unusual for this time
      day_of_week_pattern(alarm),   # Unusual for this day
      holiday_pattern(alarm)        # Holiday-specific
    ]
    
    detect_anomalies(time_patterns)
  end
  
  # 3. Device Correlation
  device_correlation(alarm) do
    device_history = get_device_history(alarm.device_id, days: 7)
    
    indicators = [
      malfunction_rate(device_history),
      false_alarm_rate(device_history),
      maintenance_due(alarm.device),
      environmental_factors(alarm.device)
    ]
    
    calculate_device_reliability(indicators)
  end
  
  # 4. Attack Pattern Detection
  attack_pattern_detection(alarm) do
    patterns = [
      # Perimeter Testing
      %{
        name: :perimeter_probe,
        indicators: [
          sequential_exterior_alarms(),
          increasing_severity(),
          systematic_coverage()
        ],
        confidence_threshold: 0.7
      },
      
      # Distraction Technique
      %{
        name: :distraction_attack,
        indicators: [
          multiple_low_priority_alarms(),
          opposite_side_activity(),
          unusual_timing()
        ],
        confidence_threshold: 0.8
      },
      
      # Insider Threat
      %{
        name: :insider_threat,
        indicators: [
          after_hours_access(),
          unusual_area_access(),
          disabled_cameras()
        ],
        confidence_threshold: 0.85
      }
    ]
    
    evaluate_patterns(alarm, patterns)
  end
  
  # 5. Cross-Domain Correlation
  cross_domain_correlation(alarm) do
    correlations = []
    
    # Access Control Correlation
    if access_events = get_recent_access_events(alarm.location_id) do
      correlations ++ correlate_with_access(alarm, access_events)
    end
    
    # Video Analytics Correlation
    if video_events = get_video_analytics(alarm.location_id) do
      correlations ++ correlate_with_video(alarm, video_events)
    end
    
    # Environmental Correlation
    if env_data = get_environmental_data(alarm.location_id) do
      correlations ++ correlate_with_environment(alarm, env_data)
    end
    
    aggregate_correlations(correlations)
  end
}
```

### 3.4 Storm Detection and Mitigation

```elixir
# Alarm Storm Detection System
StormDetection {
  # Storm Severity Levels
  levels: [
    %{name: :light, threshold: 50, window: 60},      # 50 alarms/minute
    %{name: :moderate, threshold: 100, window: 60},  # 100 alarms/minute
    %{name: :severe, threshold: 200, window: 60},    # 200 alarms/minute
    %{name: :critical, threshold: 500, window: 60}   # 500 alarms/minute
  ]
  
  # Detection Algorithm
  detect_storm(tenant_id) do
    current_rate = calculate_alarm_rate(tenant_id, :last_minute)
    storm_level = determine_level(current_rate)
    
    if storm_level != :none do
      apply_mitigation(tenant_id, storm_level)
    end
  end
  
  # Mitigation Strategies
  mitigation_strategies: %{
    light: [
      :consolidate_similar_alarms,
      :delay_low_priority_notifications,
      :enable_digest_mode
    ],
    
    moderate: [
      :suppress_duplicate_alarms,
      :batch_notifications,
      :increase_correlation_window,
      :alert_operators
    ],
    
    severe: [
      :activate_summary_only_mode,
      :suppress_non_critical_alarms,
      :emergency_notification_only,
      :alert_supervisors
    ],
    
    critical: [
      :emergency_mode,
      :critical_only_processing,
      :executive_alerts,
      :initiate_incident_response,
      :consider_system_isolation
    ]
  }
}
```

