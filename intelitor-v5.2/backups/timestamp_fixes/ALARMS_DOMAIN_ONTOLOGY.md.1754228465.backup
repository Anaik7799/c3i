### 5.2 Temporal Semantics (Implementation)

```elixir
# Time-Based Business Rules
TemporalSemantics {
  # Chronological Ordering
  invariant chronological_order(alarm) do
    alarm.triggered_at <= alarm.acknowledged_at &&
    alarm.acknowledged_at <= alarm.resolved_at
  end
  
  # Response Time Contracts
  sla_requirements: %{
    critical: %{acknowledge: 30, investigate: 300, resolve: 1800},
    high: %{acknowledge: 120, investigate: 600, resolve: 3600},
    medium: %{acknowledge: 300, investigate: 1800, resolve: 7200},
    low: %{acknowledge: 900, investigate: 3600, resolve: 86400}
  }
  
  # Business Hours Rules
  business_hours_modifier(alarm) do
    cond do
      is_business_hours?(alarm.triggered_at) ->
        1.0  # Standard response
      is_after_hours?(alarm.triggered_at) ->
        1.2  # 20% severity increase
      is_weekend?(alarm.triggered_at) ->
        1.3  # 30% severity increase
      is_holiday?(alarm.triggered_at) ->
        1.5  # 50% severity increase
    end
  end
  
  # Escalation Timing
  escalation_schedule(alarm) do
    base_timeout = sla_requirements[alarm.severity][:acknowledge]
    
    %{
      tier_1: base_timeout,
      tier_2: base_timeout * 2,
      tier_3: base_timeout * 3,
      executive: base_timeout * 5
    }
  end
  
  # Pattern Detection Windows
  correlation_windows: %{
    rapid_succession: 60,      # seconds
    spatial_proximity: 300,    # seconds
    attack_pattern: 900,       # seconds
    device_malfunction: 3600   # seconds
  }
}
```

### 5.3 Invariants and Constraints (Enforced)

```elixir
# Domain Invariants (Ash Validations)
DomainInvariants {
  # Every alarm must be acknowledged
  validation acknowledge_requirement do
    validate alarm.state != :triggered || 
            DateTime.diff(now(), alarm.triggered_at) < sla_timeout
    error_message "Alarm must be acknowledged within SLA"
  end
  
  # Resolution requires details
  validation resolution_completeness do
    validate alarm.state != :resolved || 
            (alarm.resolution_notes != nil && alarm.resolved_by != nil)
    error_message "Resolution requires notes and resolver"
  end
  
  # Severity only increases
  validation severity_monotonicity do
    validate new_severity >= old_severity
    error_message "Severity cannot be decreased"
  end
  
  # Location validity
  validation location_validity do
    validate alarm.site_id in tenant.sites ||
            alarm.zone_id in tenant.zones
    error_message "Alarm location must be valid for tenant"
  end
  
  # Correlation group consistency
  validation correlation_consistency do
    validate all_alarms_in_group_have_same_tenant()
    error_message "Correlated alarms must belong to same tenant"
  end
}

# Operational Constraints (System Limits)
OperationalConstraints {
  rate_limits: %{
    alarms_per_minute: 1000,
    notifications_per_alarm: 50,
    correlation_window_size: 100,
    workflow_depth: 10,
    escalation_tiers: 5
  }
  
  resource_limits: %{
    max_active_alarms: 10_000,
    max_notification_retries: 3,
    max_correlation_groups: 1_000,
    max_workflow_steps: 50
  }
  
  performance_targets: %{
    alarm_processing_p99: 1000,    # milliseconds
    notification_delivery_p99: 3000,
    api_response_p99: 100,
    correlation_analysis_p99: 500
  }
}
```

