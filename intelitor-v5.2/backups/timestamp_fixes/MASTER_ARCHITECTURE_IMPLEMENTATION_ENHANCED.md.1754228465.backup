## 6. Security Architecture

### 6.1 Authentication & Authorization

#### 6.1.1 Multi-Factor Authentication

```elixir
defmodule Intelitor.Accounts.Authentication do
  def authenticate_user(email, password, mfa_token \\ nil) do
    with {:ok, user} <- verify_credentials(email, password),
         :ok <- verify_mfa_if_required(user, mfa_token),
         {:ok, session} <- create_session(user) do
      {:ok, user, session}
    end
  end
  
  defp verify_mfa_if_required(user, nil) when user.mfa_enabled?, do: {:error, :mfa_required}
  defp verify_mfa_if_required(user, token) when user.mfa_enabled? do
    verify_totp_token(user.mfa_secret, token)
  end
  defp verify_mfa_if_required(_user, _token), do: :ok
end
```

#### 6.1.2 Role-Based Access Control

```elixir
defmodule Intelitor.Policy.Authorization do
  def authorize_action(actor, resource, action) do
    with {:ok, roles} <- get_actor_roles(actor),
         {:ok, permissions} <- get_role_permissions(roles),
         :ok <- check_permission(permissions, resource, action) do
      :ok
    else
      {:error, reason} -> {:error, :unauthorized, reason}
    end
  end
  
  defp check_permission(permissions, resource, action) do
    required_permission = "#{resource}:#{action}"
    
    if required_permission in permissions do
      :ok
    else
      {:error, "Missing permission: #{required_permission}"}
    end
  end
end
```

### 6.2 Data Security

#### 6.2.1 Encryption at Rest

```elixir
defmodule Intelitor.Security.Encryption do
  @key_derivation_iterations 100_000
  
  def encrypt_sensitive_data(data, tenant_id) do
    key = derive_tenant_key(tenant_id)
    :crypto.crypto_one_time(:aes_256_gcm, key, generate_iv(), data, true)
  end
  
  def decrypt_sensitive_data(encrypted_data, tenant_id) do
    key = derive_tenant_key(tenant_id)
    :crypto.crypto_one_time(:aes_256_gcm, key, extract_iv(encrypted_data), encrypted_data, false)
  end
  
  defp derive_tenant_key(tenant_id) do
    :crypto.pbkdf2_hmac(:sha256, get_master_key(), tenant_id, @key_derivation_iterations, 32)
  end
end
```

