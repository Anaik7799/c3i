## 3. Technology Stack & Implementation

### 3.1 Core Technology Stack

| Layer | Technology | Version | Purpose |
|-------|------------|---------|---------|
| **Runtime** | Elixir/Erlang | 1.18.1/OTP 27 | Concurrent, fault-tolerant execution |
| **Framework** | Ash Framework | 3.5.15 | Resource modeling, business logic |
| **Web Framework** | Phoenix | 1.7 | Web application and API layer |
| **Database** | PostgreSQL | 17 | Multi-tenant data persistence |
| **Cache** | Redis | 7+ | Session and application caching |
| **Jobs** | Oban | 2.17+ | Background job processing |
| **API** | GraphQL + JSON:API | Latest | Dual endpoint architecture |
| **Authentication** | Ash Authentication | 4.2+ | Multi-tenant auth with RBAC |
| **State Management** | Ash State Machine | 0.2+ | Workflow and lifecycle management |
| **PubSub** | Phoenix PubSub | PostgreSQL/PG2 | Real-time messaging |
| **Development** | devenv.sh + Nix | Latest | Reproducible development environment |

### 3.2 Ash Framework Implementation Patterns

#### 3.2.1 Resource Definition Pattern

```elixir
defmodule Intelitor.Alarms.AlarmEvent do
  use Intelitor.BaseResource,
    domain: Intelitor.Alarms,
    table: "alarm_events"

  use Intelitor.Multitenancy.TenantResource
  
  attributes do
    uuid_primary_key :id
    
    attribute :event_type, :atom do
      constraints one_of: [:motion, :door_open, :glass_break, :panic]
      allow_nil? false
      public? true
    end
    
    attribute :severity, :atom do
      constraints one_of: [:low, :medium, :high, :critical]
      default :medium
      public? true
    end
    
    attribute :status, :atom do
      constraints one_of: [:new, :acknowledged, :investigating, :resolved]
      default :new
      public? true
    end
    
    timestamps()
  end
  
  actions do
    defaults [:read]
    
    create :trigger do
      accept [:event_type, :severity, :source_device_id]
      
      change fn changeset, context ->
        changeset
        |> Ash.Changeset.force_change_attribute(:status, :new)
        |> Ash.Changeset.force_change_attribute(:triggered_at, DateTime.utc_now())
      end
      
      change notify(:alarm_triggered)
    end
    
    update :acknowledge do
      require_atomic? false
      accept []
      
      validate attribute_equals(:status, :new)
      
      change fn changeset, context ->
        changeset
        |> Ash.Changeset.force_change_attribute(:status, :acknowledged)
        |> Ash.Changeset.force_change_attribute(:acknowledged_at, DateTime.utc_now())
        |> Ash.Changeset.force_change_attribute(:acknowledged_by, context.actor.id)
      end
    end
  end
  
  relationships do
    belongs_to :device, Intelitor.Devices.Device do
      allow_nil? false
      attribute_public? true
    end
    
    has_many :responses, Intelitor.Alarms.Response
  end
  
  policies do
    bypass always() do
      authorize_if actor_attribute_equals(:role, "admin")
    end
    
    policy action(:read) do
      authorize_if actor_attribute_equals(:role, "operator")
      authorize_if actor_attribute_equals(:role, "viewer")
    end
    
    policy action(:trigger) do
      authorize_if actor_attribute_equals(:role, "operator")
    end
  end
end
```

#### 3.2.2 Domain Definition Pattern

```elixir
defmodule Intelitor.Alarms do
  @moduledoc """
  The Alarms domain manages security events, incidents, and response workflows.
  
  This domain provides comprehensive alarm management capabilities including:
  - Real-time alarm processing and correlation
  - Automated response workflows and notifications
  - Incident lifecycle management and reporting
  """
  
  use Intelitor.BaseDomain, name: "alarms"
  
  resources do
    resource Intelitor.Alarms.AlarmEvent
    resource Intelitor.Alarms.IncidentType
    resource Intelitor.Alarms.Notification
    resource Intelitor.Alarms.Response
    resource Intelitor.Alarms.WorkflowTemplate
    resource Intelitor.Alarms.DispatchLog
  end
  
  policies do
    bypass always() do
      authorize_if actor_attribute_equals(:role, "admin")
    end
  end
end
```

### 3.3 Database Implementation

#### 3.3.1 Multi-Tenant Schema Design

```sql
-- Example table structure with multi-tenancy
CREATE TABLE alarm_events (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  tenant_id UUID NOT NULL REFERENCES tenants(id),
  device_id UUID NOT NULL REFERENCES devices(id),
  event_type TEXT NOT NULL,
  severity TEXT NOT NULL DEFAULT 'medium',
  status TEXT NOT NULL DEFAULT 'new',
  triggered_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  acknowledged_at TIMESTAMPTZ,
  acknowledged_by UUID REFERENCES users(id),
  resolved_at TIMESTAMPTZ,
  resolved_by UUID REFERENCES users(id),
  metadata JSONB DEFAULT '{}',
  inserted_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- Multi-tenant indexes
CREATE INDEX alarm_events_tenant_device_idx ON alarm_events (tenant_id, device_id);
CREATE INDEX alarm_events_tenant_status_idx ON alarm_events (tenant_id, status);
CREATE INDEX alarm_events_triggered_at_idx ON alarm_events (triggered_at);

-- Row Level Security
ALTER TABLE alarm_events ENABLE ROW LEVEL SECURITY;

CREATE POLICY alarm_events_tenant_isolation ON alarm_events
FOR ALL TO public
USING (tenant_id::text = current_setting('app.current_tenant_id', true));
```

