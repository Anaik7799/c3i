## 7. Integration Architecture

### 7.1 Event-Driven Integration

#### 7.1.1 Domain Event Pattern

```elixir
defmodule Intelitor.Events.DomainEvent do
  @type t :: %__MODULE__{
    id: String.t(),
    event_type: String.t(),
    aggregate_id: String.t(),
    tenant_id: String.t(),
    data: map(),
    metadata: map(),
    occurred_at: DateTime.t()
  }
  
  defstruct [:id, :event_type, :aggregate_id, :tenant_id, :data, :metadata, :occurred_at]
  
  def publish(event) do
    # Publish to internal PubSub
    Phoenix.PubSub.broadcast(
      Intelitor.PubSub, 
      topic_for_event(event), 
      {:domain_event, event}
    )
    
    # Store for event sourcing
    store_event(event)
    
    # External webhook notifications
    notify_external_systems(event)
  end
end
```

#### 7.1.2 Cross-Domain Communication

```elixir
defmodule Intelitor.Alarms.Handlers.AlarmEventHandler do
  use GenServer
  
  def start_link(opts) do
    GenServer.start_link(__MODULE__, opts, name: __MODULE__)
  end
  
  def init(_opts) do
    Phoenix.PubSub.subscribe(Intelitor.PubSub, "alarms:*")
    {:ok, %{}}
  end
  
  def handle_info({:alarm_triggered, alarm}, state) do
    # Trigger video recording
    Video.Services.RecordingManager.start_emergency_recording(alarm.device_id, alarm.tenant_id)
    
    # Dispatch response team
    Dispatch.Services.ResponseCoordinator.dispatch_for_alarm(alarm)
    
    # Send notifications
    Communication.Services.NotificationManager.send_alarm_notifications(alarm)
    
    {:noreply, state}
  end
end
```

### 7.2 External API Integration

#### 7.2.1 Webhook Management

```elixir
defmodule Intelitor.Integrations.WebhookManager do
  def deliver_webhook(webhook, event_data) do
    with {:ok, payload} <- prepare_payload(webhook, event_data),
         {:ok, signature} <- sign_payload(payload, webhook.secret_key),
         {:ok, response} <- send_webhook(webhook.url, payload, signature) do
      log_webhook_success(webhook, response)
      {:ok, response}
    else
      {:error, reason} ->
        log_webhook_failure(webhook, reason)
        schedule_retry(webhook, event_data)
        {:error, reason}
    end
  end
  
  defp send_webhook(url, payload, signature) do
    headers = [
      {"content-type", "application/json"},
      {"x-webhook-signature", signature},
      {"user-agent", "Intelitor-Webhooks/1.0"}
    ]
    
    HTTPoison.post(url, Jason.encode!(payload), headers, timeout: 30_000)
  end
end
```

