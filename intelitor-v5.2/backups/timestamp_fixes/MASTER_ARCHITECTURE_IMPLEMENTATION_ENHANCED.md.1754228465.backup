## 11. Deployment Architecture

### 11.1 Containerized Deployment Strategy

#### 11.1.1 NixOS Base Images

```dockerfile
# Dockerfile.nix-base
FROM nixos/nix:latest

# Install required Nix packages
RUN nix-env -iA nixpkgs.elixir_1_18 \
    nixpkgs.erlang_27 \
    nixpkgs.postgresql_17 \
    nixpkgs.openssl \
    nixpkgs.git

# Set environment variables
ENV MIX_ENV=prod
ENV DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intelitor_prod
ENV SECRET_KEY_BASE=generated_secret_key

# Copy application code
COPY . /app
WORKDIR /app

# Install dependencies and compile
RUN mix deps.get --only prod
RUN mix compile
RUN mix assets.deploy

# Create release
RUN mix release

CMD ["_build/prod/rel/intelitor/bin/intelitor", "start"]
```

#### 11.1.2 Docker Compose Configuration

```yaml
# docker-compose.prod.yml
version: '3.8'

services:
  app:
    build:
      context: .
      dockerfile: Dockerfile.nix-base
    ports:
      - "4000:4000"
    environment:
      - MIX_ENV=prod
      - DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/intelitor_prod
      - REDIS_URL=redis://redis:6379/0
    depends_on:
      - db
      - redis
    restart: unless-stopped

  db:
    image: postgres:17
    environment:
      - POSTGRES_DB=intelitor_prod
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    restart: unless-stopped

  nginx:
    image: nginx:alpine
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf
      - ./ssl:/etc/nginx/ssl
    depends_on:
      - app
    restart: unless-stopped

volumes:
  postgres_data:
```

### 11.2 Kubernetes Deployment

#### 11.2.1 Kubernetes Manifests

```yaml
# k8s/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: intelitor-app
spec:
  replicas: 3
  selector:
    matchLabels:
      app: intelitor-app
  template:
    metadata:
      labels:
        app: intelitor-app
    spec:
      containers:
      - name: intelitor
        image: intelitor/app:latest
        ports:
        - containerPort: 4000
        env:
        - name: DATABASE_URL
          valueFrom:
            secretKeyRef:
              name: intelitor-secrets
              key: database-url
        - name: SECRET_KEY_BASE
          valueFrom:
            secretKeyRef:
              name: intelitor-secrets
              key: secret-key-base
        resources:
          requests:
            memory: "1Gi"
            cpu: "500m"
          limits:
            memory: "2Gi"
            cpu: "1000m"
        livenessProbe:
          httpGet:
            path: /health
            port: 4000
          initialDelaySeconds: 30
          periodSeconds: 10
        readinessProbe:
          httpGet:
            path: /health
            port: 4000
          initialDelaySeconds: 5
          periodSeconds: 5
```

