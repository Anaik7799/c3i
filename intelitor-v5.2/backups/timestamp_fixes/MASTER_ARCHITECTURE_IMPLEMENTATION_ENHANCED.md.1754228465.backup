## 5. Multi-Tenant Architecture

### 5.1 Tenant Isolation Strategy

#### 5.1.1 Row-Level Security Implementation

```elixir
defmodule Intelitor.Multitenancy.TenantResource do
  @moduledoc """
  Mixin that adds multi-tenancy support to any Ash resource
  """
  
  defmacro __using__(_opts) do
    quote do
      attributes do
        attribute :tenant_id, :uuid do
          allow_nil? false
          public? true
        end
      end
      
      postgres do
        custom_indexes do
          index [:tenant_id]
        end
      end
      
      policies do
        # Tenant isolation at policy level
        policy action_type([:read, :update, :destroy]) do
          authorize_if expr(tenant_id == ^actor(:tenant_id))
        end
        
        policy action_type(:create) do
          change set_attribute(:tenant_id, ^actor(:tenant_id))
        end
      end
    end
  end
end
```

#### 5.1.2 Tenant Context Management

```elixir
defmodule Intelitor.Multitenancy.Middleware do
  @behaviour Plug
  
  def init(opts), do: opts
  
  def call(conn, _opts) do
    with {:ok, tenant_id} <- extract_tenant_id(conn),
         {:ok, tenant} <- validate_tenant(tenant_id) do
      conn
      |> assign(:current_tenant, tenant)
      |> put_session("tenant_id", tenant.id)
      |> put_tenant_context(tenant)
    else
      {:error, :no_tenant} -> 
        conn |> send_resp(404, "Tenant not found") |> halt()
      {:error, :inactive_tenant} -> 
        conn |> send_resp(403, "Tenant inactive") |> halt()
    end
  end
  
  defp put_tenant_context(conn, tenant) do
    # Set PostgreSQL session variable for RLS
    Ecto.Adapters.SQL.query!(
      Intelitor.Repo, 
      "SET app.current_tenant_id = $1", 
      [tenant.id]
    )
    
    # Set process dictionary for Ash context
    Process.put(:current_tenant_id, tenant.id)
    
    # Set OpenTelemetry attributes
    OpenTelemetry.Span.set_attributes([
      {"tenant.id", tenant.id},
      {"tenant.name", tenant.name}
    ])
    
    conn
  end
end
```

### 5.2 Data Isolation Patterns

#### 5.2.1 Query Scoping

```elixir
defmodule Intelitor.Alarms.Services.AlarmManagement do
  def list_alarms(tenant_id, opts \\ []) do
    Intelitor.Alarms.AlarmEvent
    |> Ash.Query.filter(tenant_id == ^tenant_id)
    |> Ash.Query.filter(^opts[:filters] || [])
    |> Ash.read!()
  end
  
  def get_alarm!(alarm_id, tenant_id) do
    Intelitor.Alarms.AlarmEvent
    |> Ash.Query.filter(id == ^alarm_id and tenant_id == ^tenant_id)
    |> Ash.read_one!()
  end
end
