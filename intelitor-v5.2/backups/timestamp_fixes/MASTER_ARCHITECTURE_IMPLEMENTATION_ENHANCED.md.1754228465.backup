### 9.3 Performance Testing

#### 9.3.1 Load Testing

```elixir
defmodule Intelitor.LoadTest.AlarmProcessing do
  use ExUnit.Case
  
  @moduletag :load_test
  @moduletag timeout: 300_000  # 5 minutes
  
  test "system handles 1000 concurrent alarms" do
    tenant = insert(:tenant)
    devices = insert_list(100, :device, tenant: tenant)
    
    # Create 1000 concurrent alarm creation tasks
    tasks = 
      1..1000
      |> Enum.map(fn _ ->
        device = Enum.random(devices)
        Task.async(fn ->
          Intelitor.Alarms.AlarmEvent.trigger(%{
            event_type: :motion,
            severity: :medium,
            source_device_id: device.id
          })
        end)
      end)
    
    # Wait for all tasks to complete
    results = Enum.map(tasks, &Task.await(&1, 30_000))
    
    # Verify all alarms were created successfully
    successful_results = Enum.count(results, &match?({:ok, _}, &1))
    assert successful_results >= 950  # 95% success rate minimum
    
    # Verify database consistency
    alarm_count = Intelitor.Alarms.AlarmEvent.count!(tenant_id: tenant.id)
    assert alarm_count >= 950
  end
end
```

