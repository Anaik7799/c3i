### 4.2 WebSocket & Real-Time Architecture

#### 4.2.1 Phoenix Channels

```elixir
defmodule IntelitorWeb.AlarmChannel do
  use Phoenix.Channel
  
  def join("alarms:" <> tenant_id, _params, socket) do
    if authorized?(socket.assigns.user, tenant_id) do
      Phoenix.PubSub.subscribe(Intelitor.PubSub, "alarms:#{tenant_id}")
      {:ok, socket}
    else
      {:error, %{reason: "unauthorized"}}
    end
  end
  
  def handle_info({:alarm_triggered, alarm}, socket) do
    push(socket, "alarm_triggered", %{
      id: alarm.id,
      event_type: alarm.event_type,
      severity: alarm.severity,
      device_id: alarm.device_id,
      triggered_at: alarm.triggered_at
    })
    {:noreply, socket}
  end
end
```

#### 4.2.2 PubSub Architecture

```elixir
defmodule Intelitor.Events.PubSubManager do
  @moduledoc """
  Manages real-time event broadcasting across the system
  """
  
  # Dual-adapter strategy for different use cases
  def broadcast_security_event(tenant_id, event_type, data) do
    # Critical security events use PostgreSQL adapter (persistent)
    Phoenix.PubSub.broadcast(
      Intelitor.PubSub,
      "security:#{tenant_id}",
      {:security_event, event_type, data},
      adapter: Phoenix.PubSub.PG2
    )
  end
  
  def broadcast_realtime_update(tenant_id, resource_type, data) do
    # Real-time updates use PG2 adapter (fast)
    Phoenix.PubSub.broadcast(
      Intelitor.PubSub,
      "updates:#{tenant_id}:#{resource_type}",
      {:resource_updated, data}
    )
  end
end
```

### 4.3 API Security & Rate Limiting

#### 4.3.1 Authentication Middleware

```elixir
defmodule IntelitorWeb.Plugs.AuthenticateAPI do
  @behaviour Plug
  
  def init(opts), do: opts
  
  def call(conn, _opts) do
    with ["Bearer " <> token] <- get_req_header(conn, "authorization"),
         {:ok, claims} <- verify_jwt_token(token),
         {:ok, user} <- load_user(claims["sub"]) do
      conn
      |> assign(:current_user, user)
      |> assign(:actor, user)
    else
      _ ->
        conn
        |> put_status(:unauthorized)
        |> Phoenix.Controller.json(%{error: "Invalid authentication"})
        |> halt()
    end
  end
end
```

#### 4.3.2 Rate Limiting

```elixir
defmodule IntelitorWeb.Plugs.RateLimit do
  use PlugAttack
  
  rule "by ip", conn do
    conn.remote_ip
    |> tuple_to_list()
    |> Enum.join(".")
  end |> throttle(period: 60_000, limit: 100)
  
  rule "by user", conn do
    if user = conn.assigns[:current_user] do
      user.id
    end
  end |> throttle(period: 60_000, limit: 1000)
end
```

