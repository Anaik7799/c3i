## 10. Performance & Scalability

### 10.1 Database Performance

#### 10.1.1 Indexing Strategy

```sql
-- Primary tenant isolation indexes
CREATE INDEX CONCURRENTLY idx_alarm_events_tenant_id ON alarm_events (tenant_id);

-- Composite indexes for common query patterns
CREATE INDEX CONCURRENTLY idx_alarm_events_tenant_status 
ON alarm_events (tenant_id, status) 
WHERE status IN ('new', 'acknowledged');

-- Partial indexes for active data
CREATE INDEX CONCURRENTLY idx_alarm_events_active 
ON alarm_events (tenant_id, triggered_at) 
WHERE status != 'resolved';

-- JSONB indexes for metadata queries
CREATE INDEX CONCURRENTLY idx_alarm_events_metadata_gin 
ON alarm_events USING gin (metadata);
```

#### 10.1.2 Query Optimization

```elixir
defmodule Intelitor.Alarms.Queries.OptimizedQueries do
  def recent_alarms_for_tenant(tenant_id, limit \\ 50) do
    from a in Intelitor.Alarms.AlarmEvent,
      where: a.tenant_id == ^tenant_id,
      where: a.status in ["new", "acknowledged"],
      order_by: [desc: a.triggered_at],
      limit: ^limit,
      preload: [:incident_type]
  end
  
  def alarm_statistics_by_type(tenant_id, date_range) do
    from a in Intelitor.Alarms.AlarmEvent,
      where: a.tenant_id == ^tenant_id,
      where: a.triggered_at >= ^date_range.start,
      where: a.triggered_at <= ^date_range.end,
      group_by: a.event_type,
      select: {a.event_type, count(a.id)}
  end
end
```

### 10.2 Caching Strategy

#### 10.2.1 Multi-Level Caching

```elixir
defmodule Intelitor.Cache.Manager do
  @cache_ttl 3600  # 1 hour
  
  def get_tenant_config(tenant_id) do
    cache_key = "tenant_config:#{tenant_id}"
    
    case Cachex.get(:intelitor_cache, cache_key) do
      {:ok, nil} ->
        config = fetch_tenant_config_from_db(tenant_id)
        Cachex.put(:intelitor_cache, cache_key, config, ttl: @cache_ttl)
        config
      {:ok, config} ->
        config
    end
  end
  
  def invalidate_tenant_config(tenant_id) do
    cache_key = "tenant_config:#{tenant_id}"
    Cachex.del(:intelitor_cache, cache_key)
  end
end
```

### 10.3 Real-Time Performance

#### 10.3.1 PubSub Optimization

```elixir
defmodule Intelitor.PubSub.Optimization do
  @moduledoc """
  Optimized PubSub patterns for high-throughput scenarios
  """
  
  def broadcast_to_tenant(tenant_id, event_type, data) do
    # Tenant-specific topic to avoid cross-tenant message processing
    topic = "tenant:#{tenant_id}:#{event_type}"
    
    Phoenix.PubSub.broadcast(
      Intelitor.PubSub,
      topic,
      {:event, event_type, data}
    )
  end
  
  def subscribe_to_tenant_events(tenant_id, event_types) do
    Enum.each(event_types, fn event_type ->
      topic = "tenant:#{tenant_id}:#{event_type}"
      Phoenix.PubSub.subscribe(Intelitor.PubSub, topic)
    end)
  end
end
```

