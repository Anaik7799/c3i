## 12. Operational Architecture

### 12.1 Monitoring & Observability

#### 12.1.1 Telemetry Integration

```elixir
defmodule Intelitor.Telemetry do
  def setup do
    events = [
      [:intelitor, :alarm, :triggered],
      [:intelitor, :user, :authenticated],
      [:intelitor, :device, :status_changed],
      [:intelitor, :video, :recording_started]
    ]
    
    :telemetry.attach_many(
      "intelitor-telemetry",
      events,
      &handle_event/4,
      nil
    )
  end
  
  def handle_event([:intelitor, :alarm, :triggered], measurements, metadata, _config) do
    # Send metrics to monitoring system
    :prometheus_counter.inc(:alarm_events_total, [metadata.tenant_id, metadata.event_type])
    
    # Log structured event
    Logger.info("Alarm triggered", 
      tenant_id: metadata.tenant_id,
      alarm_id: metadata.alarm_id,
      event_type: metadata.event_type,
      severity: metadata.severity
    )
  end
end
```

#### 12.1.2 Health Checks

```elixir
defmodule IntelitorWeb.HealthController do
  use IntelitorWeb, :controller
  
  def show(conn, _params) do
    health_status = %{
      status: "healthy",
      timestamp: DateTime.utc_now(),
      checks: %{
        database: check_database(),
        redis: check_redis(),
        pubsub: check_pubsub(),
        domains: check_domains()
      }
    }
    
    status_code = if all_healthy?(health_status.checks), do: 200, else: 503
    
    conn
    |> put_status(status_code)
    |> json(health_status)
  end
  
  defp check_database do
    try do
      Intelitor.Repo.query!("SELECT 1")
      %{status: "healthy", response_time_ms: 0}
    rescue
      _ -> %{status: "unhealthy", error: "Database connection failed"}
    end
  end
end
```

### 12.2 Background Job Processing

#### 12.2.1 Oban Job Management

```elixir
defmodule Intelitor.Workers.AlarmProcessor do
  use Oban.Worker, queue: :alarms, max_attempts: 3
  
  @impl Oban.Worker
  def perform(%Oban.Job{args: %{"alarm_id" => alarm_id, "tenant_id" => tenant_id}}) do
    with {:ok, alarm} <- get_alarm(alarm_id, tenant_id),
         :ok <- process_alarm_workflow(alarm),
         :ok <- notify_stakeholders(alarm) do
      :ok
    else
      {:error, reason} ->
        Logger.error("Alarm processing failed", 
          alarm_id: alarm_id, 
          tenant_id: tenant_id, 
          reason: reason
        )
        {:error, reason}
    end
  end
  
  defp process_alarm_workflow(alarm) do
    # Complex alarm processing logic
    case alarm.severity do
      :critical -> handle_critical_alarm(alarm)
      :high -> handle_high_alarm(alarm)
      _ -> handle_standard_alarm(alarm)
    end
  end
end
```

