defmodule SimpleContainerPolicyScanner do
  def scan do
    IO.puts("🔍 Scanning project for container policy violations...")
    
    violations = scan_files()
    
    case violations do
      [] ->
        IO.puts("✅ #{HierarchicalNumbering.format_task_id(1, 1)} - #{HierarchicalNumbering.format_task_id(1, 1)} - No container policy violations detected")
        :ok
      violations ->
        IO.puts("❌ Container policy violations found:")
        Enum.each(violations, fn {file_path, line_num, line_content} ->
          IO.puts("  " <> file_path <> ":" <> Integer.to_string(line_num) <> " - " <> String.trim(line_content))
        end)
        {:violations, violations}
    end
  end
  
  defp scan_files do
    banned_patterns = ["docker", "lxc", "lxd", "containerd", "systemd-nspawn"]
    
    Path.wildcard("**/*.{ex,exs,sh,yml,yaml}")
    |> Enum.reject(fn path -> String.contains?(path, ".git/") or String.contains?(path, "_build/") end)
    |> Enum.flat_map(fn file_path ->
      scan_file(file_path, banned_patterns)
    end)
  end
  
  defp scan_file(file_path, banned_patterns) do
    case File.read(file_path) do
      {:ok, content} ->
        content
        |> String.split("\n")
        |> Enum.with_index(1)
        |> Enum.flat_map(fn {line, line_num} ->
          if Enum.any?(banned_patterns, &String.contains?(line, &1)) do
            [{file_path, line_num, line}]
          else
            []
          end
        end)
      _ ->
        []
    end
  end
end

SimpleContainerPolicyScanner.scan()
