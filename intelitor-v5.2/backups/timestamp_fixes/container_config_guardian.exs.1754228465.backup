  ## Agent Notes
  Establishes directory structure and support systems:
  - Protection database for tracking changes
  - Backup storage with retention policies
  - Audit log system with tamper detection
  - Recovery tools and procedures
  """
  def create_protection_infrastructure do
    IO.puts """
    🏗️ CREATING PROTECTION INFRASTRUCTURE
    ====================================
    
    ## Infrastructure Components
    
    ### Protection Database
    📁 Creating: data/protection/guardian_db/
    • File integrity records
    • Change authorization tracking
    • Audit trail storage
    • Recovery point management
    
    ### Backup Storage System
    📁 Creating: data/protection/backups/
    • Automatic file versioning
    • Retention policy enforcement
    • Compression and deduplication
    • Emergency recovery snapshots
    
    ### Audit and Logging
    📁 Creating: data/protection/audit/
    • Tamper-evident log files
    • Change request tracking
    • Approval workflow records
    • Security incident documentation
    
    ### Recovery Tools
    📁 Creating: data/protection/recovery/
    • Automated recovery scripts
    • Configuration validation tools
    • Emergency contact procedures
    • System restoration utilities
    """

    # Create directory structure
    protection_dirs = [
      "data/protection/guardian_db",
      "data/protection/backups/daily",
      "data/protection/backups/weekly", 
      "data/protection/backups/monthly",
      "data/protection/audit/changes",
      "data/protection/audit/violations",
      "data/protection/audit/approvals",
      "data/protection/recovery/snapshots",
      "data/protection/recovery/tools",
      "data/protection/monitoring/realtime",
      "data/protection/monitoring/reports"
    ]

    Enum.each(protection_dirs, fn dir ->
      File.mkdir_p!(dir)
      IO.puts "  ✅ Created: #{dir}"
    end)

    # Create initial configuration files
    create_guardian_config()
    create_protection_manifest()
    
    IO.puts "\n✅ Protection infrastructure created successfully"
  end

  @doc """
  Generates baseline checksums for all protected files.
  
  ## Agent Notes
  Creates cryptographic fingerprints for integrity validation:
  - SHA-256 checksums for tamper detection
  - Metadata capture (size, permissions, timestamp)
  - Version control integration
  - Baseline validation against known-good states
  """
  def generate_baseline_checksums do
    IO.puts """
    🔐 GENERATING BASELINE CHECKSUMS
    ===============================
    
    ## Checksum Generation Process
    """

    baseline_data = %{
      generation_date: DateTime.utc_now(),
      algorithm: @protection_config.hash_algorithm,
      files: %{}
    }

    protected_files = expand_protected_files()
    
    updated_baseline = Enum.reduce(protected_files, baseline_data, fn file_path, acc ->
      if File.exists?(file_path) do
        checksum_data = generate_file_checksum(file_path)
        IO.puts "  ✅ #{file_path}: #{checksum_data.checksum}"
        
        put_in(acc, [:files, file_path], checksum_data)
      else
        IO.puts "  ⚠️ #{file_path}: File not found (will be monitored for creation)"
        acc
      end
    end)

    # Save baseline to protection database using native serialization
    baseline_file = "data/protection/guardian_db/baseline_checksums.dat"
    
    # Use native Elixir serialization (no external dependencies)
    baseline_binary = :erlang.term_to_binary(updated_baseline, [:compressed])
    File.write!(baseline_file, baseline_binary)
    
    # Also create human-readable version for debugging
    baseline_formatted = "data/protection/guardian_db/baseline_checksums.txt"
    formatted_content = """
    # Container Configuration Guardian Baseline Checksums
    # Generated: #{DateTime.utc_now()}
    # Format: Native Elixir serialization with formatted output
    
    #{inspect(updated_baseline, pretty: true, limit: :infinity)}
    """
    File.write!(baseline_formatted, formatted_content)
    
    IO.puts """
    
    📊 Baseline Generation Summary:
    • Files Processed: #{map_size(updated_baseline.files)}
    • Algorithm: #{@protection_config.hash_algorithm}
    • Baseline Saved: #{baseline_file}
    • Next Validation: Continuous monitoring active
    
    ✅ Baseline checksums generated and stored securely
    """
  end

  @doc """
  Sets up real-time monitoring systems for protected files.
  
  ## Agent Notes
  Implements continuous monitoring with immediate detection:
  - File system event monitoring
  - Periodic integrity checking
  - Change pattern analysis
  - Integration with alert systems
  """
  def setup_monitoring_systems do
    IO.puts """
    👁️ SETTING UP MONITORING SYSTEMS
    ================================
    
    ## Monitoring Components
    
    ### Real-Time File System Monitoring
    • inotify-based change detection
    • Recursive directory monitoring
    • Event filtering and classification
    • Immediate integrity validation
    
    ### Periodic Integrity Checking
    • Hourly checksum validation
    • Daily comprehensive scans
    • Weekly deep analysis
    • Monthly security audits
    
    ### Pattern Analysis Engine
    • Change frequency monitoring
    • Unauthorized access detection
    • Anomaly pattern recognition
    • Threat intelligence integration
    
    ### Integration Monitoring
    • Container compliance system health
    • STAMP safety constraint monitoring
    • SOPv5.1 framework status
    • TPS methodology compliance
    """

    # Create monitoring configuration
    monitoring_config = %{
      enabled: true,
      scan_interval: 3600,  # 1 hour
      real_time_events: true,
      deep_scan_schedule: "0 2 * * *",  # Daily at 2 AM
      alert_threshold: 1,  # Alert on first unauthorized change
      integration_checks: true
    }

    # Save monitoring config using native serialization
    monitoring_file = "data/protection/monitoring/config.dat"
    monitoring_binary = :erlang.term_to_binary(monitoring_config, [:compressed])
    File.write!(monitoring_file, monitoring_binary)
    
    # Also create formatted version
    monitoring_formatted = "data/protection/monitoring/config.txt"
    formatted_monitoring = """
    # Monitoring Configuration
    # Generated: #{DateTime.utc_now()}
    
    #{inspect(monitoring_config, pretty: true, limit: :infinity)}
    """
    File.write!(monitoring_formatted, formatted_monitoring)

    # Create monitoring script
    create_monitoring_daemon()
    
    IO.puts "\n✅ Monitoring systems configured and activated"
  end

  @doc """
  Configures comprehensive alert systems for protection violations.
  
  ## Agent Notes
  Multi-channel alert system for immediate notification:
  - Email alerts for critical violations
  - Log-based alerts for system integration
  - Dashboard notifications for administrators
  - Emergency escalation procedures
  """
  def configure_alert_systems do
    IO.puts """
    🚨 CONFIGURING ALERT SYSTEMS
    ===========================
    
    ## Alert Channel Configuration
    
    ### Email Alert System
    • Critical violation notifications
    • Daily integrity reports
    • Weekly security summaries
    • Emergency contact procedures
    
    ### System Integration Alerts
    • Container compliance violations
    • STAMP safety constraint breaches
    • SOPv5.1 framework disruptions
    • TPS methodology deviations
    
    ### Dashboard and Logging
    • Real-time violation dashboard
    • Audit trail maintenance
    • Compliance status reporting
    • Performance impact monitoring
    
    ### Escalation Procedures
    • Automatic escalation rules
    • Emergency contact activation
    • Incident response coordination
    • Recovery procedure initiation
    """

    alert_config = %{
      channels: %{
        email: %{
          enabled: true,
          recipients: @protection_config.emergency_contacts,
          critical_immediate: true,
          daily_reports: true
        },
        logging: %{
          enabled: true,
          level: "warning",
          format: "structured_json",
          retention_days: 90
        },
        integration: %{
          container_compliance: true,
          sop_framework: true,
          tps_methodology: true,
          stamp_safety: true
        }
      },
      escalation: %{
        critical_immediate: 0,    # 0 minutes
        high_severity: 5,         # 5 minutes  
        medium_severity: 30,      # 30 minutes
        low_severity: 240         # 4 hours
      }
    }

    # Save alert config using native serialization
