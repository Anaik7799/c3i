  @doc """
  Validates current protection status and file integrity.
  
  ## Agent Notes
  Comprehensive validation of protection system:
  - File integrity checking against baselines
  - Protection system health validation
  - Security constraint compliance
  - Integration system status
  """
  def validate_protection_status do
    IO.puts """
    🔍 PROTECTION STATUS VALIDATION
    ==============================
    
    Validation Date: #{DateTime.utc_now() |> DateTime.to_string()}
    
    ## File Integrity Validation
    """

    # Load baseline checksums using native deserialization
    baseline_file = "data/protection/guardian_db/baseline_checksums.dat"
    
    if File.exists?(baseline_file) do
      baseline_binary = File.read!(baseline_file)
      baseline_data = :erlang.binary_to_term(baseline_binary, [:safe])

      # Validate each protected file
      validation_results = Enum.map(baseline_data.files, fn {file_path, baseline_checksum} ->
        validate_file_integrity(file_path, baseline_checksum)
      end)

      # Analyze results
      {valid_files, invalid_files} = Enum.split_with(validation_results, fn {_, status} -> status == :ok end)

      IO.puts """
      
      📊 Validation Summary:
      • Total Protected Files: #{length(validation_results)}
      • Valid Files: #{length(valid_files)}
      • Modified Files: #{length(invalid_files)}
      • Protection System: #{if protection_system_healthy?(), do: "✅ Healthy", else: "❌ Issues Detected"}
      """

      if Enum.empty?(invalid_files) do
        IO.puts "\n🎉 All protected files validated successfully!"
        :ok
      else
        IO.puts "\n⚠️ File integrity violations detected:"
        Enum.each(invalid_files, fn {file_path, {:error, reason}} ->
          IO.puts "  ❌ #{file_path}: #{reason}"
        end)
        
        # Trigger violation response
        handle_integrity_violations(invalid_files)
        {:error, :integrity_violations}
      end
    else
      IO.puts "❌ Baseline checksums not found - run initialization first"
      {:error, :no_baseline}
    end
  end

  @doc """
  Processes requests for authorized configuration changes.
  
  ## Agent Notes
  Secure change authorization workflow:
  - Multi-step approval process
  - Change impact analysis
  - Risk assessment integration
  - Audit trail maintenance
  """
  def request_authorized_change(file_path, reason, approver \\ nil) do
    IO.puts """
    📝 AUTHORIZED CHANGE REQUEST
    ===========================
    
    File: #{file_path}
    Reason: #{reason}
    Requestor: #{System.get_env("USER") || "unknown"}
    Request Date: #{DateTime.utc_now() |> DateTime.to_string()}
    
    ## Change Authorization Process
    """

    # Validate request
    case validate_change_request(file_path, reason) do
      :ok ->
        # Create change request record
        change_request = create_change_request(file_path, reason, approver)
        
        # Initiate approval workflow
        approval_result = initiate_approval_workflow(change_request)
        
        case approval_result do
          {:ok, approval_id} ->
            IO.puts """
            
            ✅ Change request created successfully
            📋 Request ID: #{approval_id}
            🎯 Status: Pending approval
            ⏰ Estimated approval time: 2-4 hours
            
            ## Next Steps
            1. Approval workflow initiated
            2. Change impact analysis in progress
            3. Risk assessment being conducted
            4. Notification sent to approvers
            
            Use this command to check status:
            elixir scripts/protection/container_config_guardian.exs --check-request #{approval_id}
            """
            {:ok, approval_id}
            
          {:error, reason} ->
            IO.puts """
            
            ❌ Change request rejected
            Reason: #{reason}
            
            ## Escalation Options
            1. Contact system administrator
            2. Provide additional justification
            3. Request emergency override
            4. Submit through alternative process
            """
            {:error, reason}
        end
        
      {:error, validation_error} ->
        IO.puts """
        
        ❌ Change request validation failed
        Error: #{validation_error}
        
        ## Common Issues
        1. File not in protected list
        2. Insufficient reason provided
        3. Too many recent changes
        4. Change conflicts with policy
        """
        {:error, validation_error}
    end
  end

  # Private helper functions

  defp expand_protected_files do
    Enum.flat_map(@protected_files, fn pattern ->
      if String.contains?(pattern, "*") do
        Path.wildcard(pattern)
      else
        [pattern]
      end
    end)
    |> Enum.filter(&File.exists?/1)
    |> Enum.uniq()
  end

  defp generate_file_checksum(file_path) do
    content = File.read!(file_path)
    checksum = :crypto.hash(@protection_config.hash_algorithm, content) |> Base.encode16(case: :lower)
    
    stat = File.stat!(file_path)
    
    %{
      checksum: checksum,
      size: stat.size,
      mtime: stat.mtime,
      permissions: stat.mode,
      algorithm: @protection_config.hash_algorithm
    }
  end

  defp validate_file_integrity(file_path, baseline_data) do
    if File.exists?(file_path) do
      current_checksum = generate_file_checksum(file_path)
      
      if current_checksum.checksum == baseline_data.checksum do
        IO.puts "  ✅ #{file_path}: Integrity verified"
        {file_path, :ok}
      else
        IO.puts "  ❌ #{file_path}: Checksum mismatch detected"
        {file_path, {:error, :checksum_mismatch}}
      end
    else
      IO.puts "  ⚠️ #{file_path}: File missing"
      {file_path, {:error, :file_missing}}
    end
  end

  defp validate_change_request(file_path, reason) do
    cond do
      not (file_path in expand_protected_files()) ->
        {:error, "File not in protected list"}
      
      String.length(reason) < 10 ->
        {:error, "Insufficient reason provided (minimum 10 characters)"}
      
      daily_change_limit_exceeded?() ->
        {:error, "Daily change limit exceeded"}
      
      true ->
        :ok
    end
  end

  defp create_change_request(file_path, reason, approver) do
    request_id = generate_request_id()
    
    %{
      id: request_id,
      file_path: file_path,
      reason: reason,
      requestor: System.get_env("USER") || "unknown",
      approver: approver,
      status: :pending,
      created_at: DateTime.utc_now(),
      change_type: determine_change_type(file_path),
      risk_level: assess_risk_level(file_path, reason)
    }
  end

  defp initiate_approval_workflow(change_request) do
    # Save change request using native serialization
    request_file = "data/protection/audit/changes/request_#{change_request.id}.dat"
    request_binary = :erlang.term_to_binary(change_request, [:compressed])
    File.write!(request_file, request_binary)
    
    # Also create formatted version for debugging
    request_formatted = "data/protection/audit/changes/request_#{change_request.id}.txt"
    formatted_request = """
    # Change Request #{change_request.id}
    # Generated: #{DateTime.utc_now()}
    
    #{inspect(change_request, pretty: true, limit: :infinity)}
    """
    File.write!(request_formatted, formatted_request)
    
    # Send notifications (mock implementation)
    send_approval_notifications(change_request)
    
    {:ok, change_request.id}
  end

  # Additional helper functions for comprehensive functionality

  defp create_guardian_config do
    config_content = """
    # Container Configuration Guardian System Config
    # Generated: #{DateTime.utc_now()}
    
    version: 1.0.0
    protection_level: enterprise-grade
    
