  @doc """
  Validates integration with existing security and compliance systems.
  
  ## Agent Notes
  Comprehensive integration validation:
  - Container compliance system integration
  - SOPv5.1 framework coordination
  - TPS methodology alignment
  - STAMP safety integration
  """
  def validate_system_integrations do
    IO.puts """
    🔗 VALIDATING SYSTEM INTEGRATIONS
    ================================
    
    ## Integration Validation Results
    """

    integrations = [
      {"Container Compliance System", &validate_container_compliance_integration/0},
      {"SOPv5.1 Framework", &validate_sop_framework_integration/0},
      {"TPS Methodology", &validate_tps_integration/0},
      {"STAMP Safety System", &validate_stamp_integration/0},
      {"Git Version Control", &validate_git_integration/0},
      {"File System Monitoring", &validate_filesystem_integration/0}
    ]

    validation_results = Enum.map(integrations, fn {name, validator} ->
      result = validator.()
      status = if result == :ok, do: "✅", else: "❌"
      IO.puts "  #{status} #{name}: #{format_validation_result(result)}"
      {name, result}
    end)

    failed_integrations = Enum.filter(validation_results, fn {_, result} -> result != :ok end)

    if Enum.empty?(failed_integrations) do
      IO.puts "\n🎉 All system integrations validated successfully!"
    else
      IO.puts "\n⚠️ #{length(failed_integrations)} integrations require attention"
      Enum.each(failed_integrations, fn {name, {:error, reason}} ->
        IO.puts "  • #{name}: #{reason}"
      end)
    end
  end

