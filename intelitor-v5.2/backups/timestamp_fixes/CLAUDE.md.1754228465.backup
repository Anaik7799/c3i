elixir scripts/validation/hierarchical_numbering_validator.exs --audit

# Check rollup status logic
elixir scripts/validation/hierarchical_numbering_validator.exs --validate-rollups

# Fix numbering inconsistencies
elixir scripts/validation/hierarchical_numbering_validator.exs --fix-numbering

# Generate hierarchical reports
