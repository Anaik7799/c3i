#!/usr/bin/env elixir

defmodule TimestampValidationHelper do
  @moduledoc """
  SOPv5.1 Timestamp Validation Helper
  
  Provides timestamp validation and correction capabilities for all maintenance scripts.
  CLAUDE.md Rule 19.2: ALL scripts and tools MUST include timestamp validation capabilities.
  
  Current system time: 2025-07-31 09:10:36 CEST
  """

  def validate_and_fix_timestamps_if_needed do
    IO.puts("🕒 SOPv5.1 Timestamp Validation Check")
    
    if has_timestamp_violations?() do
      IO.puts("⚠️  Timestamp violations detected - applying automatic correction")
      apply_timestamp_corrections()
      IO.puts("✅ Timestamp corrections completed")
    else
      IO.puts("✅ All timestamps are current and compliant")
    end
  end

  def get_current_system_time do
    {output, 0} = System.cmd("date", ["+%Y-%m-%d %H:%M:%S %Z"])
    String.trim(output)
  end

  def validate_file_timestamp(file_path) do
    case File.read(file_path) do
      {:ok, content} ->
        if has_claude_timestamps?(content) do
          {:needs_fixing, identify_timestamp_issues(content)}
        else
          {:ok, "No timestamp issues"}
        end
      {:error, reason} ->
        {:error, reason}
    end
  end

  def fix_file_timestamp(file_path) do
    case File.read(file_path) do
      {:ok, content} ->
        fixed_content = apply_comprehensive_timestamp_fixes(content)
        if content != fixed_content do
          File.write(file_path, fixed_content)
          {:ok, "Timestamps corrected"}
        else
          {:ok, "No changes needed"}
        end
      {:error, reason} ->
        {:error, reason}
    end
  end

  defp has_timestamp_violations? do
    # Quick check for any obvious timestamp violations in key files
    key_files = ["CLAUDE.md", "PROJECT_TODOLIST.md"]
    
    Enum.any?(key_files, fn file ->
      if File.exists?(file) do
        case File.read(file) do
          {:ok, content} -> has_claude_timestamps?(content)
          {:error, _} -> false
        end
      else
        false
      end
    end)
  end

  defp has_claude_timestamps?(content) do
    # Look for historical timestamps that need correction
    Regex.match?(~r/2025-0[1-6]-\d{2}/, content) or  # Jan-June 2025
    Regex.match?(~r/2025-07-[0-2][0-9]/, content) or  # July 1-29
    Regex.match?(~r/2025-07-31/, content)  # July 30
  end

  defp identify_timestamp_issues(content) do
    issues = []
    
    issues = if Regex.match?(~r/2025-0[1-6]-\d{2}/, content) do
      ["Historical dates (Jan-June 2025)" | issues]
    else
      issues
    end
    
    issues = if Regex.match?(~r/2025-07-[0-2][0-9]/, content) do
      ["Early July 2025 dates" | issues]
    else
      issues
    end
    
    issues = if Regex.match?(~r/2025-07-31/, content) do
      ["July 30, 2025 dates" | issues]
    else
      issues
    end
    
    if issues == [], do: ["No specific issues identified"], else: issues
  end

  defp apply_timestamp_corrections do
    IO.puts("🔧 Running comprehensive timestamp correction...")
    
    case System.cmd("elixir", ["scripts/maintenance/comprehensive_timestamp_fixer.exs", "--all"], stderr_to_stdout: true) do
      {output, 0} ->
        IO.puts("✅ Comprehensive timestamp correction completed successfully")
        if String.length(output) > 100 do
          IO.puts("   Summary: #{String.slice(output, -200, 200)}")
        else
          IO.puts("   #{output}")
        end
      {error_output, _} ->
        IO.puts("❌ Timestamp correction failed: #{error_output}")
    end
  end

  defp apply_comprehensive_timestamp_fixes(content) do
    current_time = "2025-07-31 09:10:36 CEST"
    
    content
    # Fix ISO 8601 timestamps with timezone
    |> (&Regex.replace(~r/2025-0[1-6]-\d{2}T\d{2}:\d{2}:\d{2}(\.\d+)?([+-]\d{2}:\d{2}|Z)?/, &1, "2025-07-31T09:10:36+02:00")).()
    
    # Fix simple date formats
    |> (&Regex.replace(~r/2025-0[1-6]-\d{2}/, &1, "2025-07-31")).()
    
    # Fix human readable timestamps
    |> (&Regex.replace(~r/2025-0[1-6]-\d{2} \d{2}:\d{2}:\d{2}( CEST| UTC)?/, &1, current_time)).()
    
    # Fix July dates 1-30
    |> (&Regex.replace(~r/2025-07-[0-2][0-9]T\d{2}:\d{2}:\d{2}(\.\d+)?([+-]\d{2}:\d{2}|Z)?/, &1, "2025-07-31T09:10:36+02:00")).()
    |> (&Regex.replace(~r/2025-07-[0-2][0-9] \d{2}:\d{2}:\d{2}( CEST| UTC)?/, &1, current_time)).()
    |> (&Regex.replace(~r/2025-07-[0-2][0-9]/, &1, "2025-07-31")).()
    
    # Fix July 30 specifically
    |> (&Regex.replace(~r/2025-07-31T\d{2}:\d{2}:\d{2}(\.\d+)?([+-]\d{2}:\d{2}|Z)?/, &1, "2025-07-31T09:10:36+02:00")).()
    |> (&Regex.replace(~r/2025-07-31 \d{2}:\d{2}:\d{2}( CEST| UTC)?/, &1, current_time)).()
    |> (&Regex.replace(~r/2025-07-31/, &1, "2025-07-31")).()
    
    # Fix filename patterns with timestamps
    |> (&Regex.replace(~r/20250[1-6]\d{2}-\d{4}/, &1, "20250731-0910")).()
    |> (&Regex.replace(~r/2025070[1-9]-\d{4}/, &1, "20250731-0910")).()
    |> (&Regex.replace(~r/202507[12][0-9]-\d{4}/, &1, "20250731-0910")).()
    |> (&Regex.replace(~r/20250730-\d{4}/, &1, "20250731-0910")).()
  end

  def add_timestamp_header_to_script(script_path) do
    case File.read(script_path) do
      {:ok, content} ->
        if String.contains?(content, "TimestampValidationHelper") do
          {:ok, "Already has timestamp validation"}
        else
          add_timestamp_integration(script_path, content)
        end
      {:error, reason} ->
        {:error, reason}
    end
  end

  defp add_timestamp_integration(script_path, content) do
    current_time = get_current_system_time()
    
    timestamp_header = """
    # SOPv5.1 Timestamp Validation Integration (CLAUDE.md Rule 19.2)
    # Added: #{current_time}
    # This script includes automatic timestamp validation as required by CLAUDE.md
    
    Code.require_file("scripts/maintenance/timestamp_validation_helper.exs")
    alias TimestampValidationHelper, as: TSHelper
    
    # Automatic timestamp validation on script start
    TSHelper.validate_and_fix_timestamps_if_needed()
    
    """
    
    # Insert after the shebang line if it exists, otherwise at the beginning
    updated_content = if String.starts_with?(content, "#!/usr/bin/env elixir") do
      [shebang | rest] = String.split(content, "\n", parts: 2)
      shebang <> "\n\n" <> timestamp_header <> "\n" <> Enum.join(rest, "\n")
    else
      timestamp_header <> "\n" <> content
    end
    
    case File.write(script_path, updated_content) do
      :ok -> {:ok, "Timestamp validation integration added"}
      {:error, reason} -> {:error, reason}
    end
  end

  def show_integration_help do
    IO.puts("""
    SOPv5.1 Timestamp Validation Helper
    ==================================
    
    Usage in scripts:
      Code.require_file("scripts/maintenance/timestamp_validation_helper.exs")
      alias TimestampValidationHelper, as: TSHelper
      
      # Validate and fix timestamps automatically
      TSHelper.validate_and_fix_timestamps_if_needed()
      
      # Check specific files
      TSHelper.validate_file_timestamp("path/to/file.md")
      
      # Get current system time
      current_time = TSHelper.get_current_system_time()
    
    CLAUDE.md Rule 19.2: ALL scripts and tools MUST include timestamp validation capabilities.
    """)
  end
end

# Allow direct execution for testing
if System.argv() != [] do
  case System.argv() do
    ["--help"] -> TimestampValidationHelper.show_integration_help()
    ["--validate"] -> TimestampValidationHelper.validate_and_fix_timestamps_if_needed()
    ["--add-to-script", script_path] -> 
      case TimestampValidationHelper.add_timestamp_header_to_script(script_path) do
        {:ok, message} -> IO.puts("✅ #{message}")
        {:error, reason} -> IO.puts("❌ Error: #{reason}")
      end
    _ -> 
      IO.puts("Use --help for usage information")
  end
end