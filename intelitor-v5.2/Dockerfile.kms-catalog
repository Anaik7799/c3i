# Dockerfile for KMS Catalog Daemon
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /source

# Copy all source first to ensure dependency resolution
COPY lib/cepaf/src/ lib/cepaf/src/

# Restore and Build
WORKDIR /source/lib/cepaf/src/Cepaf.KmsCatalog.Daemon
RUN dotnet publish -c Release -o /app/publish

# Runtime Image
FROM mcr.microsoft.com/dotnet/runtime:10.0
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "Cepaf.KmsCatalog.Daemon.dll"]
