# TDG + STAMP Compliant PostgreSQL 17 Container
# Test-Driven Generation with Safety Constraints

FROM docker.io/library/postgres:17-alpine

# STAMP Safety Constraint 1: Verified base image
LABEL org.opencontainers.image.source="docker.io/library/postgres:17-alpine"
LABEL org.opencontainers.image.title="Indrajaal PostgreSQL Demo"
LABEL org.opencontainers.image.version="17-nixos-demo"
LABEL container.name="indrajaal-postgres-demo"
LABEL tps.methodology="jidoka"
LABEL tdg.compliant="true"
LABEL stamp.safety="validated"

# STAMP Safety Constraint 2: Secure configuration
ENV POSTGRES_DB=indrajaal_demo
ENV POSTGRES_USER=postgres
ENV POSTGRES_PASSWORD=postgres
ENV PGPORT=5433
ENV PGDATA=/var/lib/postgresql/data

# STAMP Safety Constraint 3: Port consistency
EXPOSE 5433

# STAMP Safety Constraint 4: Data persistence
VOLUME ["/var/lib/postgresql/data"]

# STAMP Safety Constraint 5: Health validation
HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
  CMD pg_isready -U postgres -d indrajaal_demo -p 5433 || exit 1

# TDG Validation: Ensure PostgreSQL starts on correct port
CMD ["postgres", "-p", "5433"]