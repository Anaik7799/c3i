{
  "name": "c3i-planning-effect",
  "version": "1.0.0",
  "description": "Pass-29 — Effect-TS planning-grid IIFE collapse (operator-gated H-risk)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run build:planning && npm run build:agui && npm run build:page && npm run build:sw-register && npm run build:planning-utils && npm run build:verification",
    "build:sw-register": "esbuild src/sw-register.ts --bundle --format=iife --target=es2020 --minify --outfile=../static/sw-register.bundled.js",
    "build:planning-utils": "esbuild src/planning-utils.ts --bundle --format=iife --target=es2020 --minify --outfile=../static/planning-utils.bundled.js",
    "build:verification": "esbuild src/verification-grid.ts --bundle --format=iife --target=es2020 --minify --outfile=../static/verification-grid.bundled.js",
    "build:immune": "esbuild src/immune-grid.ts --bundle --format=iife --target=es2020 --minify --outfile=../static/immune-grid.bundled.js",
    "build:planning": "esbuild src/planning-grid.ts --bundle --format=iife --target=es2020 --minify --outfile=../static/planning-grid.bundled.js",
    "build:agui": "esbuild src/agui-chrome.ts --bundle --format=iife --target=es2020 --minify --outfile=../static/agui-chrome.bundled.js",
    "build:page": "esbuild src/page-grid.ts --bundle --format=iife --target=es2020 --minify --outfile=../static/page-grid.bundled.js",
    "build:dev": "esbuild src/planning-grid.ts --bundle --format=iife --target=es2020 --sourcemap --outfile=../static/planning-grid.bundled.js && esbuild src/agui-chrome.ts --bundle --format=iife --target=es2020 --sourcemap --outfile=../static/agui-chrome.bundled.js"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "effect": "^3.0.0"
  }
}
