pub fn immune_c7_performance_under_load_test() {
  let model = immune.init()
  let attacks =
    int_range(0, 29)
    |> list.map(fn(_) { immune_domain.HeartbeatSabotage(target: "n") })
  let result =
    list.fold(attacks, model, fn(m, a) {
      immune.update(m, immune.AttackDetected(a))
    })
  list.length(result.active_attacks) |> should.equal(30)
  immune.threat_level(result) |> should.equal("critical")
}

