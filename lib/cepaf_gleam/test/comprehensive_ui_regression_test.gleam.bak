  let updated = cockpit_view.update(model, cockpit_view.ToggleDarkCockpit)
  updated.dark_cockpit |> should.be_false()
}

pub fn cockpit_c7_reasoning_state_tracking_test() {
  let model = cockpit_view.init()
  let alarms = [make_alarm("a1", cockpit_domain.Critical)]
  let updated = cockpit_view.update(model, cockpit_view.AlarmsUpdated(alarms))
  list.length(cockpit_view.active_alarms(updated)) |> should.equal(1)
}

pub fn cockpit_c7_performance_under_load_test() {
  let nodes =
    int_range(0, 99)
    |> list.map(fn(i) {
      make_mesh_node("n" <> int_to_str(i), cockpit_domain.Degraded)
    })
  let model =
    cockpit_view.CockpitModel(
      nodes: nodes,
      alarms: [],
      view_mode: cockpit_view.init().view_mode,
      dark_cockpit: True,
      selected_node: None,
    )
  cockpit_view.visible_nodes(model) |> list.length |> should.equal(100)
}

pub fn cockpit_c8_model_state_change_and_effect_emitted_test() {
  let model = cockpit_view.init()
  let nodes = [make_mesh_node("n1", cockpit_domain.Degraded)]
  let updated = cockpit_view.update(model, cockpit_view.NodesUpdated(nodes))
  list.length(updated.nodes) |> should.equal(1)
  list.length(cockpit_view.visible_nodes(updated)) |> should.equal(1)
}

pub fn cockpit_c8_error_handling_both_paths_test() {
  let model = cockpit_view.init()
  let updated = cockpit_view.update(model, cockpit_view.AcknowledgeAlarm("a1"))
  updated |> should.equal(model)
}

pub fn cockpit_zenoh_otel_span_published_test() {
  domain.page_to_path(domain.Cockpit) |> should.equal("/cockpit")
}

pub fn cockpit_zenoh_message_format_valid_test() {
  let alarm = make_alarm("a1", cockpit_domain.Critical)
  alarm.level |> should.equal(cockpit_domain.Critical)
}

pub fn cockpit_zenoh_topic_routing_correct_test() {
  domain.page_to_label(domain.Cockpit) |> should.equal("Cockpit")
}

pub fn cockpit_monitoring_element_monitored_30_seconds_test() {
  let model = cockpit_view.init()
  let result = do_cockpit_tick_loop(model, 30)
  result |> should.equal(model)
}

pub fn cockpit_monitoring_no_memory_leak_detected_test() {
  let model = cockpit_view.init()
  let alarms =
    int_range(0, 99)
    |> list.map(fn(i) {
      make_alarm("a" <> int_to_str(i), cockpit_domain.Warning)
    })
  let updated = cockpit_view.update(model, cockpit_view.AlarmsUpdated(alarms))
  list.length(updated.alarms) |> should.equal(100)
}

pub fn cockpit_monitoring_state_convergence_test() {
  let model = cockpit_view.init()
  let result =
    model
    |> cockpit_view.update(cockpit_view.ToggleDarkCockpit)
    |> cockpit_view.update(cockpit_view.ToggleDarkCockpit)
  result.dark_cockpit |> should.be_true()
}

// =============================================================================
// TAB 7: VERIFICATION (L0 Constitutional)
// =============================================================================

pub fn verification_c1_init_returns_valid_model_test() {
  let model = verification.init()
  model.last_report |> should.equal(None)
  model.running |> should.be_false()
}

pub fn verification_c1_model_has_all_required_fields_test() {
  let model = verification.init()
  model.history |> should.equal([])
  model.latest_proof |> should.equal(None)
  model.graph_checks |> should.equal([])
  model.dag_node_count |> should.equal(0)
  model.dag_edge_count |> should.equal(0)
}

pub fn verification_c1_default_safe_state_test() {
  let model = verification.init()
  verification.latest_proof_verified(model) |> should.be_false()
}

pub fn verification_c2_health_class_mapping_test() {
  let report = make_swarm_report(8, 10)
  verification.compliance_percent(report) |> should.equal(80.0)
}

pub fn verification_c2_severity_indicators_correct_test() {
  let report = make_swarm_report(0, 10)
  verification.compliance_percent(report) |> should.equal(0.0)
}

pub fn verification_c3_fields_populated_after_events_test() {
  let model = verification.init()
  let report = make_swarm_report(10, 10)
  let updated = verification.update(model, verification.ReportReceived(report))
  updated.last_report |> should.equal(Some(report))
}

pub fn verification_c3_data_integrity_after_multiple_events_test() {
  let model = verification.init()
  let r1 = make_swarm_report(8, 10)
  let r2 = make_swarm_report(10, 10)
  let updated =
    model
    |> verification.update(verification.StartVerification)
    |> verification.update(verification.ReportReceived(r1))
    |> verification.update(verification.StartVerification)
    |> verification.update(verification.ReportReceived(r2))
  list.length(updated.history) |> should.equal(2)
}

pub fn verification_c4_tick_stability_test() {
  let model = verification.init()
  let updated = verification.update(model, verification.RefreshVerification)
  updated |> should.equal(model)
}

pub fn verification_c4_sequential_events_accumulate_test() {
  let model = verification.init()
  let updated =
    model
    |> verification.update(verification.DagUpdated(15, 30))
    |> verification.update(
      verification.GraphChecksCompleted([make_graph_check("c1", True)]),
    )
  updated.dag_node_count |> should.equal(15)
  updated.dag_edge_count |> should.equal(30)
}

pub fn verification_c4_long_duration_simulation_test() {
  let model = verification.init()
  let result = do_verification_tick_loop(model, 30)
  result |> should.equal(model)
}

fn do_verification_tick_loop(
  model: verification.VerificationModel,
  n: Int,
) -> verification.VerificationModel {
  case n {
    0 -> model
    _ ->
      do_verification_tick_loop(
        verification.update(model, verification.RefreshVerification),
        n - 1,
      )
  }
}

pub fn verification_c5_navigate_changes_model_test() {
  let model = verification.init()
  let updated = verification.update(model, verification.StartVerification)
  updated.running |> should.be_true()
}

pub fn verification_c5_action_buttons_change_state_test() {
  let model = verification.init()
  let proof = make_proof_token(prometheus.Verified)
  let updated = verification.update(model, verification.ProofGenerated(proof))
  verification.latest_proof_verified(updated) |> should.be_true()
}

pub fn verification_c5_drag_drop_if_applicable_test() {
  let model = verification.init()
  let checks = [make_graph_check("c1", True), make_graph_check("c2", False)]
  let updated =
    verification.update(model, verification.GraphChecksCompleted(checks))
  list.all(updated.graph_checks, fn(c) { c.passed }) |> should.be_false()
}

pub fn verification_c6_dark_cockpit_css_classes_test() {
  let model = verification.init()
  model.running |> should.be_false()
}

pub fn verification_c6_mode_affects_display_test() {
  let model = verification.init()
  let updated = verification.update(model, verification.StartVerification)
  updated.running |> should.be_true()
}

pub fn verification_c7_reasoning_state_tracking_test() {
  let model = verification.init()
  let proof = make_proof_token(prometheus.Rejected(reasons: ["failed"]))
  let updated = verification.update(model, verification.ProofGenerated(proof))
  verification.latest_proof_verified(updated) |> should.be_false()
}

pub fn verification_c7_performance_under_load_test() {
  let model = verification.init()
  let reports =
    int_range(0, 49) |> list.map(fn(_) { make_swarm_report(10, 10) })
  let result =
    list.fold(reports, model, fn(m, r) {
      verification.update(m, verification.ReportReceived(r))
    })
  list.length(result.history) |> should.equal(50)
}

pub fn verification_c8_model_state_change_and_effect_emitted_test() {
  let model = verification.init()
  let report = make_swarm_report(10, 10)
  let updated =
    model
    |> verification.update(verification.StartVerification)
    |> verification.update(verification.ReportReceived(report))
  updated.running |> should.be_false()
  updated.last_report |> should.equal(Some(report))
}

pub fn verification_c8_error_handling_both_paths_test() {
  let model = verification.init()
  let proof = make_proof_token(prometheus.Inconclusive)
  let updated = verification.update(model, verification.ProofGenerated(proof))
  verification.latest_proof_verified(updated) |> should.be_false()
}

pub fn verification_zenoh_otel_span_published_test() {
  domain.page_to_path(domain.Verification) |> should.equal("/verification")
}

pub fn verification_zenoh_message_format_valid_test() {
  let proof = make_proof_token(prometheus.Verified)
  proof.result |> should.equal(prometheus.Verified)
}

pub fn verification_zenoh_topic_routing_correct_test() {
  domain.page_to_label(domain.Verification) |> should.equal("Verification")
}

pub fn verification_monitoring_element_monitored_30_seconds_test() {
  let model = verification.init()
  let result = do_verification_tick_loop(model, 30)
  result |> should.equal(model)
}

pub fn verification_monitoring_no_memory_leak_detected_test() {
  let model = verification.init()
  let reports =
    int_range(0, 99) |> list.map(fn(_) { make_swarm_report(10, 10) })
  let result =
    list.fold(reports, model, fn(m, r) {
      verification.update(m, verification.ReportReceived(r))
    })
  list.length(result.history) |> should.equal(100)
}

pub fn verification_monitoring_state_convergence_test() {
  let model = verification.init()
  let result =
    model
    |> verification.update(verification.StartVerification)
    |> verification.update(verification.RefreshVerification)
