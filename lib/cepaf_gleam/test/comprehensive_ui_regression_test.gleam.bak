pub fn planning_c1_init_returns_valid_model_test() {
  let model = planning.init()
  model.tasks |> should.equal([])
  model.filter |> should.equal(planning.AllTasks)
}

pub fn planning_c1_model_has_all_required_fields_test() {
  let model = planning.init()
  model.selected_id |> should.equal(None)
}

pub fn planning_c1_default_filter_is_all_tasks_test() {
  planning.init().filter |> should.equal(planning.AllTasks)
}

pub fn planning_c2_health_class_mapping_test() {
  let task = make_planning_task("t1", "pending")
  task.status |> should.equal("pending")
}

pub fn planning_c2_severity_indicators_correct_test() {
  let tasks = [
    make_planning_task("1", "blocked"),
    make_planning_task("2", "pending"),
    make_planning_task("3", "completed"),
  ]
  planning.task_count_by_status(tasks, "blocked") |> should.equal(1)
  planning.task_count_by_status(tasks, "pending") |> should.equal(1)
  planning.task_count_by_status(tasks, "completed") |> should.equal(1)
}

pub fn planning_c3_fields_populated_after_events_test() {
  let model = planning.init()
  let task = make_planning_task("t1", "pending")
  let updated = planning.update(model, planning.TasksLoaded([task]))
  list.length(updated.tasks) |> should.equal(1)
}

pub fn planning_c3_data_integrity_after_multiple_events_test() {
  let model = planning.init()
  let t1 = make_planning_task("t1", "pending")
  let t2 = make_planning_task("t2", "completed")
  let updated = planning.update(model, planning.TasksLoaded([t1, t2]))
  list.length(updated.tasks) |> should.equal(2)
}

pub fn planning_c4_tick_stability_test() {
  let model = planning.init()
  let updated = planning.update(model, planning.RefreshTasks)
  updated |> should.equal(model)
}

pub fn planning_c4_sequential_events_accumulate_test() {
  let model = planning.init()
  let updated =
    model
    |> planning.update(planning.SetFilter(planning.PendingOnly))
    |> planning.update(planning.SelectTask("t1"))
  updated.filter |> should.equal(planning.PendingOnly)
  updated.selected_id |> should.equal(Some("t1"))
}

pub fn planning_c4_long_duration_simulation_test() {
  let model = planning.init()
  let result = do_planning_tick_loop(model, 30)
  result |> should.equal(model)
}

fn do_planning_tick_loop(
  model: planning.PlanningModel,
  n: Int,
) -> planning.PlanningModel {
  case n {
    0 -> model
    _ ->
      do_planning_tick_loop(
        planning.update(model, planning.RefreshTasks),
        n - 1,
      )
  }
}

pub fn planning_c5_navigate_changes_model_test() {
  let model = planning.init()
  let updated = planning.update(model, planning.SetFilter(planning.BlockedOnly))
  updated.filter |> should.equal(planning.BlockedOnly)
}

pub fn planning_c5_action_buttons_change_state_test() {
  let model = planning.init()
  let updated = planning.update(model, planning.SelectTask("t-42"))
