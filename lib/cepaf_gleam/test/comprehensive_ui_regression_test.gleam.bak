  let result = do_immune_tick_loop(model, 30)
  result |> should.equal(model)
}

pub fn immune_monitoring_no_memory_leak_detected_test() {
  let model = immune.init()
  let abs =
    int_range(0, 99)
    |> list.map(fn(i) {
      immune_domain.Antibody(
        id: "ab" <> int_to_str(i),
        target_pattern: "*",
        reason: "test",
        expires_at: 9999,
      )
    })
  let result =
    list.fold(abs, model, fn(m, ab) {
      immune.update(m, immune.AntibodyAdded(ab))
    })
  list.length(result.antibodies) |> should.equal(100)
}

pub fn immune_monitoring_state_convergence_test() {
  let model = immune.init()
  let result =
    model
    |> immune.update(immune.ToggleMara)
    |> immune.update(immune.ToggleMara)
  result.mara_running |> should.be_false()
}

