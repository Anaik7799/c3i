}

pub fn immune_zenoh_message_format_valid_test() {
  let evt = immune_domain.AttackBlocked(id: "ev1", reason: "blocked")
  case evt {
    immune_domain.AttackBlocked(id: id, reason: reason) -> {
      id |> should.equal("ev1")
      reason |> should.equal("blocked")
    }
    _ -> should.fail()
  }
}

pub fn immune_zenoh_topic_routing_correct_test() {
  domain.page_to_label(domain.Immune) |> should.equal("Immune System")
}

pub fn immune_monitoring_element_monitored_30_seconds_test() {
