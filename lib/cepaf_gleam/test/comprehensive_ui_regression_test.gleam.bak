  let task = make_planning_task("t1", "pending")
  task.id |> should.equal("t1")
  task.status |> should.equal("pending")
}

pub fn planning_zenoh_topic_routing_correct_test() {
  domain.page_to_label(domain.Planning) |> should.equal("Planning")
}

pub fn planning_monitoring_element_monitored_30_seconds_test() {
  let model = planning.init()
  let result = do_planning_tick_loop(model, 30)
  result |> should.equal(model)
}

pub fn planning_monitoring_no_memory_leak_detected_test() {
  let model = planning.init()
  let tasks =
    int_range(0, 99)
    |> list.map(fn(i) { make_planning_task("t" <> int_to_str(i), "pending") })
  let updated = planning.update(model, planning.TasksLoaded(tasks))
  list.length(updated.tasks) |> should.equal(100)
}

pub fn planning_monitoring_state_convergence_test() {
  let model = planning.init()
  let result =
    model
    |> planning.update(planning.SetFilter(planning.PendingOnly))
    |> planning.update(planning.SetFilter(planning.AllTasks))
  result.filter |> should.equal(planning.AllTasks)
}

// =============================================================================
// TAB 3: IMMUNE (L0 Constitutional)
// =============================================================================

pub fn immune_c1_init_returns_valid_model_test() {
  let model = immune.init()
  model.antibodies |> should.equal([])
  model.active_attacks |> should.equal([])
}

pub fn immune_c1_model_has_all_required_fields_test() {
  let model = immune.init()
  model.recent_events |> should.equal([])
  model.mara_running |> should.be_false()
}

pub fn immune_c1_default_safe_state_test() {
  let model = immune.init()
  immune.threat_level(model) |> should.equal("nominal")
}

pub fn immune_c2_health_class_mapping_test() {
  let model = immune.init()
  immune.threat_level(model) |> should.equal("nominal")
}

pub fn immune_c2_severity_indicators_correct_test() {
  let model = immune.init()
  let atk = immune_domain.HeartbeatSabotage(target: "n1")
  let updated = immune.update(model, immune.AttackDetected(atk))
  immune.threat_level(updated) |> should.equal("elevated")
}

pub fn immune_c3_fields_populated_after_events_test() {
  let model = immune.init()
  let ab =
    immune_domain.Antibody(
      id: "ab1",
      target_pattern: "*",
      reason: "test",
      expires_at: 9999,
    )
  let updated = immune.update(model, immune.AntibodyAdded(ab))
  list.length(updated.antibodies) |> should.equal(1)
}

pub fn immune_c3_data_integrity_after_multiple_events_test() {
  let model = immune.init()
  let atk1 = immune_domain.HeartbeatSabotage(target: "n1")
  let atk2 = immune_domain.ZenohFlood(topic: "t", count: 10)
  let updated =
    model
    |> immune.update(immune.AttackDetected(atk1))
    |> immune.update(immune.AttackDetected(atk2))
  list.length(updated.active_attacks) |> should.equal(2)
}

pub fn immune_c4_tick_stability_test() {
  let model = immune.init()
  let updated = immune.update(model, immune.RefreshImmune)
  updated |> should.equal(model)
}

pub fn immune_c4_sequential_events_accumulate_test() {
  let model = immune.init()
  let ab =
    immune_domain.Antibody(
      id: "ab1",
      target_pattern: "*",
      reason: "test",
      expires_at: 9999,
    )
  let evt = immune_domain.AttackBlocked(id: "ev1", reason: "blocked")
  let updated =
    model
    |> immune.update(immune.AntibodyAdded(ab))
    |> immune.update(immune.EventReceived(evt))
  list.length(updated.antibodies) |> should.equal(1)
  list.length(updated.recent_events) |> should.equal(1)
}

pub fn immune_c4_long_duration_simulation_test() {
  let model = immune.init()
  let result = do_immune_tick_loop(model, 30)
  result |> should.equal(model)
}

fn do_immune_tick_loop(model: immune.ImmuneModel, n: Int) -> immune.ImmuneModel {
  case n {
    0 -> model
    _ -> do_immune_tick_loop(immune.update(model, immune.RefreshImmune), n - 1)
  }
}

