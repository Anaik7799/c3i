# .dockerignore - Exclude files from Docker build context
# SC-GEM-001: No rm -rf unverified (verified exclusions only)

# =============================================================================
# VERSION CONTROL
# =============================================================================
.git/
.gitignore
.gitattributes
.github/
.gitlab-ci.yml

# =============================================================================
# BUILD ARTIFACTS (Excluded - will be built inside container)
# =============================================================================
_build/
deps/
node_modules/
*.beam
*.ez
erl_crash.dump
priv/static/

# =============================================================================
# DATA DIRECTORIES (SC-HOLON-005: Holon state in data/holons/)
# =============================================================================
data/
data/holons/
data/tmp/
data/kms/

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
.elixir_ls/
.lexical/
.direnv/
.devenv/
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# DOCUMENTATION
# =============================================================================
docs/
README.md
CHANGELOG.md
LICENSE
*.md
!mix.exs

# =============================================================================
# TEST FILES (Excluded - production build)
# =============================================================================
test/
spec/
features/

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================
*.log
logs/
tmp/
*.tmp
.DS_Store
Thumbs.db

# =============================================================================
# CI/CD & DEPLOYMENT
# =============================================================================
.circleci/
.travis.yml
Jenkinsfile
docker-compose*.yml
podman-compose*.yml
Dockerfile*
!Dockerfile.precompiled

# =============================================================================
# CONFIGURATION (Excluded - will be injected at runtime)
# =============================================================================
.env
.env.*
config/*.secret.exs
priv/cert/
priv/ssl/

# =============================================================================
# ELIXIR SPECIFIC
# =============================================================================
*.ez
doc/
.fetch
.formatter.exs.bak
cover/

# =============================================================================
# ASSETS (Source files - compiled assets will be included)
# =============================================================================
assets/node_modules/
assets/vendor/
assets/.sass-cache/

# =============================================================================
# SCRIPTS (Excluded - not needed in runtime)
# =============================================================================
scripts/
lib/cepaf/scripts/

# =============================================================================
# NATIVE COMPILATION (Will be built inside container)
# =============================================================================
native/*/target/
native/**/Cargo.lock

# =============================================================================
# BACKUP & ARCHIVE
# =============================================================================
*.bak
*.backup
*.tar.gz
*.zip
*.sql

# =============================================================================
# CLAUDE/GEMINI CONTEXT (Not needed in container)
# =============================================================================
.claude/
GEMINI.md
AGENT_BOOTSTRAP.md
