{
  // Zenoh client config for indrajaal-mojo container
  // SC-MOJO-001: Must connect to Zenoh router in the SIL-6 mesh
  "mode": "client",
  "connect": {
    "endpoints": [
      "tcp/zenoh-router-1:7447"
    ]
  },
  "scouting": {
    "multicast": {
      "enabled": false
    }
  },
  "transport": {
    "unicast": {
      "lowlatency": true,
      "qos": {
        "enabled": true
      }
    }
  }
}
