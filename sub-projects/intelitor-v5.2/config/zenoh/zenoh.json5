{
  // Zenoh Router Configuration for Indrajaal SIL-6 Mesh
  // Version: 1.3.0 | STAMP: SC-ZENOH-CFG-001, SC-SIL4-006, SC-FIX-007
  // Purpose: Standalone router for prod-standalone mesh (Zenoh 1.0.0 compatible)
  // Valid fields: id, metadata, mode, connect, listen, open, scouting, timestamping,
  //               queries_default_timeout, routing, aggregation, transport, adminspace,
  //               downsampling, access_control, plugins_loading, plugins

  mode: "router",

  listen: {
    endpoints: [
      "tcp/0.0.0.0:7447"
    ]
  },

  // Standalone mode - no connect to external routers
  // For 2oo3 quorum, use podman-compose-sil6-full-mesh.yml with zenoh-router-{1,2,3}

  plugins: {
    // REST API Plugin (for health checks and debugging)
    rest: {
      http_port: 8000
    }
  },

  // Scouting for peer discovery
  scouting: {
    gossip: {},
    multicast: {
      enabled: true,
      address: "224.0.0.224:7446",
      interface: "auto"
    }
  },

  // Routing configuration for cluster coordination
  routing: {
    router: {
      peers_failover_brokering: true
    }
  }
}
