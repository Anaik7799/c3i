**3. SOPv5.11 Script-Level Enforcement:**
All scripts MUST include cybernetic container validation:
```bash
validate_sopv511_container() {
    local container_name="$1"
    
    # Validate localhost registry
    if [[ "$container_name" != localhost/* ]]; then
        echo "❌ SOPv5.11 VIOLATION: External container usage forbidden: $container_name"
        echo "✅ REQUIRED: Use localhost/ registry only"
        echo "🤖 CYBERNETIC ENFORCEMENT: Container policy violation detected"
        exit 1
    fi
    
    # Validate container is part of Phase 2 architecture
    local valid_containers=(
        "localhost/intelitor-timescaledb-demo:nixos-devenv"
        "localhost/intelitor-redis-demo:nixos-devenv"
        "localhost/intelitor-app-demo:nixos-devenv"
        "localhost/intelitor-prometheus-demo:nixos-devenv"
        "localhost/intelitor-grafana-demo:nixos-devenv"
        "localhost/intelitor-nginx-demo:nixos-devenv"
        "localhost/intelitor-agent-supervisor:nixos-devenv"
        "localhost/intelitor-phics-coordinator:nixos-devenv"
        "localhost/intelitor-security-monitor:nixos-devenv"
        "localhost/intelitor-performance-analyzer:nixos-devenv"
    )
    
    local is_valid=false
    for valid_container in "${valid_containers[@]}"; do
        if [[ "$container_name" == "$valid_container" ]]; then
            is_valid=true
            break
        fi
    done
    
    if [[ "$is_valid" == false ]]; then
        echo "⚠️ WARNING: Container not in SOPv5.11 Phase 2 architecture: $container_name"
        echo "📋 RECOMMENDED: Use one of the 10 approved Phase 2 containers"
    fi
    
    echo "✅ SOPv5.11 CONTAINER VALIDATED: $container_name"
}

# PHICS v2.1 Integration Validation
validate_phics_integration() {
    if [[ "$PHICS_ENABLED" != "true" ]]; then
        echo "❌ PHICS VIOLATION: PHICS v2.1 must be enabled for SOPv5.11"
        exit 1
    fi
    echo "✅ PHICS v2.1 VALIDATED: Hot-reloading enabled"
}
```

