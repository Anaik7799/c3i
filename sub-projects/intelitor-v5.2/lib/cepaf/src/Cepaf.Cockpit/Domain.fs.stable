namespace Cepaf.Cockpit

open System

/// ═══════════════════════════════════════════════════════════════════════════════
/// C3I MESH COCKPIT - DOMAIN TYPES
/// ═══════════════════════════════════════════════════════════════════════════════
///
/// WHAT: Safety-Critical Domain Types for Distributed Control Interface
///
/// WHY: Implements NASA-STD-3000, NUREG-0700, and MIL-STD-1472H compliant
///      data structures for Human-Machine Interface in distributed systems.
///
/// STAMP Compliance:
///   - SC-HMI-001: Dark Cockpit philosophy (management by exception)
///   - SC-HMI-002: Trend vectors for predictive awareness
///   - SC-HMI-003: Staleness detection (5-second watchdog)
///   - SC-HMI-004: Two-step commit for critical commands
///
/// ═══════════════════════════════════════════════════════════════════════════════
module Domain =

    // ═══════════════════════════════════════════════════════════════════════════
    // PRIMITIVE STATES (Safety-Critical Enumerations)
    // ═══════════════════════════════════════════════════════════════════════════

    /// Trend Vector - Shows where the data is GOING, not just where it IS
    /// Brain processes geometry faster than arithmetic (NUREG-0700)
    type Trend =
        | Rising        // ↑  Value increasing
        | RisingFast    // ↑↑ Value increasing rapidly (action may be required)
        | Falling       // ↓  Value decreasing
        | FallingFast   // ↓↓ Value decreasing rapidly
        | Stable        // →  Value stable within tolerance

    /// Connection Status with Staleness Detection
    /// "A frozen number is a lie" - Watchdog timer mandatory
    type ConnStatus =
        | Connected     // ● Active, recent data received
        | Stale         // ◌ No data in 5 seconds - VISUAL DECAY required
        | Degraded      // ◐ Partial connectivity
        | Disconnected  // ○ No connection

    /// Alarm Level - Dark Cockpit Philosophy
    /// Gray/Blue = Normal, Amber = Advisory, Red = Critical
    /// NO "Christmas Trees" of green lights - show nothing when OK
    type AlarmLevel =
        | Normal    // Gray   - No display or very dim
        | Advisory  // Cyan   - Informational only
        | Caution   // Amber  - Attention required
        | Warning   // Red    - Immediate action required
        | Critical  // Red+Flash - Emergency

    /// Command State for Two-Step Commit (SC-HMI-004)
    type CommandState =
        | Idle          // No command pending
        | Armed         // Command selected, awaiting confirmation
        | Executing     // Command sent, awaiting acknowledgment
        | Acknowledged  // Echo-back received from mesh
        | Failed        // Command rejected or timed out

    /// Node Role in the Mesh
    type NodeRole =
        | Supervisor    // Executive control
        | Controller    // Domain controller
        | Worker        // Execution unit
        | Observer      // Monitoring only
        | Gateway       // External interface

    // ═══════════════════════════════════════════════════════════════════════════
    // SMART METRIC - More Than Just a Number
    // ═══════════════════════════════════════════════════════════════════════════

    /// The "Smart Metric" - Encapsulates value with context
    /// Implements analog-over-digital principle (NUREG-0700)
    type SmartMetric<'T> = {
        Value: 'T                   // Current value
        PreviousValue: 'T option    // Previous value for trend calculation
        LastUpdated: DateTime       // For staleness detection
        Trend: Trend                // Computed trend vector
        Level: AlarmLevel           // Current alarm level
        Thresholds: Thresholds<'T> option  // Optional threshold configuration
        Unit: string                // Display unit
        Label: string               // Human-readable label
        Sparkline: float list       // Historical values for mini-chart (last 20)
    }

    and Thresholds<'T> = {
        AdvisoryLow: 'T option
        AdvisoryHigh: 'T option
        CautionLow: 'T option
        CautionHigh: 'T option
        WarningLow: 'T option
        WarningHigh: 'T option
    }

    /// Create a new smart metric with defaults
    let createMetric<'T> (label: string) (unit: string) (value: 'T) : SmartMetric<'T> =
        {
            Value = value
            PreviousValue = None
            LastUpdated = DateTime.UtcNow
            Trend = Stable
            Level = Normal
            Thresholds = None
            Unit = unit
            Label = label
            Sparkline = []
        }

    /// Update a metric with staleness and trend detection
    let updateMetric<'T when 'T : comparison> (newValue: 'T) (metric: SmartMetric<'T>) : SmartMetric<'T> =
        let trend =
            match metric.PreviousValue with
            | None -> Stable
            | Some prev when newValue > prev -> Rising
            | Some prev when newValue < prev -> Falling
            | _ -> Stable

        let sparkline =
            match box newValue with
            | :? float as f -> (f :: metric.Sparkline) |> List.truncate 20
            | :? int as i -> (float i :: metric.Sparkline) |> List.truncate 20
            | _ -> metric.Sparkline

        { metric with
            Value = newValue
            PreviousValue = Some metric.Value
            LastUpdated = DateTime.UtcNow
            Trend = trend
            Sparkline = sparkline
        }

    /// Check if metric is stale (> 5 seconds since last update)
    let isStale (metric: SmartMetric<'T>) : bool =
        (DateTime.UtcNow - metric.LastUpdated).TotalSeconds > 5.0

    // ═══════════════════════════════════════════════════════════════════════════
    // MESH NODE - Entity in the Distributed Fabric
    // ═══════════════════════════════════════════════════════════════════════════

    type NodeId = string
    type ZoneId = string

    /// Mesh Node - A participant in the data fabric
    type MeshNode = {
        Id: NodeId
        Name: string
        Zone: ZoneId
        Role: NodeRole
        Status: ConnStatus

        // Core Metrics (Smart Metrics with trends)
        Cpu: SmartMetric<float>
        Memory: SmartMetric<float>
        Battery: SmartMetric<float> option
        NetworkLatency: SmartMetric<float>

        // Capabilities (EID principle)
        Capabilities: string list

        // Health Score (0-100)
        HealthScore: SmartMetric<int>

        // Last known position (for geo-aware systems)
        Location: (float * float) option

        // AI-Generated Insights
        AiInsight: string option
        AiInsightUpdatedAt: DateTime option
    }

    /// Create a new mesh node with sensible defaults
    let createNode (id: NodeId) (name: string) (zone: ZoneId) (role: NodeRole) : MeshNode =
        {
            Id = id
            Name = name
            Zone = zone
            Role = role
            Status = Disconnected
            Cpu = createMetric "CPU" "%" 0.0
            Memory = createMetric "Memory" "%" 0.0
            Battery = None
            NetworkLatency = createMetric "Latency" "ms" 0.0
            Capabilities = []
            HealthScore = createMetric "Health" "%" 100
            Location = None
            AiInsight = None
            AiInsightUpdatedAt = None
        }

    // ═══════════════════════════════════════════════════════════════════════════
    // ALARMS - Safety-Critical Event Notifications
    // ═══════════════════════════════════════════════════════════════════════════

    type AlarmId = string

    type Alarm = {
        Id: AlarmId
        NodeId: NodeId
        Level: AlarmLevel
        Category: string
        Message: string
        Details: string option
        OccurredAt: DateTime
        AcknowledgedAt: DateTime option
        AcknowledgedBy: string option
        AutoClearable: bool
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // COMMANDS - Control Plane with Two-Step Commit
    // ═══════════════════════════════════════════════════════════════════════════

    type CommandId = string

    /// Commands that can be sent to mesh nodes
    type MeshCommand =
        | PowerOff
        | PowerOn
        | Restart
        | Hibernate
        | IsolateNetwork
        | ResumeNetwork
        | SetLoadBalancer of percentage: int
        | ForceHealthCheck
        | ClearAlarms
        | Custom of name: string * payload: byte[]

    /// Command tracking for two-step commit
    type CommandRecord = {
        Id: CommandId
        TargetNodeId: NodeId
        Command: MeshCommand
        State: CommandState
        ArmedAt: DateTime option
        ExecutedAt: DateTime option
        AcknowledgedAt: DateTime option
        ErrorMessage: string option
        RequiresConfirmation: bool
    }

    /// Check if a command is critical (requires two-step commit)
    let isCriticalCommand (cmd: MeshCommand) : bool =
        match cmd with
        | PowerOff | Restart | IsolateNetwork | Hibernate -> true
        | _ -> false

    // ═══════════════════════════════════════════════════════════════════════════
    // ZONES - Hierarchical Grouping
    // ═══════════════════════════════════════════════════════════════════════════

    type Zone = {
        Id: ZoneId
        Name: string
        ParentZone: ZoneId option
        Nodes: NodeId list
        AggregateHealth: SmartMetric<int>
        ActiveAlarms: int
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // AI INSIGHTS - LLM-Generated Intelligence
    // ═══════════════════════════════════════════════════════════════════════════

    type InsightType =
        | Anomaly           // Detected unusual pattern
        | Prediction        // Predicted future state
        | Recommendation    // Suggested action
        | Correlation       // Related events
        | RootCause         // Identified root cause
        | Summary           // Status summary

    type AiInsight = {
        Id: string
        Type: InsightType
        Level: AlarmLevel
        Title: string
        Description: string
        RelatedNodes: NodeId list
        RelatedAlarms: AlarmId list
        Confidence: float  // 0.0 - 1.0
        GeneratedAt: DateTime
        ExpiresAt: DateTime option
        ActionItems: string list
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // COCKPIT STATE - The Complete Digital Twin
    // ═══════════════════════════════════════════════════════════════════════════

    type ViewMode =
        | Dashboard     // Overview with all panels
        | NodeDetail    // Single node deep-dive
        | AlarmCenter   // Alarm management view
        | Topology      // Network topology view
        | Timeline      // Historical timeline
        | AiAssistant   // AI copilot interaction

    type CockpitState = {
        // Identity
        OperatorId: string
        SessionId: string
        StartedAt: DateTime

        // Mesh State (Digital Twin)
        Nodes: Map<NodeId, MeshNode>
        Zones: Map<ZoneId, Zone>
        Alarms: Map<AlarmId, Alarm>

        // Active Commands
        PendingCommands: Map<CommandId, CommandRecord>
        CommandHistory: CommandRecord list

        // AI Intelligence
        Insights: AiInsight list
        AiEnabled: bool
        LastAiUpdate: DateTime option

        // UI State
        CurrentView: ViewMode
        SelectedNodeId: NodeId option
        SelectedZoneId: ZoneId option
        FilterLevel: AlarmLevel option

        // Telemetry
        MessagesReceived: int64
        LastMessageAt: DateTime option
        UiRefreshRate: int  // Hz

        // Flags
        MonitorOnly: bool   // Read-only mode
        SimulationMode: bool
    }

    /// Create initial cockpit state
    let createCockpitState (operatorId: string) : CockpitState =
        {
            OperatorId = operatorId
            SessionId = Guid.NewGuid().ToString("N").[..7]
            StartedAt = DateTime.UtcNow
            Nodes = Map.empty
            Zones = Map.empty
            Alarms = Map.empty
            PendingCommands = Map.empty
            CommandHistory = []
            Insights = []
            AiEnabled = true
            LastAiUpdate = None
            CurrentView = Dashboard
            SelectedNodeId = None
            SelectedZoneId = None
            FilterLevel = None
            MessagesReceived = 0L
            LastMessageAt = None
            UiRefreshRate = 10
            MonitorOnly = false
            SimulationMode = false
        }

    // ═══════════════════════════════════════════════════════════════════════════
    // ZENOH KEY SPACE
    // ═══════════════════════════════════════════════════════════════════════════

    module KeySpace =
        let prefix = "c3i"

        /// Telemetry key: c3i/units/{zone}/{id}/telemetry
        let telemetry (zone: ZoneId) (nodeId: NodeId) =
            sprintf "%s/units/%s/%s/telemetry" prefix zone nodeId

        /// Alarm key: c3i/alarms/{severity}/{id}
        let alarm (severity: AlarmLevel) (alarmId: AlarmId) =
            sprintf "%s/alarms/%A/%s" prefix severity alarmId

        /// Control key: c3i/ctrl/{id}/{subsystem}/set
        let control (nodeId: NodeId) (subsystem: string) =
            sprintf "%s/ctrl/%s/%s/set" prefix nodeId subsystem

        /// Config key: c3i/config/{id}
        let config (nodeId: NodeId) =
            sprintf "%s/config/%s" prefix nodeId

        /// AI insight key: c3i/ai/insights/{type}
        let aiInsight (insightType: InsightType) =
            sprintf "%s/ai/insights/%A" prefix insightType

        /// Subscription pattern for all unit telemetry
        let allTelemetry = sprintf "%s/units/**" prefix

        /// Subscription pattern for all alarms
        let allAlarms = sprintf "%s/alarms/**" prefix
