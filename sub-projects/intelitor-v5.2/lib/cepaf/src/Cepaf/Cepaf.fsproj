    <Compile Include="Mesh/SevenLevelRCA.fs" />
    <!-- AI-Assisted RCA: OpenRouter integration for 7-level analysis (SC-BOOT-012, SC-AI-001, AOR-OPENROUTER-001 to AOR-OPENROUTER-005) -->
    <Compile Include="AI/OpenRouterRCA.fs" />
    <!-- Supervisor Hierarchy: 3-level supervisor tree (SC-SUP-001, SC-SUP-002, SC-SUP-003) -->
    <Compile Include="Mesh/SupervisorHierarchy.fs" />
    <!-- Mesh Shutdown: Graceful drain, dying gasp, transaction semantics (Borg/AUTOSAR) -->
    <Compile Include="Mesh/MeshShutdown.fs" />
    <!-- Mesh Dashboard: TUI with 10s KPI refresh (AOR-BIO-004) -->
    <Compile Include="Mesh/MeshDashboard.fs" />
    <!-- OODA Supervisor: Biomorphic cybernetic control (SC-OODA-001, AOR-BIO-001) -->
    <Compile Include="Mesh/OodaSupervisor.fs" />
    <!-- Mathematical System Monitor: 17-discipline health monitoring (SC-AI-003, SC-PROM-001) -->
    <Compile Include="Mesh/MathematicalSystemMonitor.fs" />
