    <Compile Include="Mesh/CliHealthScore.fs" />
    <!-- Mesh CLI: sa-* command integration (original) -->
    <Compile Include="Mesh/MeshCli.fs" />
    <!-- CommandVerifier: GA runtime verifier for 32 devenv sa-* commands (SC-CLI-001, AOR-CMD-001) -->
    <Compile Include="Mesh/CommandVerifier.fs" />
    <!-- SIL-6 Biomorphic CLI: Unified sa-* commands with 5-order effects (SC-CTRL-003) -->
    <Compile Include="Mesh/Artifacts.fs" />
    <!-- BuildHistory: SQLite-backed persistent build timing database for ETA estimation (SC-IGNITE-001, SC-HOLON-009) -->
    <Compile Include="Mesh/BuildHistory.fs" />
    <!-- BuildStreamMonitor: Real-time build observability with ETA, step parsing, Zenoh telemetry (SC-IGNITE-004, SC-HMI-010) -->
    <Compile Include="Mesh/BuildStreamMonitor.fs" />
    <Compile Include="Mesh/PanopticIgnition.fs" />
    <Compile Include="Mesh/MetabolicPruner.fs" />
    <Compile Include="Mesh/SIL6MeshCLI.fs" />
    <Compile Include="Mesh/PanopticSupervisor.fs" />
