    <Compile Include="Orchestrator/OptimalMesh.fs" />
    <!-- SIL-6 MESH ORCHESTRATION (2026-01-04) -->
    <!-- STAMP: SC-SIL6-001 to SC-SIL6-020, SC-CMD-010 to SC-CMD-020, SC-EMR-057 -->
    <!-- AOR: AOR-SIL6-001 to AOR-SIL6-006, AOR-CMD-001 to AOR-CMD-008 -->
    <!-- ZenohPublish: Unified Zenoh publishing abstraction with SC-ZTEST-008 dual-write -->
    <!-- MUST be before Core.fs so all Mesh modules can reference it -->
    <Compile Include="Mesh/ZenohPublish.fs" />
    <!-- Core: Shared types and utilities for all mesh modules (SC-CONSOL-007, SC-CONSOL-008) -->
    <Compile Include="Mesh/Core.fs" />
    <!-- Mathematical Startup Foundations (SC-BOOT-001 to SC-BOOT-050, 2026-01-18) -->
    <!-- DAG: Kahn's algorithm for topological sorting of container dependencies -->
    <Compile Include="Mesh/DAG.fs" />
    <!-- CPM: Critical Path Method for boot time optimization -->
    <Compile Include="Mesh/CPM.fs" />
    <!-- FSM: Deterministic Finite Automaton for container lifecycle (9 states, 8 signals) -->
    <Compile Include="Mesh/FSM.fs" />
    <!-- Hysteresis: Health check stability control (prevents flapping) -->
    <Compile Include="Mesh/Hysteresis.fs" />
    <!-- ZenohCheckpoints: Real-time boot progress via Zenoh pub/sub (<100ms latency) -->
    <Compile Include="Mesh/ZenohCheckpoints.fs" />
    <!-- SmokeTestPublisher: Zenoh checkpoint publishing for smoke tests (SC-ZTEST-001 to SC-ZTEST-008) -->
    <Compile Include="Mesh/SmokeTestPublisher.fs" />
    <!-- Smriti SEO: Smriti-Enabled Orchestration -->
    <Compile Include="Mesh/SmritiSEO.fs" />
    <!-- SIL6BiomorphicOrchestrator: Unified startup with DAG/CPM/FSM/Hysteresis + Zenoh (SC-BOOT-001 to SC-BOOT-050) -->
    <Compile Include="Mesh/SIL6BiomorphicOrchestrator.fs" />
    <!-- Fractal Logger: 5-level logging with Zenoh telemetry (Dapper/Jaeger) -->
    <Compile Include="Mesh/FractalLogger.fs" />
    <!-- Digital Twin: Holon genotype/phenotype state tracking -->
    <Compile Include="Mesh/DigitalTwin.fs" />
    <!-- Sprint Orchestrator: Criticality-based DAG execution with Zenoh checkpoints (SC-ZTEST-001 to SC-ZTEST-020) -->
    <Compile Include="Mesh/SprintOrchestrator.fs" />
    <!-- Container Lifecycle: 5 startup + 6 shutdown phases (SC-SIL6-012/013) -->
    <Compile Include="Mesh/ContainerLifecycleManager.fs" />
    <!-- Health Coordinator: Quorum voting + FPPS consensus (SC-SIL6-011) -->
    <Compile Include="Mesh/HealthCoordinator.fs" />
    <!-- Apoptosis: Controlled self-destruction protocol (SC-SIL6-015) -->
    <Compile Include="Mesh/Apoptosis.fs" />
    <!-- Mesh Startup: Dependency-aware parallel boot (systemd/AUTOSAR patterns) -->
    <Compile Include="Mesh/MeshStartup.fs" />
    <!-- Startup Verification: State vector gates for SIL-6 boot sequence (SC-BOOT-001 to SC-BOOT-010) -->
    <Compile Include="Mesh/StartupVerification.fs" />
