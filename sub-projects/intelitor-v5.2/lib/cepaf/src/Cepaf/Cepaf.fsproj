<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>preview</LangVersion>
    <!-- FS0064: Type constraint warnings in recursion schemes (intentional HKT emulation pattern) -->
    <NoWarn>FS0064</NoWarn>
  </PropertyGroup>

  <!-- Allow test project to access internal members (SafeSubscriber.DeliverSample, etc.) -->
  <ItemGroup>
    <InternalsVisibleTo Include="Cepaf.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core F# Capability Modules (SC-FSH-001 to SC-FSH-043) -->
    <!-- Advanced F# patterns: Active Patterns, Units of Measure, Composition -->
    <!-- Level 1: Foundation Types -->
    <Compile Include="Core/Units.fs" />
    <Compile Include="Core/Composition.fs" />
    <Compile Include="Core/ActivePatterns.fs" />
    <Compile Include="Bio/Holon.fs" />
    <Compile Include="Modules/ConstraintValidator.fs" />
    <!-- Level 2: Domain Extensions (depends on Level 1) -->
    <Compile Include="Core/DomainUnits.fs" />
    <Compile Include="Core/DomainPatterns.fs" />
    <Compile Include="Core/Pipelines.fs" />
    <!-- Level 3: Safety & Async (depends on Level 2) -->
    <Compile Include="Core/SafetyConstraints.fs" />
    <Compile Include="Core/AsyncWorkflows.fs" />
    <!-- Level 4: Advanced Functional Patterns (SC-FSH-020 to SC-FSH-062) -->
    <!-- Parser Combinators: Monadic parser for DSLs (SC-FSH-070 to SC-FSH-072) -->
    <Compile Include="Core/Parsers.fs" />
    <!-- Category Theory: Bifunctors, Profunctors, Comonads (SC-FSH-090 to SC-FSH-092) -->
    <Compile Include="Core/CategoryTheory.fs" />
    <!-- Tagless Final: Effect-polymorphic programs (SC-FSH-080 to SC-FSH-082) -->
    <Compile Include="Core/TaglessFinal.fs" />
    <!-- Advanced Validation: Applicative error accumulation (SC-FSH-110 to SC-FSH-112) -->
    <Compile Include="Core/Validation.fs" />
    <!-- Capability Security: Object-capability model (SC-FSH-100 to SC-FSH-102) -->
    <Compile Include="Core/Capabilities.fs" />
    <!-- Level 5: Advanced Computational Structures (SC-FSH-120 to SC-FSH-175) -->
    <!-- Recursion Schemes: Catamorphisms, Anamorphisms, Hylomorphisms (SC-FSH-120 to SC-FSH-125) -->
    <Compile Include="Core/RecursionSchemes.fs" />
    <!-- Streaming: AsyncSeq, Transducers, Push Streams, Windowing (SC-FSH-130 to SC-FSH-135) -->
    <Compile Include="Core/Streaming.fs" />
    <!-- Comonads: Identity, Env, Store, Traced, Zippers (SC-FSH-150 to SC-FSH-155) -->
    <Compile Include="Core/Comonads.fs" />
    <!-- Arrows: Arrow, ArrowChoice, ArrowApply, ArrowLoop, Kleisli (SC-FSH-140 to SC-FSH-145) -->
    <Compile Include="Core/Arrows.fs" />
    <!-- Concurrency: STM, MVar, Channels, Barriers, Actors (SC-FSH-160 to SC-FSH-168) -->
    <Compile Include="Core/ConcurrencyPatterns.fs" />
    <!-- Free Effects: Free/Freer Monads, Effect Algebras, Handlers (SC-FSH-170 to SC-FSH-175) -->
    <Compile Include="Core/FreeEffects.fs" />
    <!-- Effects: Algebraic effect system for controlled side effects -->
    <Compile Include="Core/Effects.fs" />
    <!-- Optics: Lenses, Prisms, Traversals for immutable data access -->
    <Compile Include="Core/Optics.fs" />
    <!-- Workflows: Reader, Writer, State, RWS computation expressions -->
    <Compile Include="Core/Workflows.fs" />
    <!-- StateMachine: Phantom-typed state machines for compile-time validation -->
    <Compile Include="Core/StateMachine.fs" />
    <!-- EventSourcing: Event-sourced aggregates, commands, projections -->
    <Compile Include="Core/EventSourcing.fs" />
    <!-- End Core Modules -->
    <!-- Validation System (SC-FSH-140 to SC-FSH-165, SC-VAL-003, SC-VAL-004) -->
    <!-- Pattern-based compilation validation with FPPS 5-method consensus -->
    <Compile Include="Validation/ErrorPatterns.fs" />
    <Compile Include="Validation/CompilationValidator.fs" />
    <Compile Include="Validation/FPPSValidator.fs" />
    <Compile Include="Validation/PatternMigrationVerification.fs" />
    <!-- L6/L7 Cognitive Integration (SC-NEURO-001 to SC-NEURO-004, SC-AI-001 to SC-AI-008) -->
    <Compile Include="Validation/CognitiveValidator.fs" />
    <!-- End Validation System -->
    <!-- KMS Catalog System (SC-SING-008, SC-SING-009) -->
    <Compile Include="Safety/KmsCatalog.fs" />
    <!-- AI Integration placeholder - actual file compiled after Mesh modules -->
    <Compile Include="Domain.fs" />
    <Compile Include="Safety/SimplexKernel.fs" />
    <Compile Include="Safety/LethalMutationGate.fs" />
    <Compile Include="Safety/PiCalculus.fs" />
    <Compile Include="Safety/PrometheusGate.fs" />
    <Compile Include="Ark/Substrate.fs" />
    <Compile Include="Rop.fs" />
    <Compile Include="Observability/Types.fs" />
    <!-- Fractal Logging System (5-Level Zenoh-style) -->
    <Compile Include="Observability/Fractal/Types.fs" />
    <Compile Include="Observability/Fractal/HLC.fs" />
    <Compile Include="Observability/Fractal/KeyExpression.fs" />
    <Compile Include="Observability/Fractal/WriteFilter.fs" />
    <Compile Include="Observability/Fractal/FractalControl.fs" />
    <Compile Include="Observability/Fractal/BatchEncoder.fs" />
    <Compile Include="Observability/Fractal/ContentRouter.fs" />
    <Compile Include="Observability/Fractal/PIIMasking.fs" />
    <Compile Include="Observability/Fractal/AdminSpace.fs" />
    <!-- OTEL/SigNoz Integration (SC-LOG-004, SC-OBS-069, SC-OBS-071) -->
    <Compile Include="Observability/Fractal/OTELIntegration.fs" />
    <!-- End Fractal Logging System -->
    <!-- Zenoh Native Integration (SC-ZENOH-FSH-001 to SC-ZENOH-FSH-003) -->
    <!-- Real-time pub/sub connectivity to Indrajaal Elixir backend -->
    <!-- Level 1: Core Types and FFI (SC-NAT-001 to SC-NAT-004) -->
    <Compile Include="Zenoh/Core/ZenohTypes.fs" />
    <Compile Include="Zenoh/Core/ZenohSerialization.fs" />
    <!-- FFI Bridge: P/Invoke wrappers for native/zenoh_ffi Rust cdylib (SC-ZENOH-FFI-001 to SC-ZENOH-FFI-025) -->
    <Compile Include="Zenoh/Core/ZenohFfiBridge.fs" />
    <Compile Include="Zenoh/Core/ZenohNative.fs" />
    <!-- Level 3: Messaging (SC-MSG-001 to SC-MSG-006) -->
    <Compile Include="Zenoh/Messaging/ZenohEnvelope.fs" />
    <!-- Level 5: Session Lifecycle (SC-OP-001 to SC-OP-004, SC-SESS-001) -->
    <Compile Include="Zenoh/Session/ZenohLifecycle.fs" />
    <!-- FM-007: Health Gate (SC-ZENOH-007, SC-ZENOH-008, SC-CNT-015) -->
    <Compile Include="Zenoh/Session/ZenohHealthGate.fs" />
    <!-- Level 6: Cluster Coordination (SC-OP-005, SC-QUORUM-001, SC-SIL6-001) -->
    <Compile Include="Zenoh/Cluster/ZenohQuorum.fs" />
    <Compile Include="Zenoh/Cluster/ZenohConsensus.fs" />
    <!-- FM-006: Split-brain Resolution (SC-CONS-003, SC-CONS-005, SC-CONS-006) -->
    <Compile Include="Zenoh/Cluster/SplitBrainResolver.fs" />
