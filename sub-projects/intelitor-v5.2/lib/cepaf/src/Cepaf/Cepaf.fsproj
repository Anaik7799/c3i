    <!-- Security: Immutable Audit Trail (SC-SIL6-007, SC-REG-003, SC-SIL6-015) -->
    <Compile Include="Zenoh/Security/SignedBlock.fs" />
    <!-- Health: Dual-Layer Health Monitoring (SC-SIL6-004, SC-OP-003, SC-IMMUNE-001) -->
    <Compile Include="Zenoh/Health/DualLayerHealthMonitor.fs" />
    <!-- Guardian: Constitutional Validation (SC-SIL6-013, SC-CONST-001 to SC-CONST-004) -->
    <!-- Validates Ψ₀-Ψ₅ invariants and Ω₀ Founder's Directive before operations -->
    <Compile Include="Zenoh/Guardian/ConstitutionalChecker.fs" />
    <!-- Level 3-5: Session and Messaging (Legacy - to be migrated) -->
    <Compile Include="Zenoh/ZenohSession.fs" />
    <Compile Include="Zenoh/ZenohChannel.fs" />
    <!-- KMS Subscriber: Real-time holon state from Elixir KMS (SC-KMS-005) -->
    <Compile Include="Zenoh/KmsSubscriber.fs" />
    <!-- Zenoh Fractal Publisher (SC-ZENOH-PUB-001 to SC-ZENOH-PUB-003) -->
    <!-- Bridges Fractal logging to Zenoh for real-time streaming -->
    <Compile Include="Observability/Fractal/ZenohFractalPublisher.fs" />
    <!-- SC-ZTEST-001 to SC-ZTEST-011: Real-Time Test Messaging System (2026-01-18) -->
    <!-- Replaces log-based verification with Zenoh pub/sub for <100ms feedback -->
    <!-- Checkpoint-based messaging for boot phases, tests, and smoke tests -->
    <Compile Include="Zenoh/SmokeTestPublisher.fs" />
    <Compile Include="Zenoh/BootPhasePublisher.fs" />
    <!-- End Zenoh Integration -->
    <!-- Dashboard Components (SC-GUI-LOG-001 to SC-GUI-HIS-003) -->
    <!-- Real-time log viewer and historical query interface -->
    <Compile Include="Dashboard/FractalLogView.fs" />
    <Compile Include="Dashboard/HistoryQuery.fs" />
    <Compile Include="Dashboard/TelemetryPublisher.fs" />
    <!-- End Dashboard Components -->
    <!-- Cockpit Health Dashboard: TUI ANSI-coloured health rendering (SC-HMI-010, SC-CPU-GOV-001) -->
    <Compile Include="Cockpit/HealthDashboard.fs" />
    <!-- Cockpit Container Health Bars: per-container status bars (SC-HMI-010, SC-VER-031, SC-CNT-001) -->
    <Compile Include="Cockpit/ContainerHealthBars.fs" />
    <!-- Cockpit Math Integrity Pane: Hs/epsilon/Ds metrics (SC-MATH-001, SC-MATH-002) -->
    <Compile Include="Cockpit/MathIntegrityPane.fs" />
    <!-- Cockpit Sparkline Renderer: Unicode time-series charts for CPU/memory (SC-HMI-010, SC-CPU-GOV-001) -->
    <Compile Include="Cockpit/SparklineRenderer.fs" />
    <!-- Cockpit Evolution Vector View: V1-V4 gauges for Prajna Cockpit (SC-EVO-001, SC-HMI-010) -->
    <Compile Include="Cockpit/EvolutionVectorView.fs" />
    <!-- Cockpit Zettel View: Markdown renderer for SMRITI Zettelkasten client (SC-SMRITI-131, SC-HMI-010) -->
