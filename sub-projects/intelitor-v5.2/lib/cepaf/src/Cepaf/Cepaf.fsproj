    <!-- Cockpit F# DAP: Debug Adapter Protocol model layer (SC-DEBUG-001, SC-HMI-010) -->
    <Compile Include="Cockpit/FSharpDAP.fs" />
    <!-- Cockpit Bicameral Dashboard: Two-Key release protocol (SC-SAFETY-001, SC-GIT-006) -->
    <Compile Include="Cockpit/BicameralDashboard.fs" />
    <!-- Cockpit CRM Audit View: Field change tracking with audit log (SC-AUDIT-001, SC-REG-001) -->
    <Compile Include="Cockpit/CrmAuditView.fs" />
    <Compile Include="Observability/ConsoleChannel.fs" />
    <Compile Include="Observability/FileChannel.fs" />
    <Compile Include="Observability/TelemetryChannel.fs" />
    <Compile Include="Observability/StateTrackerChannel.fs" />
    <Compile Include="Observability/MetricsCollector.fs" />
    <Compile Include="Observability/QuadplexLogger.fs" />
    <Compile Include="Observability/Integration.fs" />
    <!-- CLI Dashboard System (Reusable UX Component) -->
