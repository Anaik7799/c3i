<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>preview</LangVersion>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <NoWarn>FS0667</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Unit Tests -->
    <Compile Include="SmartMetricTests.fs" />
    <Compile Include="SignalArrowsTests.fs" />
    <Compile Include="DarkCockpitUITests.fs" />
    <Compile Include="ZenohIntegrationTests.fs" />

    <!-- Property Tests -->
    <Compile Include="PropertyTests.fs" />

    <!-- Main entry point -->
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Cepaf.Cockpit/Cepaf.Cockpit.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FsCheck" Version="2.16.5" />
    <PackageReference Include="Expecto" Version="10.2.1" />
    <PackageReference Include="Expecto.FsCheck" Version="10.2.1" />
    <PackageReference Include="Unquote" Version="7.0.0" />
  </ItemGroup>

</Project>
