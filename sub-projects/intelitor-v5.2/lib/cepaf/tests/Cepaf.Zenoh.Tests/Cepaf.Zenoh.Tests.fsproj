<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>preview</LangVersion>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <NoWarn>FS0667</NoWarn>
  </PropertyGroup>

  <!-- =================================================================== -->
  <!-- STAMP: SC-TDG-001, SC-TDG-002, SC-TDG-003                          -->
  <!-- AOR: AOR-TEST-001, AOR-TEST-EVO-001                                -->
  <!-- Criticality: Level 1 (CRITICAL) - Test-Driven Generation          -->
  <!-- =================================================================== -->
  <!-- 7-Level Zenoh Test Suite                                           -->
  <!-- L1: FFI/Native Tests                                               -->
  <!-- L2: Core Primitives Tests                                          -->
  <!-- L3: Envelope/Messaging Tests                                       -->
  <!-- L4: Bridge Tests                                                   -->
  <!-- L5: Lifecycle Tests                                                -->
  <!-- L6: Cluster/Consensus Tests                                        -->
  <!-- L7: Federation Tests                                               -->
  <!-- =================================================================== -->

  <ItemGroup>
    <!-- Property-based tests (FsCheck) -->
    <Compile Include="PropertyTests.fs" />

    <!-- Level 1-3: Core Tests -->
    <Compile Include="ZenohTypesTests.fs" />
    <Compile Include="ZenohNativeTests.fs" />
    <Compile Include="ZenohEnvelopeTests.fs" />

    <!-- Level 4-5: Session Tests (TDG Comprehensive Suite) -->
    <Compile Include="ZenohLifecycleTests.fs" />
    <Compile Include="ZenohL4L5Tests.fs" />

    <!-- Level 6: Cluster Tests -->
    <Compile Include="ZenohQuorumTests.fs" />
    <Compile Include="ZenohConsensusTests.fs" />

    <!-- Level 7: Federation Tests -->
    <Compile Include="ZenohFederationTests.fs" />

    <!-- Integration Tests -->
    <Compile Include="IntegrationTests.fs" />

    <!-- SIL-6 Safety Tests -->
    <Compile Include="SIL6SafetyTests.fs" />

    <!-- Main entry point -->
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Cepaf/Cepaf.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" Version="10.2.1" />
    <PackageReference Include="Expecto.FsCheck" Version="10.2.1" />
    <PackageReference Include="FsCheck" Version="2.16.6" />
    <PackageReference Include="Unquote" Version="7.0.0" />
  </ItemGroup>

</Project>
