# Dockerfile.app-dev - Indrajaal Application Dev Base Image
# STAMP: SC-MESH-006, SC-NET-001, SC-CNT-009
# Purpose: Dev-mode base image with full toolchain for source-mounted containers
# Usage: Compose mounts workspace and runs mix compile + mix phx.server
#
# This replaces the broken 1.75MB NixOS skeleton (indrajaal-app-unified:nixos-devenv)
# with a functional image containing Elixir 1.19 + OTP 28 + Rust + Node.js

FROM docker.io/library/elixir:1.19-alpine

# Install build dependencies needed for mix compile + Zenoh NIF
RUN apk add --no-cache \
    build-base \
    linux-headers \
    git \
    curl \
    openssl-dev \
    rust \
    cargo \
    nodejs \
    npm \
    inotify-tools \
    postgresql-client \
    bash \
    && rm -rf /var/cache/apk/*

# Fix musl/glibc compat: picosat_elixir uses sys/unistd.h (glibc-only)
RUN mkdir -p /usr/include/sys && echo '#include <unistd.h>' > /usr/include/sys/unistd.h

# Set mix environment
ENV MIX_ENV=prod
ENV SKIP_ZENOH_NIF=0
ENV SKIP_LINEAGE_NIF=1
ENV LANG=C.UTF-8

# Install hex and rebar (baked in to avoid network fetch on every container start)
RUN mix local.hex --force && mix local.rebar --force

WORKDIR /workspace

# Health check: verify elixir runtime is functional
HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=10s \
    CMD elixir -e "IO.puts(:ok)" || exit 1

# Default entrypoint - compose will override with specific command
CMD ["elixir", "--version"]
