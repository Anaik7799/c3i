### **Automated Quality Enforcement Script**

**✅ CLAUDE MUST USE THIS PATTERN:**
```elixir
defmodule Claude.CodeQuality do
  @moduledoc """
  Mandatory code quality validation for all Claude-generated code
  """

  def validate_generated_code(file_path) do
    with :ok <- validate_format(file_path),
         :ok <- validate_credo(file_path) do
      Logger.info("✅ Code quality validation passed for #{file_path}")
      :ok
    else
      {:error, :format_issues} ->
        Logger.warn("⚠️ Format issues detected, auto-fixing...")
        System.cmd("mix", ["format", file_path])
        validate_generated_code(file_path)
        
      {:error, :credo_issues} ->
        Logger.warn("⚠️ Credo issues detected, fixing...")
        fix_credo_issues(file_path)
        validate_generated_code(file_path)
    end
  end
  
  defp validate_format(file_path) do
    case System.cmd("mix", ["format", "--check-formatted", file_path]) do
      {_, 0} -> :ok
      _ -> {:error, :format_issues}
    end
  end
  
  defp validate_credo(file_path) do
    case System.cmd("mix", ["credo", "--strict", file_path]) do
      {_, 0} -> :ok
      _ -> {:error, :credo_issues}
    end
  end
  
  defp fix_credo_issues(file_path) do
    # Apply common credo fixes
    # - Add @moduledoc
    # - Fix line length
    # - Remove unused variables
    # - Add specs
    :ok
  end
end
```

