```bash
# Claude MUST use this pattern for container compilation
podman exec container_name bash -c "
  export NO_TIMEOUT=true &&
  export PATIENT_MODE=enabled &&
  export BASH_DEFAULT_TIMEOUT_MS=3600000 &&
