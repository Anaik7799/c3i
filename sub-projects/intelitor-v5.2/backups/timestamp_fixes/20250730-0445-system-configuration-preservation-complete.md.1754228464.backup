CHROMEDRIVER_PATH=/home/an/.nix-profile/bin/chromedriver \
WALLABY_CHROME_PATH=/usr/bin/google-chrome \
ELIXIR_ERL_OPTIONS="+S 16" \
mix test test/integration/domain_integration_test.exs --exclude wallaby
```

