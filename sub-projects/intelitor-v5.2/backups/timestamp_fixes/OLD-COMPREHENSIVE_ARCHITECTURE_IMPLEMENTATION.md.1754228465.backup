    mode: :installation,
    phases: [],
    domains: @ash_domains,
    status: :preparing,
    errors: [],
    warnings: []
  }
end
```

#### 3.2 Phase-Based Installation System
```elixir
defp determine_installation_phases(opts) do
  base_phases = [
    %{name: "Environment Setup", type: :environment, duration: 60},
    %{name: "Nix Dependencies", type: :dependencies, duration: 120},
    %{name: "Elixir Project Init", type: :project_init, duration: 30},
    %{name: "Ash Framework Setup", type: :ash_setup, duration: 90},
    %{name: "Database Configuration", type: :database, duration: 45},
    %{name: "Domain Generation", type: :domains, duration: 60},
    %{name: "Resource Generation", type: :resources, duration: 120},
    %{name: "Authentication Setup", type: :auth, duration: 45},
    %{name: "API Configuration", type: :api, duration: 30},
    %{name: "Migration Generation", type: :migrations, duration: 30}
  ]
end
