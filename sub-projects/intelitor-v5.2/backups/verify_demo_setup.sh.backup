#!/bin/bash

echo "Verifying Intelitor Demo Setup..."
echo "================================="

# Check directory structure
echo -n "Checking directory structure... "
dirs=(lib config priv scripts test assets)
missing_dirs=()
for dir in "${dirs[@]}"; do
    if [ ! -d "$dir" ]; then
        missing_dirs+=("$dir")
    fi
done
if [ ${#missing_dirs[@]} -eq 0 ]; then
    echo "✓"
else
    echo "✗ Missing directories: ${missing_dirs[*]}"
fi

# Check essential files
echo -n "Checking essential files... "
files=(mix.exs mix.lock "lib/intelitor/application.ex" "lib/intelitor_web.ex")
missing_files=()
for file in "${files[@]}"; do
    if [ ! -f "$file" ]; then
        missing_files+=("$file")
    fi
done
if [ ${#missing_files[@]} -eq 0 ]; then
    echo "✓"
else
    echo "✗ Missing files: ${missing_files[*]}"
fi

# Check domain modules
echo -n "Checking domain modules... "
domains=(alarms sites devices core)
missing_domains=()
for domain in "${domains[@]}"; do
    if [ ! -f "lib/intelitor/${domain}.ex" ] || [ ! -d "lib/intelitor/${domain}" ]; then
        missing_domains+=("$domain")
    fi
done
if [ ${#missing_domains[@]} -eq 0 ]; then
    echo "✓"
else
    echo "✗ Missing domains: ${missing_domains[*]}"
fi

# Check Mix tasks
echo -n "Checking Mix demo tasks... "
mix_tasks=("setup_environment.ex" "validate_environment.ex" "alarm_processing.ex" "observability.ex")
missing_tasks=()
for task in "${mix_tasks[@]}"; do
    if [ ! -f "lib/mix/tasks/demo/$task" ]; then
        missing_tasks+=("$task")
    fi
done
if [ ${#missing_tasks[@]} -eq 0 ]; then
    echo "✓"
else
    echo "✗ Missing Mix tasks: ${missing_tasks[*]}"
fi

# Check demo scripts
echo -n "Checking demo scripts... "
script_count=$(find scripts/demo -name "*.exs" -type f | wc -l)
if [ $script_count -gt 50 ]; then
    echo "✓ ($script_count scripts found)"
else
    echo "✗ Only $script_count scripts found (expected 50+)"
fi

# Check migrations
echo -n "Checking database migrations... "
migration_count=$(find priv/repo/migrations -name "*.exs" -type f | wc -l)
if [ $migration_count -gt 5 ]; then
    echo "✓ ($migration_count migrations found)"
else
    echo "✗ Only $migration_count migrations found"
fi

echo ""
echo "File Statistics:"
echo "================"
echo "Elixir files (.ex):  $(find . -name "*.ex" -type f | wc -l)"
echo "Script files (.exs): $(find . -name "*.exs" -type f | wc -l)"
echo "Test files:          $(find test -name "*_test.exs" -type f | wc -l)"
echo "Total files:         $(find . -type f | wc -l)"

echo ""
echo "Demo setup verification complete!"