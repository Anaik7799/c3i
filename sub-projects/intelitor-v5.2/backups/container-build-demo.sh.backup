#!/bin/bash
# Container-Only Build Script for Intelitor Demo
# This script ensures ALL operations run in NixOS containers with PHICS/Claude AI

set -e  # Exit on error
set -u  # Exit on undefined variable

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
PROJECT_DIR=$(pwd)
CONTAINER_NAME="intelitor-demo"
DB_CONTAINER_NAME="intelitor-demo-db"
REDIS_CONTAINER_NAME="intelitor-demo-redis"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)

echo -e "${GREEN}=== Intelitor Demo Container-Only Build ===${NC}"
echo "Timestamp: $TIMESTAMP"
echo "Project Directory: $PROJECT_DIR"

# Function to check if container exists
container_exists() {
    nix-shell -p podman --run "podman ps -a --format '{{.Names}}' | grep -q '^$1$'"
}

# Function to check if container is running
container_running() {
    nix-shell -p podman --run "podman ps --format '{{.Names}}' | grep -q '^$1$'"
}

# Pre-execution optimizations
echo -e "\n${YELLOW}Setting system limits...${NC}"
ulimit -n 65536  # File descriptors
ulimit -u 32768  # Process limit

# Create local data directories
echo -e "\n${YELLOW}Creating local data directories...${NC}"
mkdir -p "$PROJECT_DIR/data/postgres"
mkdir -p "$PROJECT_DIR/data/redis"
mkdir -p "$PROJECT_DIR/logs"
mkdir -p "$PROJECT_DIR/tmp"
mkdir -p "$PROJECT_DIR/_build"
mkdir -p "$PROJECT_DIR/deps"

# Step 1: Container Setup
echo -e "\n${YELLOW}Step 1: Setting up containers...${NC}"

# Remove existing containers if they exist
if container_exists "$CONTAINER_NAME"; then
    echo "Removing existing container: $CONTAINER_NAME"
    nix-shell -p podman --run "podman rm -f $CONTAINER_NAME"
fi

if container_exists "$DB_CONTAINER_NAME"; then
    echo "Removing existing container: $DB_CONTAINER_NAME"
    nix-shell -p podman --run "podman rm -f $DB_CONTAINER_NAME"
fi

# Create network if it doesn't exist
echo "Creating podman network..."
nix-shell -p podman --run "podman network create intelitor-net 2>/dev/null || true"

# Start PostgreSQL container
echo "Starting PostgreSQL container..."
nix-shell -p podman --run "podman run -d \
  --name $DB_CONTAINER_NAME \
  -e POSTGRES_USER=postgres \
  -e POSTGRES_PASSWORD=postgres \
  -e POSTGRES_DB=intelitor_dev \
  -v $PROJECT_DIR/data/postgres:/var/lib/postgresql/data:z \
  -p 5433:5432 \
  --network intelitor-net \
  registry.nixos.org/nixos/postgresql:17"

# Wait for PostgreSQL to be ready
echo "Waiting for PostgreSQL to start..."
sleep 5

# Start main development container
echo "Starting development container with PHICS..."
nix-shell -p podman --run "podman run -d \
  --name $CONTAINER_NAME \
  -v $PROJECT_DIR:/workspace:z \
  -v $PROJECT_DIR/data:/data:z \
  -v $PROJECT_DIR/logs:/logs:z \
  -v $PROJECT_DIR/tmp:/tmp:z \
  -e PHICS_ENABLED=true \
  -e CLAUDE_AI_MODE=true \
  -e TPS_MODE=true \
  -e MIX_ENV=dev \
  -e ELIXIR_ERL_OPTIONS='+S 10' \
  -e DATABASE_URL='ecto://postgres:postgres@$DB_CONTAINER_NAME:5432/intelitor_dev' \
  -p 4000:4000 \
  -p 4001:4001 \
  --network intelitor-net \
  registry.nixos.org/nixos/nixos:25.05-small \
  tail -f /dev/null"

# Install dependencies in container
echo -e "\n${YELLOW}Installing Elixir and dependencies in container...${NC}"
nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  nix-env -iA nixos.elixir_1_18 \
    nixos.erlang_27 \
    nixos.nodejs_22 \
    nixos.git \
    nixos.inotify-tools \
    nixos.postgresql_17
'"

# Setup mix and hex
echo "Setting up Mix and Hex..."
nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  mix local.hex --force && \
  mix local.rebar --force
'"

# Step 2: Initial Compilation
echo -e "\n${YELLOW}Step 2: Running initial compilation...${NC}"
if ! nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  timeout 300 ELIXIR_ERL_OPTIONS=\"+S 10\" mix deps.get && \
  timeout 300 ELIXIR_ERL_OPTIONS=\"+S 10\" mix compile --warnings-as-errors
' 2>&1 | tee $PROJECT_DIR/logs/compilation-$TIMESTAMP.log"; then
    
    echo -e "${RED}Initial compilation failed. Running error analysis...${NC}"
    
    # Run 5-Level RCA
    echo "Running 5-Level Root Cause Analysis..."
    nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
      cd /workspace && \
      if [ -f scripts/analysis/five_level_rca_analyzer.exs ]; then
        elixir scripts/analysis/five_level_rca_analyzer.exs \
          --issue-type compilation_error \
          --analysis-depth comprehensive \
          --verbose
      fi
    '"
    
    # Step 3: Claude AI Compilation
    echo -e "\n${YELLOW}Step 3: Running Claude AI compilation with PHICS...${NC}"
    nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
      cd /workspace && \
      timeout 600 ELIXIR_ERL_OPTIONS=\"+S 10\" mix claude compilation \
        --warnings-as-errors \
        --agents 10 \
        --phics-agents 21 \
        --strategy smart \
        --dynamic-tokens \
        --parallel \
        --cache \
        --parallel-domains \
        --enable-phics \
        --container-sync \
        --hot-reload \
        --verbose
    ' 2>&1 | tee $PROJECT_DIR/logs/claude-compilation-$TIMESTAMP.log"
fi

# Step 4: Quality Analysis
echo -e "\n${YELLOW}Step 4: Running quality analysis...${NC}"
nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  timeout 300 ELIXIR_ERL_OPTIONS=\"+S 10\" mix claude quality \
    --analyze \
    --warning-elimination \
    --pattern-based \
    --verbose
' 2>&1 | tee $PROJECT_DIR/logs/quality-$TIMESTAMP.log" || true

# Step 5: Database Setup
echo -e "\n${YELLOW}Step 5: Setting up database...${NC}"
nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  timeout 120 ELIXIR_ERL_OPTIONS=\"+S 10\" mix ecto.create && \
  timeout 300 ELIXIR_ERL_OPTIONS=\"+S 10\" mix ecto.migrate
' 2>&1 | tee $PROJECT_DIR/logs/database-setup-$TIMESTAMP.log"

# Step 6: Run Tests
echo -e "\n${YELLOW}Step 6: Running comprehensive tests...${NC}"
nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  timeout 600 ELIXIR_ERL_OPTIONS=\"+S 10\" mix test \
    --comprehensive \
    --coverage 95 \
    --parallel
' 2>&1 | tee $PROJECT_DIR/logs/test-$TIMESTAMP.log" || true

# Step 7: Optimization
echo -e "\n${YELLOW}Step 7: Running optimization...${NC}"
nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  timeout 300 ELIXIR_ERL_OPTIONS=\"+S 10\" mix claude optimization \
    --analyze \
    --comprehensive \
    --auto-tune \
    --verbose
' 2>&1 | tee $PROJECT_DIR/logs/optimization-$TIMESTAMP.log" || true

# Step 8: Run Demo
echo -e "\n${YELLOW}Step 8: Running demo...${NC}"
if nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  timeout 300 ELIXIR_ERL_OPTIONS=\"+S 10\" mix demo --quick
' 2>&1 | tee $PROJECT_DIR/logs/demo-$TIMESTAMP.log"; then
    echo -e "${GREEN}Demo executed successfully!${NC}"
else
    echo -e "${YELLOW}Demo failed. Running comprehensive demo with error handling...${NC}"
    nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
      cd /workspace && \
      timeout 600 ELIXIR_ERL_OPTIONS=\"+S 10\" mix demo --comprehensive --verbose
    ' 2>&1 | tee $PROJECT_DIR/logs/demo-comprehensive-$TIMESTAMP.log" || true
fi

# Step 9: PHICS Validation
echo -e "\n${YELLOW}Step 9: Validating PHICS compliance...${NC}"
nix-shell -p podman --run "podman exec $CONTAINER_NAME sh -c '
  cd /workspace && \
  if [ -f scripts/pcis/validation_cli.exs ]; then
    elixir scripts/pcis/validation_cli.exs --phics-compliance --all
  fi
'"

# Final Status
echo -e "\n${GREEN}=== Build Process Complete ===${NC}"
echo "Logs saved in: $PROJECT_DIR/logs/"
echo ""
echo "Container Status:"
nix-shell -p podman --run "podman ps | grep intelitor-demo"
echo ""
echo "To access the development container:"
echo "  nix-shell -p podman --run \"podman exec -it $CONTAINER_NAME bash\""
echo ""
echo "To run the Phoenix server:"
echo "  nix-shell -p podman --run \"podman exec -it $CONTAINER_NAME sh -c 'cd /workspace && mix phx.server'\""
echo ""
echo "To stop all containers:"
echo "  nix-shell -p podman --run \"podman stop $CONTAINER_NAME $DB_CONTAINER_NAME\""