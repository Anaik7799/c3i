#\!/bin/bash
# Simple Phoenix startup script - dependencies already installed

# Set up environment
export NIX_PATH=nixpkgs=channel:nixos-unstable
export LANG=C.UTF-8
export LC_ALL=C.UTF-8
export ELIXIR_ERL_OPTIONS='+fnu'
export MIX_ENV=dev
export DATABASE_URL=postgresql://postgres:postgres@localhost:5434/intelitor_dev
export REDIS_URL=redis://localhost:6380

# Change to workspace directory
cd /workspace

echo "Starting Phoenix server (dependencies already installed)..."

# Run with nix-shell - skip dependency installation
nix-shell -p elixir_1_18 erlang_27 nodejs_20 --run '
  # Start Phoenix server directly
  echo "Starting Phoenix server on http://localhost:4000"
  exec mix phx.server
'
