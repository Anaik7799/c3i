{
  "title": "Alarms Dashboard",
  "description": "Real-time alarm monitoring and analytics for security incidents",
  "layout": "grid",
  "variables": [],
  "panels": [
    {
      "title": "Active Alarms",
      "type": "metric",
      "query": "sum(alarm_active_total)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Alarm Rate (per minute)",
      "type": "metric",
      "query": "sum(rate(alarm_created_total[1m]))",
      "gridPos": {
        "x": 3,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Avg Response Time",
      "type": "metric",
      "query": "avg(alarm_response_time_seconds)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Escalated Alarms",
      "type": "metric",
      "query": "sum(alarm_escalated_total)",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Alarms by Severity",
      "type": "metric",
      "query": "sum(alarm_active_total) by (severity)",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "pie",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Alarms by Type",
      "type": "metric",
      "query": "sum(alarm_active_total) by (type)",
      "gridPos": {
        "x": 6,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "bar",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Alarm Timeline",
      "type": "metric",
      "query": "sum(rate(alarm_created_total[5m])) by (severity)",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 4
      },
      "options": {
        "aggregation": "rate",
        "visualization": "line",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Recent Alarm Events",
      "type": "log",
      "query": "service=alarms",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 4
      },
      "options": {
        "columns": ["timestamp", "severity", "type", "site", "message"],
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Alarm Processing Traces",
      "type": "trace",
      "query": "service=alarms AND operation=process_alarm",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 4
      },
      "options": {
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    }
  ]
}