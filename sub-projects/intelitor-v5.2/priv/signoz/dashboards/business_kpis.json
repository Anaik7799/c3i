{
  "title": "Business KPIs Dashboard",
  "description": "Executive view of key business metrics and operational indicators",
  "layout": "grid",
  "variables": [],
  "panels": [
    {
      "title": "Monthly Active Users",
      "type": "metric",
      "query": "count(count by (user_id) (user_activity_total[30d]))",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Total Alarms (30d)",
      "type": "metric",
      "query": "sum(increase(alarm_created_total[30d]))",
      "gridPos": {
        "x": 3,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "System Uptime %",
      "type": "metric",
      "query": "(1 - avg(rate(system_downtime_seconds[30d])) / (30 * 24 * 3600)) * 100",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "visualization": "gauge",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Est. Revenue Impact",
      "type": "metric",
      "query": "sum(alarm_revenue_impact_dollars)",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "options": {
        "format": "currency",
        "visualization": "stat",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "User Growth Trend",
      "type": "metric",
      "query": "count(count by (user_id) (user_created_timestamp)) by (month)",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "line",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Alarm Resolution Efficiency",
      "type": "metric",
      "query": "avg(alarm_resolution_time_seconds) by (severity)",
      "gridPos": {
        "x": 6,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "options": {
        "visualization": "bar",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Site Activity Heatmap",
      "type": "metric",
      "query": "sum(site_activity_score) by (site_id, hour)",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 4
      },
      "options": {
        "visualization": "heatmap",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Customer Satisfaction Score",
      "type": "metric",
      "query": "avg(customer_satisfaction_score)",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 6,
        "h": 3
      },
      "options": {
        "min": 0,
        "max": 100,
        "visualization": "gauge",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Operational Efficiency Index",
      "type": "metric",
      "query": "(sum(alarm_resolved_total) / sum(alarm_created_total)) * 100",
      "gridPos": {
        "x": 6,
        "y": 11,
        "w": 6,
        "h": 3
      },
      "options": {
        "min": 0,
        "max": 100,
        "visualization": "gauge",
        "aggregation": "avg",
        "interval": "1m",
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    },
    {
      "title": "Key Business Events",
      "type": "log",
      "query": "level=info AND category=business",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 4
      },
      "options": {
        "columns": ["timestamp", "event", "impact", "details"],
        "time_range": "15m",
        "refresh_interval": "30s"
      }
    }
  ]
}