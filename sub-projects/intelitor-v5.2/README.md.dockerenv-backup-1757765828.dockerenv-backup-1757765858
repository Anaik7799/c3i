    def render(assigns) do
      ~H"""
      <div>Updated content here!</div>  <!-- This change appears instantly -->
      """
    end
  end

  # Browser automatically refreshes with new content
  # No container restart, no manual refresh needed

  3. Container-Native Watchers: File watching within container boundaries

  What it provides:

  File system monitoring that works inside containers, overcoming the traditional limitation where inotify
   events don't cross container boundaries.

  How it works:

  # PHICS implements container-aware file watching
  defmodule Phics.ContainerWatcher do
    use GenServer

    def start_link(_) do
      GenServer.start_link(__MODULE__, %{
        # Uses polling for reliability in containers
        backend: :fs_poll,
        # Watches the mounted workspace
        dirs: ["/workspace"],
        # Optimized polling interval
        interval: 100
      })
    end

    def handle_info({:file_event, path, events}, state) do
      # Triggers Phoenix recompilation
      Phoenix.CodeReloader.reload!()
      {:noreply, state}
    end
  end

  Key benefits:

  - Container-optimized: Uses polling instead of inotify for reliability
  - Resource efficient: Smart polling to minimize CPU usage
  - Cross-platform: Works on Linux, macOS, Windows containers
  - Automatic fallback: Detects best watching strategy

  Technical implementation:

  # PHICS automatically configures file watching based on environment
  if container_environment do
    # Use polling-based watcher
    config :phoenix_live_reload, backend: :fs_poll
  else
    # Use native inotify (host only)
    config :phoenix_live_reload, backend: :fs_inotify
  end

  4. Zero Configuration Setup: Automatic PHICS environment detection

  What it provides:

  PHICS automatically detects whether it's running in a container and configures itself appropriately - no
   manual setup required.

  How it works:

  # Automatic detection in application startup
  defmodule Intelitor.Application do
    def start(_type, _args) do
      # PHICS auto-detection
      phics_enabled = detect_phics_environment()

      if phics_enabled do
        # Automatically configure for container development
        configure_container_hot_reload()
        start_container_watchers()
        enable_bidirectional_sync()
      end

      # Continue with normal startup...
    end

    defp detect_phics_environment do
      # Multiple detection methods for reliability
      System.get_env("PHICS_ENABLED") == "true" ||
      File.exists?(".phics") ||
      File.exists?("/.dockerenv") ||
      File.exists?("/run/.containerenv") ||
      container_mount_detected?()
    end

    defp container_mount_detected? do
      # Detects if /workspace is a mount point
      case System.cmd("findmnt", ["-n", "-o", "TARGET", "/workspace"]) do
        {"/workspace\n", 0} -> true
        _ -> false
      end
    end
  end

  Key benefits:

  - No configuration files: Works out of the box
  - Smart defaults: Optimizes settings based on environment
  - Automatic optimization: Adjusts polling intervals, cache settings
  - Developer friendly: Just run the container and code

  Automatic configurations:

  # PHICS automatically sets these when detected:
  config :phoenix, :live_reload,
    url: "ws://localhost:4000",      # Correct WebSocket URL
    backend: :fs_poll,               # Container-compatible watcher
    interval: 100                    # Optimized polling

  config :intelitor, IntelitorWeb.Endpoint,
    http: [ip: {0, 0, 0, 0}],       # Bind to all interfaces
    url: [host: "localhost"],        # Correct external URL
    check_origin: false              # Allow connections from host

  # File sync optimization
  config :intelitor, :phics,
    sync_exclude: ~w(deps _build node_modules .git),
    sync_interval: 50,
    batch_timeout: 100

