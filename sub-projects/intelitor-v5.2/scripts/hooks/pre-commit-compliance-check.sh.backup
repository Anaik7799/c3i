#!/bin/sh

# Pre-Commit Document Compliance Hook
#
# **Date**: June 13, 2025  
# **Timestamp**: 2025-06-13T09:52:30Z  
# **Version**: Intelitor v0.2.0  
# **Generated By**: Claude AI (Sonnet 4)  
# **Environment**: NixOS 25.05, Elixir 1.18, Podman 5.4.1  
# **Category**: Configuration Document  
# **Valid Until**: September 11, 2025  

# This script runs before each commit to ensure document compliance

echo "🔒 Pre-Commit: Document Compliance Check"
echo "========================================"

# Check if we're in the project root
if [ ! -f "CLAUDE.md" ]; then
    echo "❌ Error: Not in project root directory"
    exit 1
fi

# Run the pre-commit compliance check
elixir scripts/maintenance/ci_cd_compliance_validator.exs --pre-commit

# Capture exit code
EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    echo "✅ Pre-commit compliance check passed"
    exit 0
else
    echo "❌ Pre-commit compliance check failed"
    echo ""
    echo "💡 To fix compliance issues, run:"
    echo "   elixir scripts/maintenance/document_compliance_dashboard.exs --fix-all"
    echo ""
    echo "To bypass this check (not recommended), use:"
    echo "   git commit --no-verify"
    exit 1
fi