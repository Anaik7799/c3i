#!/bin/bash
echo "🧠 THINKING: Compilation must happen within development container"
echo "🎯 DECISION: Use intelitor-dev-phics for all compilation"
echo "⚙️ EXECUTING: Container-based compilation"

podman exec intelitor-dev-phics bash -c "
    cd /workspace && 
    echo '📦 Installing dependencies...' &&
    mix deps.get &&
    echo '🔧 Compiling application...' &&
    mix compile --warnings-as-errors
"
