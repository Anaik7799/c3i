#!/bin/bash
echo "🔍 Validating existing container infrastructure..."

# Check if TPS Agent 2 containers exist
expected_containers=("intelitor-dev-phics" "intelitor-db-primary" "intelitor-cache-redis")

for container in "${expected_containers[@]}"; do
    if podman ps -a --format "{{.Names}}" | grep -q "^${container}$"; then
        status=$(podman ps --format "{{.Status}}" --filter "name=${container}")
        echo "✅ Container exists: ${container} - Status: ${status}"
    else
        echo "❌ Missing container: ${container}"
    fi
done

# Check PHICS integration
if podman exec intelitor-dev-phics test -f /workspace/.phics/config/phics.exs 2>/dev/null; then
    echo "✅ PHICS integration operational"
else
    echo "⚠️ PHICS integration may need setup"
fi
