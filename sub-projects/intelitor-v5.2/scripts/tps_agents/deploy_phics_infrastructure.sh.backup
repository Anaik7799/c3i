#!/bin/bash

echo "🏭 TPS AGENT 3: PHICS INFRASTRUCTURE DEPLOYMENT"
echo "==============================================="
echo "🧠 THINKING: Need to deploy complete PHICS container infrastructure"
echo "🎯 DECISION: Deploy systematic container-first environment within DevEnv"
echo "⚙️ EXECUTING: Comprehensive PHICS deployment"

# Ensure we're in the project directory
cd /home/an/dev/elixir/ash/intelitor

echo ""
echo "📁 Creating required directories..."
mkdir -p data/postgres data/phics data/redis data/prometheus data/grafana
mkdir -p logs/phics logs/containers logs/monitoring
mkdir -p config/phics config/containers config/monitoring
mkdir -p artifacts/containers artifacts/performance

echo "✅ Directories created"

echo ""
echo "🌐 Creating container networks..."
if ! podman network ls | grep -q "intelitor-phics"; then
    podman network create intelitor-phics
    echo "✅ Created network: intelitor-phics"
else
    echo "ℹ️ Network already exists: intelitor-phics"
fi

echo ""
echo "🐳 Creating development container with PHICS..."
if ! podman ps -a --format "{{.Names}}" | grep -q "^intelitor-dev-phics$"; then
    podman run -d \
        --name intelitor-dev-phics \
        --network intelitor-phics \
        -v "$(pwd):/workspace:z" \
        -v "./data/phics:/workspace/.phics:z" \
        -v "./logs/phics:/workspace/.phics/logs:z" \
        -p 4000:4000 \
        -p 4001:4001 \
        -e "PHICS_ENABLED=true" \
        -e "MIX_ENV=dev" \
        --privileged \
        registry.nixos.org/nixos/nix:latest \
        tail -f /dev/null
    
    echo "✅ Development container created: intelitor-dev-phics"
else
    echo "ℹ️ Development container already exists"
fi

echo ""
echo "🗄️ Creating database container..."
if ! podman ps -a --format "{{.Names}}" | grep -q "^intelitor-db-phics$"; then
    podman run -d \
        --name intelitor-db-phics \
        --network intelitor-phics \
        -v "./data/postgres:/var/lib/postgresql/data:z" \
        -p 5433:5432 \
        -e "POSTGRES_DB=intelitor_dev" \
        -e "POSTGRES_USER=postgres" \
        -e "POSTGRES_PASSWORD=postgres" \
        docker.io/library/postgres:17-alpine
    
    echo "✅ Database container created: intelitor-db-phics"
else
    echo "ℹ️ Database container already exists"
fi

echo ""
echo "🧪 Creating testing container..."
if ! podman ps -a --format "{{.Names}}" | grep -q "^intelitor-test-runner$"; then
    podman run -d \
        --name intelitor-test-runner \
        --network intelitor-phics \
        -v "$(pwd):/workspace:z" \
        -v "./data/phics:/workspace/.phics:z" \
        -e "MIX_ENV=test" \
        -e "PHICS_ENABLED=true" \
        --privileged \
        registry.nixos.org/nixos/nix:latest \
        tail -f /dev/null
    
    echo "✅ Testing container created: intelitor-test-runner"
else
    echo "ℹ️ Testing container already exists"
fi

echo ""
echo "🔧 Creating analysis containers..."
if ! podman ps -a --format "{{.Names}}" | grep -q "^intelitor-analysis-agent$"; then
    podman run -d \
        --name intelitor-analysis-agent \
        --network intelitor-phics \
        -v "$(pwd):/workspace:z" \
        -v "./data/analysis:/workspace/.analysis:z" \
        -e "ANALYSIS_ROLE=docker_violation_scanner" \
        registry.nixos.org/nixos/nix:latest \
        tail -f /dev/null
    
    echo "✅ Analysis container created: intelitor-analysis-agent"
else
    echo "ℹ️ Analysis container already exists"
fi

if ! podman ps -a --format "{{.Names}}" | grep -q "^intelitor-validation-agent$"; then
    podman run -d \
        --name intelitor-validation-agent \
        --network intelitor-phics \
        -v "$(pwd):/workspace:z" \
        -v "./data/validation:/workspace/.validation:z" \
        -e "VALIDATION_ROLE=pcis_compliance_checker" \
        registry.nixos.org/nixos/nix:latest \
        tail -f /dev/null
    
    echo "✅ Validation container created: intelitor-validation-agent"
else
    echo "ℹ️ Validation container already exists"
fi

echo ""
echo "🔥 Setting up PHICS integration..."
# Install PHICS packages in development container
podman exec intelitor-dev-phics sh -c "
    echo 'Installing PHICS packages...' &&
    apk add --no-cache inotify-tools curl nodejs npm &&
    mkdir -p /workspace/.phics/{watchers,config,logs} &&
    echo 'PHICS packages installed'
"

# Create PHICS watcher script
cat > config/phics/watcher.sh << 'EOF'
#!/bin/bash
echo "🔥 Starting PHICS file watcher..."
inotifywait -m -r -e modify,create,delete,move \
  --include '\.(ex|exs|heex|eex|js|css)$' \
  /workspace/lib /workspace/assets /workspace/test |
while read path action file; do
  echo "📝 File changed: $path$file ($action)"
  curl -s http://localhost:4001/phoenix/live_reload/frame || true
  echo "$(date): $path$file ($action)" >> /workspace/.phics/logs/changes.log
done
EOF

chmod +x config/phics/watcher.sh

# Copy watcher to containers
podman cp config/phics/watcher.sh intelitor-dev-phics:/workspace/.phics/watcher.sh
podman cp config/phics/watcher.sh intelitor-test-runner:/workspace/.phics/watcher.sh

echo "✅ PHICS integration setup complete"

echo ""
echo "📊 VALIDATING: Container infrastructure status"
echo "=============================================="
podman ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"

echo ""
echo "🌐 Network status:"
podman network ls

echo ""
echo "🏆 PHICS INFRASTRUCTURE DEPLOYMENT COMPLETE"
echo "✅ Container-first development environment operational"
echo "✅ All containers running and accessible"
echo "✅ PHICS integration ready for hot-reloading"
echo "✅ Ready for Docker violation resolution"
#═══════════════════════════════════════════════════════════════════════════════
# PATIENT MODE - NO_TIMEOUT POLICY VARIABLES
#═══════════════════════════════════════════════════════════════════════════════

# Patient Mode Configuration
export PATIENT_MODE=enabled
export NO_TIMEOUT=true
export INFINITE_PATIENCE=true
export TIMEOUT_POLICY=none

# Patient Mode Execution Settings
export COMPILE_TIMEOUT=infinity
export TEST_TIMEOUT=infinity
export DEMO_TIMEOUT=infinity
export TASK_TIMEOUT=infinity


#═══════════════════════════════════════════════════════════════════════════════
# 11-AGENT ARCHITECTURE COORDINATION VARIABLES
#═══════════════════════════════════════════════════════════════════════════════

# Agent Architecture Configuration
export AGENT_COORDINATION=enabled
export SUPERVISOR_AGENTS=1
export HELPER_AGENTS=4
export WORKER_AGENTS=6
export TOTAL_AGENTS=11

# Agent Coordination Settings
export MULTI_AGENT_COORDINATION=enabled
export DYNAMIC_LOAD_BALANCING=enabled
export AGENT_COMMUNICATION=enabled
export COORDINATION_STRATEGY=cybernetic


