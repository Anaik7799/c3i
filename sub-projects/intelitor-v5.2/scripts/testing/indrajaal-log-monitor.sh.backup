#!/bin/bash

# Intelitor Log Monitoring Script
# Monitors log directory size and enforces 100GB limit

LOG_DIR="/home/an/dev/elixir/ash/intelitor/logs"
MAX_SIZE_GB=100
CLEANUP_THRESHOLD_GB=$((MAX_SIZE_GB - 10))  # Start cleanup at 90GB
CHECK_INTERVAL=60  # Check every minute

log_message() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a /home/an/dev/elixir/ash/intelitor/logs/monitoring/log-monitor.log
}

get_directory_size_gb() {
    du -sg "$LOG_DIR" 2>/dev/null | cut -f1
}

cleanup_old_logs() {
    log_message "Starting log cleanup - size limit approaching"
    
    # Remove oldest compressed logs first
    find "$LOG_DIR" -name "*.gz" -type f -mtime +1 | head -20 | xargs rm -f
    
    # Remove oldest archived logs
    find "$LOG_DIR/archived" -type f -mtime +1 | head -10 | xargs rm -f
    
    # Force log rotation for all active logs
    logrotate -f /etc/logrotate.d/intelitor-scalability
    
    log_message "Log cleanup completed"
}

emergency_cleanup() {
    log_message "EMERGENCY: Log size limit exceeded - performing aggressive cleanup"
    
    # Remove all compressed logs older than 30 minutes
    find "$LOG_DIR" -name "*.gz" -type f -mmin +30 | xargs rm -f
    
    # Truncate large active log files
    find "$LOG_DIR" -name "*.log" -size +100M -exec truncate -s 50M {} \;
    
    log_message "Emergency cleanup completed"
}

main_loop() {
    log_message "Starting log monitoring (limit: ${MAX_SIZE_GB}GB)"
    
    while true; do
        CURRENT_SIZE=$(get_directory_size_gb)
        
        if [ "$CURRENT_SIZE" -gt "$MAX_SIZE_GB" ]; then
            log_message "CRITICAL: Log size ${CURRENT_SIZE}GB exceeds limit ${MAX_SIZE_GB}GB"
            emergency_cleanup
        elif [ "$CURRENT_SIZE" -gt "$CLEANUP_THRESHOLD_GB" ]; then
            log_message "WARNING: Log size ${CURRENT_SIZE}GB approaching limit - starting cleanup"
            cleanup_old_logs
        else
            log_message "Log size OK: ${CURRENT_SIZE}GB (limit: ${MAX_SIZE_GB}GB)"
        fi
        
        sleep $CHECK_INTERVAL
    done
}

# Handle signals gracefully
trap 'log_message "Log monitoring stopped"; exit 0' TERM INT

# Start monitoring
main_loop
