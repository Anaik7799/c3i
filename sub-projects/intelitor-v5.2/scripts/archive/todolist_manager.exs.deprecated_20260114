  @spec find_tasks(String.t()) :: any()
  def find_tasks(keyword) do
    IO.puts("🔍 SEARCHING FOR TASKS CONTAINING: #{keyword}")
    IO.puts("=" <> String.duplicate("=", 50))

    if File.exists?(@todolist_file) do
      content = File.read!(@todolist_file)

      # Find all tasks containing the keyword (case-insensitive)
      lines = String.split(content, "\n")

      matching_tasks =
        lines
        |> Enum.with_index(1)
        |> Enum.filter(fn {line, _} ->
          String.contains?(String.downcase(line), String.downcase(keyword)) and
          String.contains?(line, "###")
        end)

      if length(matching_tasks) > 0 do
        IO.puts("📋 FOUND #{length(matching_tasks)} MATCHING TASKS:")
        IO.puts("")

        matching_tasks
        |> Enum.each(fn {line, line_num} ->
          IO.puts("  Line #{line_num}: #{String.trim(line)}")
        end)
      else
        IO.puts("❌ No tasks found containing '#{keyword}'")
      end
    else
      IO.puts("❌ Todolist file not found!")
    end
  end

  @spec add_custom_task(String.t(), String.t(), String.t(), String.t()) :: any()
  def add_custom_task(task_id, parent_id, priority, task_content) do
    with_transaction("add_custom_task", fn ->
      IO.puts("➕ ADDING CUSTOM TASK: #{task_id} - #{task_content}")

      if File.exists?(@todolist_file) do
        content = File.read!(@todolist_file)
        timestamp = DateTime.utc_now() |> Calendar.strftime("%Y-%m-%d %H:%M:%S UTC")

        parent_line = if parent_id != "none", do: " | **Parent**: #{parent_id}", else: ""

        new_task = """

        ### #{task_id} - #{task_content} (#{priority})
        **Status**: pending | **Priority**: #{priority}#{parent_line}
        **Created**: #{timestamp}
        """

        updated_content = content <> new_task
        case atomic_write(@todolist_file, updated_content) do
          :ok ->
            do_sync_with_git()
            IO.puts("✅ Task added successfully")
          error -> IO.puts("❌ Failed to write task: #{inspect(error)}")
        end
      else
        IO.puts("❌ Todolist file not found!")
      end
    end)
  end

  @spec add_task(String.t(), String.t()) :: any()
  def add_task(parent_id, task_content) do
    with_transaction("add_task", fn ->
      IO.puts("➕ ADDING TASK: #{task_content}")
      IO.puts("📋 Parent: #{parent_id}")

      if File.exists?(@todolist_file) do
        content = File.read!(@todolist_file)

        # For now, just append to end - in full implementation would find parent and insert
        timestamp = DateTime.utc_now() |> Calendar.strftime("%Y-%m-%d %H:%M:%S UTC")
