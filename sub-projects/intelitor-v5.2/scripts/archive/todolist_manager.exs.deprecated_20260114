  def verify_state_consistency(sessions \\ nil) do
    sessions = sessions || get_active_sessions()
    
    if File.exists?(@todolist_file) do
      content = File.read!(@todolist_file)
      tasks = parse_tasks(content)
      
      issues = Enum.reduce(sessions, [], fn session, acc ->
        task = Enum.find(tasks, & &1.id == session["task_id"])
        if task do
          if task.status != "in_progress" do
            ["Task #{session["task_id"]} is '#{task.status}' in MD but active in session." | acc]
          else
            acc
          end
        else
          ["Task #{session["task_id"]} not found in MD." | acc]
        end
      end)
      
      if issues != [] do
        IO.puts("⚠️  STATE INCONSISTENCY DETECTED:")
        Enum.each(issues, &IO.puts("  - #{&1}"))
      else
        if length(sessions) > 0, do: IO.puts("✅ State is consistent.")
      end
    end
  end

