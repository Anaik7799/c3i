  @spec show_active_tasks(term()) :: term()
  defp show_active_tasks(content) do
    IO.puts("🔄 ACTIVE TASKS:")

    lines = String.split(content, "\n")
    in_progress_lines = Enum.filter(lines, &String.contains?(&1, "**Status**: in_progress"))
    
    # Get ASSP data
    sessions = get_active_sessions()
    session_map = Map.new(sessions, fn s -> {s["task_id"], s} end)

    case in_progress_lines do
      [] ->
        IO.puts("  No tasks currently in progress")

      tasks ->
        tasks
        |> Enum.each(fn line ->
          # Look for the task description in the previous lines
          {task_id, task_title} = extract_task_info(lines, line)
          
          # Check ASSP lock
          lock_info = case Map.get(session_map, task_id) do
            nil -> ""
            s -> " [🔒 Locked by #{s["agent"]}]"
          end
          
          IO.puts("  • #{task_id} - #{task_title}#{lock_info}")
        end)
    end
  end

  defp extract_task_info(lines, status_line) do
    index = Enum.find_index(lines, &(&1 == status_line))

    if index && index > 0 do
      previous_lines = Enum.take(lines, index) |> Enum.reverse()
      task_header = Enum.find(previous_lines, &String.starts_with?(&1, "#"))

      if task_header do
        # Parse "### 18.0 - Title (P3...)"
        case Regex.run(~r/^#+\s+([\d\.\wX]+)\s+-\s+(.+?)(\s+\(P\d.*\))?$/, task_header) do
          [_, id, title | _] -> {String.trim(id), String.trim(title)}
          _ -> {"unknown", String.trim(task_header)}
        end
      else
        {"unknown", "Unknown task"}
      end
    else
      {"unknown", "Unknown task"}
    end
  end

