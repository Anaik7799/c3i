  defp update_task_status(content, task_id, new_status) do
    lines = String.split(content, "\n")
    
    {updated_lines, _} = Enum.map_reduce(lines, nil, fn line, current_id ->
      # Check for header line: "### 1.0 - Title"
      # Regex matches: start of line, hashes, whitespace, ID, whitespace, dash
      new_current_id = case Regex.run(~r/^#+\s+([\d\.\wX]+)\s+-/, line) do
        [_, id] -> id
        nil -> current_id
      end

      # Check for Status line
      updated_line = if new_current_id == task_id and String.contains?(line, "**Status**:") do
        String.replace(line, ~r/\*\*Status\*\*: \w+/, "**Status**: #{new_status}")
      else
        line
      end

      {updated_line, new_current_id}
    end)

    Enum.join(updated_lines, "\n")
  end

