  # ==================== ADVANCED PARALLELIZATION & SYNC ====================

  @doc """
  Parses the todo list into a structured format for analysis.
  """
  def parse_tasks(content) do
    lines = String.split(content, "\n")
    
    {tasks, last_task} = Enum.reduce(lines, {[], nil}, fn line, {acc, current_task} ->
      # Match headers like "### 13.0 - Title" or "#### 13.1 - Title"
      if Regex.match?(~r/^#+\s+[\d\.\wX]+\s+-/, line) do
        # Save previous task
        new_acc = if current_task, do: [finalize_task(current_task) | acc], else: acc
        
        # Start new task
        [_, id, title] = Regex.run(~r/^#+\s+([\d\.\wX]+)\s+-\s+(.+)/, line)
        
        # Extract priority from title if present "(P1 ...)"
        priority = case Regex.run(~r/\((P\d).*\)/, title) do
          [_, p] -> p
          nil -> nil
        end
        
        clean_title = String.replace(title, ~r/\s+\(P\d.*\)/, "") |> String.trim()
        
        new_task = %{
          id: id,
          title: clean_title,
          priority: priority,
          lines: []
        }
        {new_acc, new_task}
      else
        if current_task do
          # Append line to current task body
          updated_task = Map.update!(current_task, :lines, fn l -> [line | l] end)
          {acc, updated_task}
        else
          # Still in prologue
          {acc, nil}
        end
      end
    end)
    
    # Add the very last task
    final_tasks = if last_task, do: [finalize_task(last_task) | tasks], else: tasks
    
    Enum.reverse(final_tasks)
  end

  defp finalize_task(task) do
    body = Enum.reverse(task.lines) |> Enum.join("\n")
    
    status = extract_attribute(body, "Status")
    priority = task.priority || extract_attribute(body, "Priority")
    parent = extract_attribute(body, "Parent")
    assigned = extract_attribute(body, "Assigned")
    file_ref = extract_attribute(body, "File")

    task
    |> Map.delete(:lines)
    |> Map.merge(%{
      status: status,
      priority: priority,
      parent: parent,
      assigned: assigned,
      file: file_ref
    })
  end

  defp extract_attribute(text, key) do
    case Regex.run(~r/\*\*#{key}\*\*:\s*([^\|\n]+)/, text) do
      [_, val] -> String.trim(val)
      nil -> 
        # Try simplified format "Status: pending" (without bold)
        case Regex.run(~r/^#{key}:\s*([^\|\n]+)/m, text) do
          [_, val] -> String.trim(val)
          nil -> nil
        end
    end
  end

  def dispatch_tasks do
    IO.puts("🤖 ANALYZING PARALLEL EXECUTION PLAN...")
    
    if File.exists?(@todolist_file) do
      content = File.read!(@todolist_file)
      tasks = parse_tasks(content)
      
      # Build status map for fast lookup
      status_map = Map.new(tasks, fn t -> {t.id, t.status} end)
      
      # Get currently active tasks (to filter them out)
      active_session_ids = get_active_sessions() |> Enum.map(& &1["task_id"])
      
      # Identify dispatchable tasks
      # Criteria:
      # 1. Status is 'pending'
      # 2. Parent is 'in_progress' or 'completed' (or root/nil)
      # 3. Not in active sessions (massively concurrent safety)
      
      dispatchable = tasks
      |> Enum.filter(fn t -> 
        t.status == "pending" and 
        t.id not in active_session_ids and
        (is_nil(t.parent) or 
         t.parent in ["0", "0.0"] or
         Map.get(status_map, t.parent) in ["in_progress", "completed", "Active Development"]) 
      end)
      |> Enum.sort_by(fn t -> t.priority || "P9" end) # P1 first

      # Simulate Agent Assignment
      # We have 10 Workers, 4 Functional Supervisors
      agents = 1..10 |> Enum.map(&"Worker-#{&1}")
      
      assignments = 
        dispatchable
        |> Enum.with_index()
        |> Enum.map(fn {task, idx} ->
          agent = Enum.at(agents, rem(idx, length(agents)))
          Map.put(task, :suggested_agent, agent)
        end)

      # Output JSON-like structure
      IO.puts("\n📋 DISPATCH PLAN (JSON):")
      IO.puts("[")
      assignments
      |> Enum.map(fn t -> 
        """
          {
            "id": "#{t.id}",
            "priority": "#{t.priority}",
            "parent": "#{t.parent}",
            "agent": "#{t.suggested_agent}",
            "title": "#{t.title}"
          }
        """ 
      end)
      |> Enum.join(",\n")
      |> IO.puts()
      IO.puts("]")
      
      IO.puts("\n✅ Found #{length(assignments)} parallelizable tasks.")
    else
      IO.puts("❌ Todolist file not found!")
    end
  end

  def sync_system_state do
    with_transaction("sync_system", fn ->
      IO.puts("🔄 SYNCING WITH SYSTEM STATE...")
      
      if File.exists?(@todolist_file) do
        content = File.read!(@todolist_file)
        tasks = parse_tasks(content)
        
        # Identify tasks where file exists but status is pending
        updates = 
          tasks
          |> Enum.filter(fn t -> 
            t.status == "pending" and not is_nil(t.file)
          end)
          |> Enum.filter(fn t -> 
            # Remove backticks if present in file path
            clean_path = String.replace(t.file, "`", "")
            File.exists?(clean_path)
          end)
        
        if updates == [] do
          IO.puts("✅ System state is consistent with todo list.")
        else
          IO.puts("⚠️  Found #{length(updates)} tasks with existing files but 'pending' status:")
          
          # Auto-update logic
          updated_content = Enum.reduce(updates, content, fn t, acc ->
            IO.puts("  • Updating #{t.id} -> in_progress (File found: #{t.file})")
            update_task_status(acc, t.id, "in_progress")
          end)
          
          case atomic_write(@todolist_file, updated_content) do
            :ok -> IO.puts("✅ Sync complete. Updated #{length(updates)} tasks.")
            error -> IO.puts("❌ Failed to save updates: #{inspect(error)}")
          end
        end
      else
        IO.puts("❌ Todolist file not found!")
      end
    end)
  end

  @spec show_status() :: any()
  def show_status do
    # Read-only operation, but good to check if locked to be safe, 
    # though technically we can read while locked if we accept stale data.
    # For robust consistency, we'll assume we can read anytime (non-blocking).
    
    IO.puts("🎯 INTELITOR PROJECT TODOLIST STATUS")
    IO.puts("=" <> String.duplicate("=", 50))

    if File.exists?(@todolist_file) do
      content = File.read!(@todolist_file)

      # Extract completion stats
      total_tasks = count_tasks(content)
      completed_tasks = count_completed(content)
      in_progress_tasks = count_in_progress(content)
      pending_tasks = count_pending(content)
      blocked_tasks = count_blocked(content)

      completion_percentage =
        if total_tasks > 0, do: Float.round(completed_tasks / total_tasks * 100, 1), else: 0.0

      IO.puts("📊 Project Progress: #{completion_percentage}% (#{completed_tasks}/#{total_tasks})")
      IO.puts("🔄 In Progress: #{in_progress_tasks}")
      IO.puts("⏳ Pending: #{pending_tasks}")
      IO.puts("🚫 Blocked: #{blocked_tasks}")
      IO.puts("")

      # Show active tasks
      show_active_tasks(content)
    else
      IO.puts("❌ PROJECT_TODOLIST.md not found!")
      IO.puts("Creating initial todolist file...")
      create_initial_todolist()
    end
  end

  @spec update_task(String.t(), String.t()) :: any()
  def update_task(task_ids_str, status) do
    with_transaction("update_task", fn ->
      if not File.exists?(@todolist_file) do
        IO.puts("❌ PROJECT_TODOLIST.md not found!")
        :error
      else
        content = File.read!(@todolist_file)
        
        # Handle multiple comma-separated IDs
        updated_content = 
          task_ids_str
          |> String.split(",")
          |> Enum.map(&String.trim/1)
          |> Enum.reduce(content, fn task_id, acc ->
             update_task_status(acc, task_id, status)
          end)

        case atomic_write(@todolist_file, updated_content) do
          :ok -> 
            do_sync_with_git()
            IO.puts("✅ Task(s) #{task_ids_str} updated to #{status}")
          error -> IO.puts("❌ Failed to write update: #{inspect(error)}")
        end
      end
    end)
  end

