        ### #{parent_id}.X - #{task_content} (P3 - Medium)
        **Status**: pending | **Priority**: P3 | **Parent**: #{parent_id}
        **Created**: #{timestamp}
        """

        updated_content = content <> new_task
        case atomic_write(@todolist_file, updated_content) do
          :ok -> 
            do_sync_with_git()
            IO.puts("✅ Task added successfully")
          error -> IO.puts("❌ Failed to write task: #{inspect(error)}")
        end
      else
        IO.puts("❌ Todolist file not found!")
      end
    end)
  end

  @spec show_working_set() :: any()
  def show_working_set do
    IO.puts("🎯 CURRENT WORKING SET")
    IO.puts("=" <> String.duplicate("=", 30))

    if File.exists?(@todolist_file) do
      content = File.read!(@todolist_file)
      lines = String.split(content, "\n")

      # Find in_progress tasks (current working set)
      working_tasks = Enum.filter(lines, &String.contains?(&1, "**Status**: in_progress"))
      
      # Get ASSP data
      sessions = get_active_sessions()
      session_map = Map.new(sessions, fn s -> {s["task_id"], s} end)

      if length(working_tasks) > 0 do
        IO.puts("📋 ACTIVE WORK (#{length(working_tasks)} tasks):")
        IO.puts("")

        working_tasks
        |> Enum.each(fn line ->
          {task_id, task_title} = extract_task_info(lines, line)
          
          # Check ASSP lock
          lock_info = case Map.get(session_map, task_id) do
            nil -> ""
            s -> " [🔒 Locked by #{s["agent"]}]"
          end
          
          IO.puts("  🔄 #{task_id} - #{task_title}#{lock_info}")
        end)
      else
        IO.puts("✅ No tasks currently in progress")
      end
    else
      IO.puts("❌ Todolist file not found!")
    end
  end

  @spec restore_backup(String.t()) :: any()
  def restore_backup(backup_file) do
    with_transaction("restore_backup", fn ->
      IO.puts("🔄 RESTORING FROM BACKUP: #{backup_file}")

      backup_path = Path.join(@backup_dir, backup_file)

      if File.exists?(backup_path) do
        # Create backup of current file before restore
        do_create_backup()

        # Copy backup to main file
        content = File.read!(backup_path)
        case atomic_write(@todolist_file, content) do
          :ok ->
            IO.puts("✅ Restored from #{backup_file}")
          {:error, reason} ->
            IO.puts("❌ Failed to restore: #{reason}")
        end
      else
        IO.puts("❌ Backup file not found: #{backup_path}")
      end
    end)
  end

  @spec validate_structure() :: any()
  def validate_structure do
    IO.puts("🔍 VALIDATING TODOLIST STRUCTURE...")

    if File.exists?(@todolist_file) do
      content = File.read!(@todolist_file)
      lines = String.split(content, "\n")

      # Basic validation checks
      header_count = Enum.count(lines, &String.contains?(&1, "###"))
      status_count = Enum.count(lines, &String.contains?(&1, "**Status**:"))

      IO.puts("📊 Structure Analysis:")
      IO.puts("  • Task headers (###): #{header_count}")
      IO.puts("  • Status lines: #{status_count}")

      if header_count == status_count do
        IO.puts("✅ Structure appears valid")
      else
        IO.puts("⚠️  Potential structure issues detected")
      end
    else
      IO.puts("❌ Todolist file not found!")
    end
  end

  @spec validate_hierarchical_numbering() :: any()
  def validate_hierarchical_numbering do
    IO.puts("🔍 VALIDATING HIERARCHICAL NUMBERING...")

    if File.exists?(@todolist_file) do
      content = File.read!(@todolist_file)
      lines = String.split(content, "\n")

      # Find all task headers
      headers = Enum.filter(lines, &String.contains?(&1, "###"))

      IO.puts("📊 Found #{length(headers)} task headers")

      # Simple validation - just check they exist
      if length(headers) > 0 do
        IO.puts("✅ Hierarchical structure exists")
      else
        IO.puts("❌ No hierarchical headers found")
      end
    else
      IO.puts("❌ Todolist file not found!")
    end
  end

  @spec sync_with_validation() :: any()
  def sync_with_validation do
    IO.puts("🔄 SYNCING WITH VALIDATION...")
    validate_structure()
    sync_with_git()
  end

  @spec validate_strict_compliance() :: any()
  def validate_strict_compliance do
    IO.puts("🔍 STRICT COMPLIANCE VALIDATION...")
    validate_structure()
    validate_hierarchical_numbering()
    IO.puts("✅ Strict validation complete")
  end

