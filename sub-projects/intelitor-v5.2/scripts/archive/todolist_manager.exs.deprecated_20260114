  # ==================== CONCURRENCY CONTROL ====================

  defp acquire_lock(retries \\ @lock_max_retries) do
    case File.mkdir(@lock_dir) do
      :ok -> :ok
      {:error, :eexist} ->
        if is_stale_lock?() do
          Logger.warning("⚠️ Found stale lock (older than #{@stale_lock_age}s). Forcing release.")
          release_lock()
          acquire_lock(retries)
        else
          if retries > 0 do
            # Add jitter to avoid thundering herd
            jitter = :rand.uniform(100)
            Process.sleep(@lock_retry_delay_base + jitter)
            acquire_lock(retries - 1)
          else
            {:error, :timeout}
          end
        end
      err -> err
    end
  end

  defp release_lock do
    File.rmdir(@lock_dir)
  end

  defp is_stale_lock? do
    case File.stat(@lock_dir) do
      {:ok, info} ->
        {date, time} = info.mtime
        case NaiveDateTime.from_erl({date, time}) do
          {:ok, dt} ->
             age = NaiveDateTime.diff(NaiveDateTime.utc_now(), dt)
             age > @stale_lock_age
          _ -> false
        end
      _ -> false
    end
  end

  defp with_transaction(operation_name, fun) do
    case acquire_lock() do
      :ok ->
        try do
          fun.()
        rescue
          e ->
            Logger.error("🔥 Exception during #{operation_name}: #{inspect(e)}")
            {:error, e}
        after
          release_lock()
        end
      {:error, reason} ->
        Logger.error("❌ Failed to acquire lock for #{operation_name}: #{inspect(reason)}")
        IO.puts("❌ Could not acquire lock. System busy.")
        {:error, :locked}
    end
  end

  def force_unlock do
    IO.puts("🔓 Forcing lock release...")
    case release_lock() do
      :ok -> IO.puts("✅ Lock released.")
      {:error, reason} -> IO.puts("❌ Failed to release lock: #{inspect(reason)}")
    end
  end

  # ==================== ROBUST PERSISTENCE PROTOCOLS ====================

  @doc """
  Protocol 1: Atomic Persistence with Verification
  Writes to a temp file, verifies integrity, then renames.
  """
  @spec atomic_write(String.t(), String.t()) :: :ok | {:error, term()}
  def atomic_write(path, content) do
    temp_path = path <> ".tmp.#{:os.system_time(:millisecond)}"
    
    try do
      # Barrier 1: Write to temp
      with :ok <- File.write(temp_path, content),
           :ok <- verify_file_integrity(temp_path),
           :ok <- File.rename(temp_path, path) do
        :ok
      else
        {:error, reason} -> 
          Logger.error("❌ Atomic write failed: #{inspect(reason)}")
          attempt_recovery_save(content)
          {:error, reason}
      end
    rescue
      e -> 
        Logger.error("🔥 Exception during atomic write: #{inspect(e)}")
        attempt_recovery_save(content)
        {:error, e}
    after
      # Cleanup temp file if it still exists
      if File.exists?(temp_path), do: File.rm(temp_path)
    end
  end

  defp verify_file_integrity(path) do
    # Simple integrity check: can we read it back and does it have content?
    case File.read(path) do
      {:ok, content} when byte_size(content) > 0 -> :ok
      {:ok, _} -> {:error, :empty_file}
      error -> error
    end
  end

  # Private helper to attempt saving recovery file
  defp attempt_recovery_save(content) do
    IO.puts("🚨 INITIATING RECOVERY SAVE PROTOCOL")
    timestamp = DateTime.utc_now() |> DateTime.to_unix()
    filename = "PROJECT_TODOLIST_RECOVERY_#{timestamp}.md"

    # Barrier 2: Local Backup
    local_path = Path.join(@backup_dir, filename)
    IO.puts("🛡️ Attempting Barrier 2: Local Backup (#{local_path})")
    
    # Ensure dir exists
    File.mkdir_p!(@backup_dir)

    case File.write(local_path, content) do
      :ok -> 
        IO.puts("✅ Barrier 2 Successful: Saved to #{local_path}")
        :ok
      {:error, reason} ->
        IO.puts("❌ Barrier 2 Failed: #{inspect(reason)}")
        
        # Barrier 3: System Temp
        system_temp = System.tmp_dir() || "/tmp"
        temp_path = Path.join(system_temp, filename)
        IO.puts("🛡️ Attempting Barrier 3: System Temp (#{temp_path})")
        
        case File.write(temp_path, content) do
          :ok -> 
            IO.puts("✅ Barrier 3 Successful: Saved to #{temp_path}")
            :ok
          {:error, reason2} ->
            IO.puts("🔥 CRITICAL FAILURE: ALL PERSISTENCE BARRIERS FAILED: #{inspect(reason2)}")
            IO.puts("⚠️  DUMPING CONTENT TO STDOUT AS LAST RESORT:")
            IO.puts("============================================")
            IO.puts(content)
            IO.puts("============================================")
            {:error, :all_barriers_failed}
        end
    end
  end
