#!/bin/bash

# 🏭 TPS AGENT: WEB BROWSER LAUNCHER
# Automatic web browser page creation for web-based subsystems

echo "🌐 TPS AGENT: WEB BROWSER LAUNCHER"
echo "=================================="
echo "🎯 MISSION: Launch web browsers for all demo subsystems"
echo "🚀 STRATEGY: Automatic browser page creation"

# Function to open URL in available browser
open_url() {
    local url="$1"
    local description="$2"
    
    echo "🔗 Opening $description: $url"
    
    # Try different browsers in order of preference
    if command -v google-chrome >/dev/null 2>&1; then
        google-chrome "$url" >/dev/null 2>&1 &
    elif command -v chromium-browser >/dev/null 2>&1; then
        chromium-browser "$url" >/dev/null 2>&1 &
    elif command -v firefox >/dev/null 2>&1; then
        firefox "$url" >/dev/null 2>&1 &
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url" >/dev/null 2>&1 &
    else
        echo "⚠️ No browser available, URL: $url"
        return 1
    fi
    
    echo "✅ Browser launched for $description"
    sleep 2  # Brief delay between launches
}

# Check if we're in a desktop environment
if [ -z "$DISPLAY" ] && [ -z "$WAYLAND_DISPLAY" ]; then
    echo "⚠️ No display available - running in headless mode"
    echo "📋 Available web interfaces:"
    echo "• Grafana Dashboard: http://localhost:3000"
    echo "• Local Registry: http://localhost:5000"
    echo "• PHICS Registry: http://localhost:5001"
    echo ""
    echo "🔧 To access these interfaces, use:"
    echo "curl http://localhost:3000  # Grafana"
    echo "curl http://localhost:5000/v2/_catalog  # Local Registry"
    echo "curl http://localhost:5001/v2/_catalog  # PHICS Registry"
    exit 0
fi

echo ""
echo "🚀 Launching web browser pages for demo subsystems..."
echo ""

# Launch browsers for all demo interfaces
open_url "http://localhost:3000" "Grafana Monitoring Dashboard"
open_url "http://localhost:5000/v2/_catalog" "Local Container Registry"
open_url "http://localhost:5001/v2/_catalog" "PHICS Development Registry"

echo ""
echo "✅ All web browser pages launched successfully!"
echo ""
echo "📊 Available Demo Interfaces:"
echo "• Grafana Dashboard: http://localhost:3000 (admin/admin123)"
echo "• Local Registry: http://localhost:5000"
echo "• PHICS Registry: http://localhost:5001"
echo ""
echo "🎯 TPS MISSION COMPLETE: Web browser automation successful"
echo "🏆 ACHIEVEMENT: All demo subsystems accessible via browser"