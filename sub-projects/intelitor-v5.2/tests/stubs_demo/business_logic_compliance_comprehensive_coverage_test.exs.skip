            "Invalid compliance configuration or missing regulatory validation",
          level_3_system_cause: "Insufficient input validation in compliance process",
          level_4_process_cause: "Missing comprehensive regulatory validation framework",
          level_5_cultural_cause: "Need for systematic quality culture in compliance management"
