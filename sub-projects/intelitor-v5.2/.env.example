# Intelitor Security Monitoring System - Environment Configuration Template
# SOPv5.1 Framework: Production-Ready Environment Variables
# 
# Copy this file to .env.local and customize values for your environment
# NEVER commit actual .env files with real secrets to version control
#
# Framework: SOPv5.1 + TPS + STAMP + TDG + GDE + Patient Mode + Container-Only
# Last Updated: 2025-08-02
# Version: 1.0.0 GA

#═══════════════════════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
#═══════════════════════════════════════════════════════════════════════════════

# Application Environment (dev, test, prod)
MIX_ENV=dev

# Phoenix Secret Key Base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=your_64_character_secret_key_base_here_generate_with_mix_phx_gen_secret

# Phoenix LiveView Signing Salt (generate with: mix phx.gen.secret 32)
LIVE_VIEW_SIGNING_SALT=your_32_character_signing_salt_here

# Application Hostname and Port
PHX_HOST=localhost
PHX_PORT=4000

# Application URL Base
URL_HOST=localhost
URL_PORT=4000
URL_SCHEME=http

#═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
#═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL Database Configuration
DATABASE_URL=postgres://intelitor:secure_password@localhost:5433/intelitor_dev
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=intelitor_dev
DATABASE_USER=intelitor
DATABASE_PASSWORD=secure_password_here

# Database Pool Configuration
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=15000
DATABASE_OWNERSHIP_TIMEOUT=60000

# Test Database Configuration  
TEST_DATABASE_URL=postgres://intelitor:secure_password@localhost:5433/intelitor_test
TEST_DATABASE_NAME=intelitor_test

#═══════════════════════════════════════════════════════════════════════════════
# MICROSOFT ENTRA ID AUTHENTICATION
#═══════════════════════════════════════════════════════════════════════════════

# Entra ID Application Configuration
ENTRA_CLIENT_ID=your_entra_application_client_id
ENTRA_CLIENT_SECRET=your_entra_application_client_secret
ENTRA_TENANT_ID=your_entra_tenant_id
ENTRA_REDIRECT_URI=http://localhost:4000/auth/entra/callback

# B2C Configuration (for customer authentication)
ENTRA_B2C_TENANT=your_b2c_tenant_name
ENTRA_B2C_CLIENT_ID=your_b2c_client_id
ENTRA_B2C_CLIENT_SECRET=your_b2c_client_secret
ENTRA_B2C_POLICY=B2C_1_signin_signup

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=86400

#═══════════════════════════════════════════════════════════════════════════════
# ENCRYPTION AND SECURITY
#═══════════════════════════════════════════════════════════════════════════════

# Cloak Encryption (for PII field-level encryption)
CLOAK_KEY=your_32_byte_base64_encoded_encryption_key_here

# Guardian Secret Key (for JWT tokens)
GUARDIAN_SECRET_KEY=your_guardian_secret_key_here_minimum_64_characters

# Session Encryption
SESSION_ENCRYPTION_SALT=your_session_encryption_salt_here
SESSION_SIGNING_SALT=your_session_signing_salt_here

# API Keys
API_SECRET_KEY=your_api_secret_key_here
WEBHOOK_VERIFICATION_SECRET=your_webhook_verification_secret

#═══════════════════════════════════════════════════════════════════════════════
# EXTERNAL SERVICES
#═══════════════════════════════════════════════════════════════════════════════

# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_TLS=true
FROM_EMAIL=noreply@yourdomain.com

# MinIO/S3 Storage Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_password
MINIO_BUCKET=intelitor-storage
MINIO_REGION=us-east-1

# Redis Configuration (for caching/sessions)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0

#═══════════════════════════════════════════════════════════════════════════════
# MONITORING AND OBSERVABILITY
#═══════════════════════════════════════════════════════════════════════════════

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=intelitor
OTEL_SERVICE_VERSION=1.0.0
OTEL_RESOURCE_ATTRIBUTES=service.name=intelitor,service.version=1.0.0

# Prometheus Metrics
PROMETHEUS_PORT=9568
PROMETHEUS_METRICS_ENABLED=true

# Application Insights (if using Azure)
APPINSIGHTS_INSTRUMENTATIONKEY=your_app_insights_key
APPINSIGHTS_CONNECTION_STRING=your_app_insights_connection_string

# Logging Configuration
LOG_LEVEL=info
LOGGER_JSON_ENABLED=true
LOGGER_CONSOLE_ENABLED=true

#═══════════════════════════════════════════════════════════════════════════════
# CONTAINER AND DEVELOPMENT CONFIGURATION
#═══════════════════════════════════════════════════════════════════════════════

# SOPv5.1 Framework Configuration
SOPV51_ENABLED=true
CYBERNETIC_EXECUTION=true
PATIENT_MODE=true
NO_TIMEOUT=true
CONTAINER_ONLY=true
PHICS_ENABLED=true
AGENT_COORDINATION=true
STAMP_VALIDATION=true
TPS_INTEGRATION=true
TDG_COMPLIANCE=true
GDE_FRAMEWORK=true

# Container Configuration
PODMAN_ENABLED=true
DOCKER_FORBIDDEN=true
NIXOS_CONTAINERS_ONLY=true
CONTAINER_REGISTRY=localhost
CONTAINER_IMAGE_TAG=nixos-devenv

# Development Environment
DEVENV_ENABLED=true
NIX_ENABLED=true
PHICS_HOT_RELOAD=true
LIVE_RELOAD_ENABLED=true

# Testing Configuration
TEST_COVERAGE_THRESHOLD=95
WALLABY_ENABLED=false
PROPERTY_TESTING_ENABLED=true
TDG_VALIDATION_ENABLED=true

#═══════════════════════════════════════════════════════════════════════════════
# SECURITY MONITORING SPECIFIC
#═══════════════════════════════════════════════════════════════════════════════

# Alarm Processing Configuration
SIA_DC09_PORT=3061
ALARM_PROCESSING_ENABLED=true
ALARM_AUTO_RESOLVE_TIMEOUT=300
ALARM_CORRELATION_ENABLED=true

# Video Analytics
VIDEO_ANALYTICS_ENABLED=true
VIDEO_STORAGE_PATH=/var/lib/intelitor/video
VIDEO_RETENTION_DAYS=30

# Device Integration
DEVICE_DISCOVERY_ENABLED=true
DEVICE_HEARTBEAT_INTERVAL=30
DEVICE_TIMEOUT=120

# Mobile API Configuration
MOBILE_API_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=true
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key_json_here

# Access Control Integration
ACCESS_CONTROL_ENABLED=true
CARD_READER_INTEGRATION=true
BIOMETRIC_INTEGRATION=false

#═══════════════════════════════════════════════════════════════════════════════
# PERFORMANCE AND SCALING
#═══════════════════════════════════════════════════════════════════════════════

# Elixir VM Configuration
ELIXIR_ERL_OPTIONS="+S 16"
ERL_MAX_PROCESSES=4000000
ERL_MAX_ATOMS=2000000
ERL_ASYNC_THREADS=256

# Phoenix Configuration
PHOENIX_MAX_CONNECTIONS=16384
PHOENIX_POOL_SIZE=10
PHOENIX_TIMEOUT=60000

# Oban Background Jobs
OBAN_QUEUES_DEFAULT=10
OBAN_QUEUES_ALARMS=5
OBAN_QUEUES_ANALYTICS=3
OBAN_QUEUES_REPORTS=2

# Cache Configuration
CACHE_TTL=3600
CACHE_SIZE_LIMIT=100000
CACHE_ENABLED=true

#═══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT AND DEBUGGING
#═══════════════════════════════════════════════════════════════════════════════

# Development Tools
LIVE_RELOAD_ENABLED=true
DEBUG_ENABLED=false
PROFILING_ENABLED=false
BENCHMARKING_ENABLED=false

# Code Quality Tools
CREDO_STRICT=true
DIALYZER_ENABLED=true
SOBELOW_ENABLED=true
COVERALLS_ENABLED=true

# Compilation Configuration
WARNINGS_AS_ERRORS=true
COMPILE_TIMEOUT=1200000
PATIENT_COMPILE=true
PARALLEL_COMPILE=true

#═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT SPECIFIC (PRODUCTION)
#═══════════════════════════════════════════════════════════════════════════════

# Production URL Configuration
# PROD_URL_HOST=yourdomain.com
# PROD_URL_PORT=443
# PROD_URL_SCHEME=https

# SSL/TLS Configuration
# SSL_CERT_PATH=/etc/ssl/certs/intelitor.crt
# SSL_KEY_PATH=/etc/ssl/private/intelitor.key
# SSL_ENABLED=true

# Load Balancer Configuration  
# LOAD_BALANCER_ENABLED=true
# HEALTH_CHECK_PATH=/health
# HEALTH_CHECK_PORT=4000

# Backup Configuration
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE="0 2 * * *"
# BACKUP_RETENTION_DAYS=90
# BACKUP_S3_BUCKET=intelitor-backups

#═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
#═══════════════════════════════════════════════════════════════════════════════

# Core Features
MULTI_TENANT_ENABLED=true
AUDIT_LOGGING_ENABLED=true
REAL_TIME_MONITORING=true
DASHBOARD_ENABLED=true

# Advanced Features
AI_ANALYTICS_ENABLED=false
MACHINE_LEARNING_ENABLED=false
BLOCKCHAIN_AUDIT=false
EDGE_COMPUTING_ENABLED=false

# Integration Features
THIRD_PARTY_INTEGRATIONS=true
WEBHOOK_ENABLED=true
API_RATE_LIMITING=true
GRAPHQL_ENABLED=true

#═══════════════════════════════════════════════════════════════════════════════
# COMPLIANCE AND AUDIT
#═══════════════════════════════════════════════════════════════════════════════

# Compliance Standards
DPDP_COMPLIANCE=true
ISO27001_COMPLIANCE=true
SOC2_COMPLIANCE=true
GDPR_COMPLIANCE=true

# Audit Configuration
AUDIT_LOG_RETENTION=2555  # 7 years in days
AUDIT_LOG_ENCRYPTION=true
AUDIT_LOG_BACKUP=true
COMPLIANCE_REPORTING=true

# Data Retention
DATA_RETENTION_DAYS=2555
LOG_RETENTION_DAYS=365
METRICS_RETENTION_DAYS=90
TEMP_FILE_CLEANUP_HOURS=24

#═══════════════════════════════════════════════════════════════════════════════
# NOTES AND REMINDERS
#═══════════════════════════════════════════════════════════════════════════════

# Security Reminders:
# 1. Generate all secrets using cryptographically secure methods
# 2. Use different secrets for different environments (dev/test/prod)
# 3. Rotate secrets regularly (quarterly minimum)
# 4. Store production secrets in secure key management systems
# 5. Never commit real secrets to version control
# 6. Use environment-specific .env files (.env.local, .env.prod, etc.)
# 7. Validate all environment variables on application startup
# 8. Use encrypted storage for database passwords and API keys
# 9. Enable audit logging for all secret access
# 10. Follow principle of least privilege for all service accounts

# SOPv5.1 Framework Reminders:
# 1. All development must occur in NixOS containers
# 2. TDG methodology is mandatory for all code changes
# 3. STAMP safety constraints must be validated
# 4. Patient mode execution with NO_TIMEOUT policy
# 5. 11-agent architecture for complex operations
# 6. Container compliance validation required
# 7. Zero tolerance for warnings or test failures
# 8. Comprehensive quality gates must pass

# Container Security Reminders:
# 1. Use rootless containers only
# 2. Minimize container attack surface
# 3. Regular security scans of container images
# 4. Network isolation between containers
# 5. Resource limits for all containers
# 6. Regular updates of base images
# 7. Container registry security policies
# 8. Backup and disaster recovery for containers

#═══════════════════════════════════════════════════════════════════════════════
# END OF CONFIGURATION
#═══════════════════════════════════════════════════════════════════════════════