# Standalone Environment Template for CEPAF and Cockpit Testing
# Usage: Copy to .env.standalone and customize as needed
# cp .env.standalone.template .env.standalone
#
# WHAT: Environment variables for standalone testing mode
# WHY: Enable isolated CEPAF and Prajna Cockpit testing
# CONSTRAINTS: Requires PostgreSQL container on port 5433

# =============================================================
# DATABASE CONFIGURATION
# =============================================================
DB_HOST=localhost
DB_PORT=5433
DB_NAME=indrajaal_standalone
DB_USER=postgres
DB_PASS=postgres
DATABASE_URL=ecto://postgres:postgres@localhost:5433/indrajaal_standalone

# =============================================================
# PHOENIX/WEB CONFIGURATION
# =============================================================
PHX_PORT=4001
PHX_HOST=localhost
SECRET_KEY_BASE=standalone_test_secret_key_base_change_in_production

# =============================================================
# CEPAF CONFIGURATION
# =============================================================
CEPAF_SYSTEM_TEST_COMPOSE=lib/cepaf/artifacts/podman-compose-db-standalone.yml
CEPAF_STANDALONE_OBS_TEST_COMPOSE=lib/cepaf/artifacts/podman-compose-obs-standalone.yml
CEPAF_TEST_MODE=standalone
DOTNET_ROOT=/nix/store/b9fq54b1yqc3fk189imvmcckm46q4pl8-dotnet-sdk-9.0.308/share/dotnet

# =============================================================
# PRAJNA COCKPIT CONFIGURATION
# =============================================================
PRAJNA_COCKPIT_ENABLED=true
PRAJNA_DARK_MODE=true
PRAJNA_AI_COPILOT_ENABLED=true
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# =============================================================
# OBSERVABILITY CONFIGURATION
# =============================================================
FRACTAL_LOGGING_ENABLED=true
ZENOH_ENABLED=false
OTEL_ENABLED=false
LOG_LEVEL=info

# =============================================================
# CORTEX CONFIGURATION (Disabled for Standalone)
# =============================================================
CORTEX_ENABLED=false
FAST_OODA_ENABLED=false
SYNAPSE_ENABLED=false

# =============================================================
# CONTAINER REGISTRY
# =============================================================
CONTAINER_REGISTRY=localhost/
PODMAN_COMPOSE_FILE=lib/cepaf/artifacts/podman-compose-db-standalone.yml
