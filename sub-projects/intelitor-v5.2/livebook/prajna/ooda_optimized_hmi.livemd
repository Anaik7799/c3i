## 8. Two-Step Command Panel (Arm → Confirm)

Safety-critical command execution with arming and confirmation states.

```elixir
# Command selection
command_type = Kino.Input.select("Command Type", [
  {"Health Check", :health_check},
  {"Restart Node", :restart},
  {"Isolate Node", :isolate},
  {"Emergency Stop", :emergency_stop}
])

target_node = Kino.Input.text("Target Node ID", default: "app-01")
```

```elixir
# Command state management
defmodule CommandState do
  use Agent

  def start_link(_) do
    Agent.start_link(fn -> %{armed: false, command: nil, target: nil, armed_at: nil} end, name: __MODULE__)
  end

  def arm(command, target) do
    Agent.update(__MODULE__, fn _ ->
      %{armed: true, command: command, target: target, armed_at: DateTime.utc_now()}
    end)
  end

  def disarm() do
    Agent.update(__MODULE__, fn _ ->
      %{armed: false, command: nil, target: nil, armed_at: nil}
    end)
  end

  def get() do
    Agent.get(__MODULE__, & &1)
  end

  def armed?() do
    Agent.get(__MODULE__, & &1.armed)
  end
end

# Start the agent if not already running
case CommandState.start_link([]) do
  {:ok, _pid} -> :ok
  {:error, {:already_started, _pid}} -> :ok
end

:ok
```

```elixir
# Arm button
arm_button = Kino.Control.button("ARM COMMAND")
confirm_button = Kino.Control.button("CONFIRM EXECUTE")
cancel_button = Kino.Control.button("CANCEL")

command_frame = Kino.Frame.new()

# Handle arm
Kino.listen(arm_button, fn _event ->
  cmd = Kino.Input.read(command_type)
  target = Kino.Input.read(target_node)
  CommandState.arm(cmd, target)

  content = Kino.Markdown.new("""
  ## ⚠️ COMMAND ARMED

  | Property | Value |
  |----------|-------|
  | **Command** | #{cmd} |
  | **Target** | #{target} |
  | **Armed At** | #{DateTime.utc_now()} |
  | **Expires In** | 30 seconds |

  **Press CONFIRM to execute or CANCEL to abort**
  """)

  Kino.Frame.render(command_frame, content)
end)

# Handle confirm
Kino.listen(confirm_button, fn _event ->
  state = CommandState.get()
  if state.armed do
    CommandState.disarm()

    content = Kino.Markdown.new("""
    ## ✓ COMMAND EXECUTED

    - **Command**: #{state.command}
    - **Target**: #{state.target}
    - **Executed At**: #{DateTime.utc_now()}
    - **Status**: Success

    *Command has been sent to orchestrator*
    """)

    Kino.Frame.render(command_frame, content)
  end
end)

# Handle cancel
Kino.listen(cancel_button, fn _event ->
  CommandState.disarm()

  content = Kino.Markdown.new("""
  ## Command Cancelled

  No command is armed. Select a command and click ARM to begin.
  """)

  Kino.Frame.render(command_frame, content)
end)

Kino.Layout.grid([
  Kino.Layout.grid([arm_button, confirm_button, cancel_button], columns: 3),
  command_frame
])
```

## 9. Aggregate Health Dashboard

Combined view showing all L7 visualizations in a unified grid.

```elixir
# Create frames for aggregate view
agg_spider = Kino.Frame.new()
agg_safety = Kino.Frame.new()
agg_ooda = Kino.Frame.new()
agg_summary = Kino.Frame.new()

# Update aggregate views
Kino.listen(2000, fn _ ->
  health = SmartMetrics.health_summary()

  # Summary card
  summary = Kino.Markdown.new("""
  ## System Health: #{health.status |> to_string() |> String.upcase()}

  | Metric | Value |
  |--------|-------|
  | Health Score | **#{health.health_score}%** |
  | Total Metrics | #{health.total_metrics} |
  | Alarmed | #{health.alarmed_count} |
  | Stale | #{health.stale_count} |

  *Updated: #{DateTime.utc_now() |> DateTime.to_string()}*
  """)

  Kino.Frame.render(agg_summary, summary)
end)

# Layout in grid
Kino.Layout.grid([
  agg_summary,
  spider_frame,
  safety_frame,
  ooda_frame
], columns: 2)
```

---

## Usage Notes

1. **Connect to Node**: Ensure `indrajaal@127.0.0.1` is running before executing
2. **Real-Time Updates**: All charts update automatically at their configured intervals
3. **Progressive Disclosure**: Use the dropdown to adjust detail level
4. **Two-Step Commands**: Always ARM before CONFIRM for safety-critical operations
5. **Dark Cockpit Philosophy**: Gray indicates normal; color indicates attention needed

## STAMP Compliance

- **SC-HMI-001**: Dark cockpit implemented (gray default, color for deviations)
- **SC-HMI-002**: Analog over digital (bars, sparklines, trend vectors)
- **SC-HMI-003**: Staleness decay visualization
- **SC-HMI-004**: Two-step commit for critical commands
- **SC-AI-001**: AI insights are ADVISORY only
