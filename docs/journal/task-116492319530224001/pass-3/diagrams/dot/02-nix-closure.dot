digraph NixClosure {
  rankdir=LR; bgcolor="#0a0e17";
  node [fontname="Inter" style="filled,rounded" shape=box color="#1e2a3a" fontcolor="#e0e6ed"];
  edge [color="#7a8fa6" fontcolor="#7a8fa6" fontsize=9];

  subgraph cluster_nix { label="Nix store (cached on first build)"; color="#9b59b6"; fontcolor="#c89cf2";
    n_icu [label="icu74\n(icu4c-74.2)\nlibicudata.so.74"];
    n_xml [label="libxml2_13\n(2.13.8)\nlibxml2.so.2"];
    n_jxl [label="libjxl @ nixos-23.11\n(0.8.2)\nlibjxl.so.0.8"];
    n_evt [label="libevent\n(2.1.12)"];
    n_avif [label="libavif\n(1.3.0)"];
    n_man [label="libmanette\n(0.2.13)"];
    n_gst [label="gst-plugins-bad\n(1.26.5)"];
  }

  setup [label="setup-webkit-libs.sh\n(idempotent symlink farm)" fillcolor="#141922" color="#00d4aa" fontcolor="#00d4aa"];

  subgraph cluster_wk { label="~/.cache/ms-playwright/webkit-2191/"; color="#4d96ff"; fontcolor="#7ab3ff";
    wpe [label="minibrowser-wpe/\n  MiniBrowser (wrapper)\n  bin/MiniBrowser\n  lib/  ← symlinks land here" fillcolor="#1e2a3a"];
    gtk [label="minibrowser-gtk/\n  MiniBrowser (wrapper)\n  bin/MiniBrowser\n  lib/  ← symlinks land here" fillcolor="#1e2a3a"];
  }

  pw [label="Playwright @1.54.1\n(matched browser revs)" fillcolor="#141922" color="#3dd68c" fontcolor="#3dd68c"];
  test [label="planning.spec.ts\n6 tests × 5 projects = 30 cells\n30/30 PASS" fillcolor="#141922" color="#3dd68c" fontcolor="#3dd68c"];

  {n_icu, n_xml, n_jxl, n_evt, n_avif, n_man, n_gst} -> setup;
  setup -> wpe; setup -> gtk;
  pw -> wpe; pw -> gtk;
  wpe -> test; gtk -> test;
}
