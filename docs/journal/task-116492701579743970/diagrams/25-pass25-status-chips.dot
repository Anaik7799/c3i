digraph StatusChips {
  rankdir=LR; bgcolor="#0a0e17";
  node [fontcolor="#e0e6ed", fontname="Helvetica", style="filled,rounded"];
  edge [color="#7a8fa6", fontcolor="#7a8fa6", fontname="Helvetica", fontsize=10];

  subgraph cluster_in { label="Input"; style=dashed; color="#3a4555"; fontcolor="#7a8fa6";
    nif [label="c3i_nif::plan_status\n→ StatusCounts\n(pending,in_progress,blocked,completed)", fillcolor="#141922"];
    sel [label="ActiveFilter\n(URL ?status=...)", fillcolor="#141922"];
  }
  subgraph cluster_pure { label="Phase 2a — Pure Component (Pass-25)"; style=dashed; color="#00d4aa"; fontcolor="#00d4aa";
    build [label="build_chips\n→ List(Chip)\n5 chips: All + 4 statuses", fillcolor="#3dd68c", fontcolor="#0a0e17"];
    inv [label="invariant_holds\nAll.count ≡ Σ(status counts)", fillcolor="#3dd68c", fontcolor="#0a0e17"];
    parse [label="parse_active /\nfilter_to_key\n(round-trip)", fillcolor="#3dd68c", fontcolor="#0a0e17"];
  }
  subgraph cluster_render { label="Triple Render"; style=dashed; color="#00d4aa"; fontcolor="#00d4aa";
    html [label="render_html\nchip-row + chip-active +\nchip-p0/p1/p2/neutral classes", fillcolor="#3dd68c", fontcolor="#0a0e17"];
    ansi [label="render_ansi\n[Active] | Other 4 | …", fillcolor="#3dd68c", fontcolor="#0a0e17"];
    url [label="chip_url / chip_page_url\ncomposes with Pass-23\n/api/v1/planning/page", fillcolor="#3dd68c", fontcolor="#0a0e17"];
  }
  subgraph cluster_phase2b { label="Phase 2b (next pass)"; style=dashed; color="#f5a623"; fontcolor="#f5a623";
    wire [label="planning-grid.js\n+ domain_views.gleam\nedit: 3 grids → 1\n(M risk, multiverse branch)", fillcolor="#141922"];
  }
  subgraph cluster_tests { label="26 gleeunit tests (all pass)"; style=dashed; color="#00d4aa"; fontcolor="#00d4aa";
    t [label="4 counts\n4 build chips\n2 variants\n3 parse round-trip\n4 HTML render\n2 ANSI render\n3 URL builders\n2 empty state\n2 invariant", fillcolor="#3dd68c", fontcolor="#0a0e17"];
  }

  nif -> build; sel -> build;
  build -> inv; build -> html; build -> ansi; build -> url;
  parse -> sel [label="from URL"];
  url -> wire [style=dashed, label="next pass\nwires"];
  html -> wire [style=dashed];
  t -> build [style=dotted, color="#00d4aa"];
  t -> inv [style=dotted, color="#00d4aa"];
}
