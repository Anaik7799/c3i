// g19-cx-operator-journey.dot — Pass-12 operator CX
digraph G19CXOperatorJourney {
  rankdir=LR;
  labelloc="t";
  label="G19 — Operator CX Journey (8 steps, tool names on transitions)";
  fontname="Helvetica";
  fontsize=15;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#e3f2fd", color="#1565c0"];
  edge [fontname="Helvetica", fontsize=9, color="#37474f"];

  o1 [label="1. ssh vm-1\n(Tailscale)", fillcolor="#fff9c4", color="#f9a825"];
  o2 [label="2. /sa-plan list\npending tasks", fillcolor="#bbdefb"];
  o3 [label="3. claim task\n(in_progress)", fillcolor="#fff59d", color="#f57f17"];
  o4 [label="4. /marionette-explore\nfluffychat onboarding-login", fillcolor="#80deea", color="#006064", penwidth=2];
  o5 [label="5. review evidence\n(screenshots, logs,\ninteractive tree)", fillcolor="#a5d6a7", color="#1b5e20"];
  o6 [label="6. close task\nupdate completed", fillcolor="#a5d6a7", color="#1b5e20"];
  o7 [label="7. email closure\n+ journal attached", fillcolor="#ce93d8", color="#4a148c"];
  o8 [label="8. ZK ingest\n(both brains)", fillcolor="#d1c4e9", color="#4527a0"];

  o1 -> o2 [label="ssh + zsh"];
  o2 -> o3 [label="./sa-plan update\n<id> in_progress"];
  o3 -> o4 [label="/marionette-explore"];
  o4 -> o5 [label="docs/cache/\nmarionette/<run>/"];
  o5 -> o6 [label="./sa-plan update\n<id> completed"];
  o6 -> o7 [label="sa-plan-daemon\nsend-email -a journal.md"];
  o7 -> o8 [label="sa-plan-daemon\ningest-docs"];
  o8 -> o2 [label="next task", style=dashed, color="#9e9e9e"];

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_y  [label="entry",       fillcolor="#fff9c4"];
    lg_b  [label="planning",    fillcolor="#bbdefb"];
    lg_t  [label="testing (Marionette)", fillcolor="#80deea"];
    lg_g  [label="evidence/closure",     fillcolor="#a5d6a7"];
    lg_v  [label="notify/ingest",        fillcolor="#d1c4e9"];
    lg_y -> lg_b -> lg_t -> lg_g -> lg_v [style=invis];
  }
}
