// g16-sequence-uc1-cron-job.dot — UC-1 sequence (cron → enqueue → execute → complete)
digraph G16SequenceUC1 {
  rankdir=LR;
  labelloc="t";
  label="G16 — UC-1 Sequence: cron tick → enqueue → execute → complete (8 lifelines)";
  fontname="Helvetica";
  fontsize=15;
  bgcolor="#fafafa";
  node [fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9];

  // Lifeline columns (rank=same)
  ll_op    [label="Operator",          shape=box, style="rounded,filled", fillcolor="#fff9c4", color="#f9a825"];
  ll_sch   [label="scheduler-run",     shape=box, style="rounded,filled", fillcolor="#fff59d", color="#f57f17"];
  ll_db    [label="db (SQLite)",       shape=box, style="rounded,filled", fillcolor="#a5d6a7", color="#1b5e20"];
  ll_oban  [label="oban_jobs",         shape=box, style="rounded,filled", fillcolor="#a5d6a7", color="#1b5e20"];
  ll_disp  [label="workers::dispatch", shape=box, style="rounded,filled", fillcolor="#66bb6a", color="#1b5e20", fontcolor="white"];
  ll_pr    [label="process_runner",    shape=box, style="rounded,filled", fillcolor="#ce93d8", color="#4a148c"];
  ll_zen   [label="Zenoh",             shape=box, style="rounded,filled", fillcolor="#bbdefb", color="#0d47a1"];
  ll_dash  [label="Dashboard",         shape=box, style="rounded,filled", fillcolor="#fff9c4", color="#f9a825"];
  { rank=same; ll_op; ll_sch; ll_db; ll_oban; ll_disp; ll_pr; ll_zen; ll_dash; }

  // Numbered messages encoded as labeled invisible-stack steps
  s1 [label="1: cron fires\n(due schedule)", shape=note, fillcolor="#fff9c4", style=filled];
  s2 [label="2: SELECT\nworkflow_schedules\nWHERE next_run<=now", shape=note, fillcolor="#e3f2fd", style=filled];
  s3 [label="3: INSERT\noban_jobs\n(state=available)", shape=note, fillcolor="#e8f5e9", style=filled];
  s4 [label="4: claim\n(SELECT FOR UPDATE\nSKIP LOCKED)", shape=note, fillcolor="#e8f5e9", style=filled];
  s5 [label="5: dispatch(job)\nmatch worker arm", shape=note, fillcolor="#c8e6c9", style=filled];
  s6 [label="6: process_runner\nspawn gleam build", shape=note, fillcolor="#f3e5f5", style=filled];
  s7 [label="7: PUT\nl4/sched/proc/{pid}/start", shape=note, fillcolor="#e1f5fe", style=filled];
  s8 [label="8: exit ok\n+ stdout log", shape=note, fillcolor="#f3e5f5", style=filled];
  s9 [label="9: UPDATE\noban_jobs.completed_at", shape=note, fillcolor="#e8f5e9", style=filled];
  s10 [label="10: PUT\nl4/sched/job/{id}/done", shape=note, fillcolor="#e1f5fe", style=filled];
  s11 [label="11: dashboard\nlive update\n(WS push)", shape=note, fillcolor="#fffde7", style=filled];

  // Vertical sequence stack (left side)
  s1 -> s2 -> s3 -> s4 -> s5 -> s6 -> s7 -> s8 -> s9 -> s10 -> s11 [style=invis];

  // Cross-lifeline arrows showing sender→receiver for each step
  ll_op   -> ll_sch  [label="1: cron tick"];
  ll_sch  -> ll_db   [label="2: SELECT due"];
  ll_sch  -> ll_oban [label="3: INSERT job"];
  ll_sch  -> ll_oban [label="4: claim", color="#1b5e20"];
  ll_oban -> ll_disp [label="5: dispatch(job)"];
  ll_disp -> ll_pr   [label="6: run(spec)"];
  ll_pr   -> ll_zen  [label="7: proc/start"];
  ll_pr   -> ll_disp [label="8: outcome=Ok"];
  ll_disp -> ll_oban [label="9: mark_completed"];
  ll_disp -> ll_zen  [label="10: job/done"];
  ll_zen  -> ll_dash [label="11: WS push"];

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_h [label="happy path UC-1\n(scheduler claims a known\nworker, runner ok, telemetry\nflows to dashboard)",
          shape=note, fillcolor="#fff9c4", color="#f57f17"];
  }
}
