// g20-cx-developer-journey.dot — Pass-12 developer CX
digraph G20CXDeveloperJourney {
  rankdir=LR;
  labelloc="t";
  label="G20 — Developer CX Journey (Marionette discover → Patrol regress → commit)";
  fontname="Helvetica";
  fontsize=15;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#e3f2fd", color="#1565c0"];
  edge [fontname="Helvetica", fontsize=9, color="#37474f"];

  d1 [label="1. edit Flutter\nwidget (.dart)",   fillcolor="#fff9c4", color="#f9a825"];
  d2 [label="2. flutter run\n--debug",            fillcolor="#bbdefb"];
  d3 [label="3. Marionette\nget_interactive_\nelements()",
      fillcolor="#80deea", color="#006064", penwidth=2];
  d4 [label="4. discover\nValueKey('login_btn')", fillcolor="#a5d6a7", color="#1b5e20"];
  d5 [label="5. translate to\nPatrol case\n(integration_test/*)", fillcolor="#80deea", color="#006064"];
  d6 [label="6. cargo build\n(planning_daemon)",  fillcolor="#ffe0b2", color="#e65100"];
  d7 [label="7. cargo test --test\ndispatcher_registry_test", fillcolor="#66bb6a", color="#1b5e20", fontcolor="white", penwidth=2];
  d8 [label="8. commit\nICP v2.0",                fillcolor="#ce93d8", color="#4a148c"];
  d9 [label="9. push\nmultiverse/<branch>",        fillcolor="#d1c4e9", color="#4527a0"];

  d1 -> d2 [label="save\n+ hot-reload"];
  d2 -> d3 [label="VM Service\nattach"];
  d3 -> d4 [label="tree.json\ndocs/cache/"];
  d4 -> d5 [label="copy key\nas selector"];
  d5 -> d6 [label="cargo build\n--release"];
  d6 -> d7 [label="green build"];
  d7 -> d8 [label="0 failures\ngit add"];
  d8 -> d9 [label="git push -u"];

  // Side branch — failure path
  d7 -> d3 [label="test fails →\nrediscover", style=dashed, color="#b71c1c", fontcolor="#b71c1c"];

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_y [label="edit", fillcolor="#fff9c4"];
    lg_t [label="Marionette/Patrol", fillcolor="#80deea"];
    lg_o [label="cargo build", fillcolor="#ffe0b2"];
    lg_g [label="cargo test pass", fillcolor="#66bb6a", fontcolor="white"];
    lg_v [label="commit/push",  fillcolor="#d1c4e9"];
    lg_y -> lg_t -> lg_o -> lg_g -> lg_v [style=invis];
  }
}
