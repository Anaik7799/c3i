// g17-sequence-uc5-unknown-worker.dot — UC-5 (PRE/POST Pass-10 dispatch fix)
digraph G17SequenceUC5 {
  rankdir=LR;
  labelloc="t";
  label="G17 — UC-5 Unknown-Worker Path: PRE-PASS-10 (BROKEN, red) vs POST-PASS-10 (FIXED, green)";
  fontname="Helvetica";
  fontsize=15;
  bgcolor="#fafafa";
  node [fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9];

  // PRE track
  subgraph cluster_pre {
    label="PRE-PASS-10 — BROKEN (silent fall-through, retryable=true loop)";
    style="rounded,filled"; fillcolor="#ffebee"; color="#b71c1c"; fontsize=12; fontcolor="#b71c1c";
    pre_op  [label="Operator",        shape=box, style="rounded,filled", fillcolor="#fff9c4"];
    pre_sch [label="scheduler",       shape=box, style="rounded,filled", fillcolor="#fff59d"];
    pre_oban[label="oban_jobs",       shape=box, style="rounded,filled", fillcolor="#a5d6a7"];
    pre_disp[label="workers::dispatch\n(no registry)", shape=box, style="rounded,filled",
             fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
    pre_log [label="log line\n(only)", shape=box, style="rounded,filled", fillcolor="#ffe0b2"];

    pre_op   -> pre_sch  [label="1: enqueue\n\"vibe_check\""];
    pre_sch  -> pre_oban [label="2: INSERT job"];
    pre_oban -> pre_disp [label="3: claim+dispatch"];
    pre_disp -> pre_log  [label="4: warn:\n\"unknown worker\"", color="#b71c1c"];
    pre_disp -> pre_oban [label="5: leave job\nas executing\n(retryable=true)\n★BUG★",
                          color="#b71c1c", penwidth=2, style=bold];
    pre_oban -> pre_disp [label="6: tick again\n(infinite re-claim)",
                          color="#b71c1c", style=dashed];
  }

  // POST track
  subgraph cluster_post {
    label="POST-PASS-10 — FIXED (registry match-arm + retryable=false)";
    style="rounded,filled"; fillcolor="#e8f5e9"; color="#1b5e20"; fontsize=12; fontcolor="#1b5e20";
    post_op  [label="Operator",        shape=box, style="rounded,filled", fillcolor="#fff9c4"];
    post_sch [label="scheduler",       shape=box, style="rounded,filled", fillcolor="#fff59d"];
    post_oban[label="oban_jobs",       shape=box, style="rounded,filled", fillcolor="#a5d6a7"];
    post_disp[label="workers::dispatch\n★registry★",
              shape=box, style="rounded,filled", fillcolor="#66bb6a", color="#1b5e20",
              fontcolor="white", penwidth=3];
    post_zen [label="Zenoh\nl4/sched/job/.../failed",
              shape=box, style="rounded,filled", fillcolor="#bbdefb"];

    post_op   -> post_sch  [label="1: enqueue\n\"vibe_check\""];
    post_sch  -> post_oban [label="2: INSERT job"];
    post_oban -> post_disp [label="3: claim+dispatch"];
    post_disp -> post_disp [label="4: match-arm\n=> _ unknown\n=> Outcome::Failed\n(retryable=false)",
                            color="#1b5e20", penwidth=2];
    post_disp -> post_oban [label="5: mark_failed\n(terminal)", color="#1b5e20", penwidth=2];
    post_disp -> post_zen  [label="6: PUT failed\n+reason", color="#1b5e20"];
  }

  // Cross-link
  pre_disp -> post_disp [label="Pass-10 fix\n(SC-DISP-REGISTRY-005..007)",
                         constraint=false, style=dashed, color="#f57f17", penwidth=2,
                         fontcolor="#f57f17"];

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_red   [label="BROKEN", fillcolor="#ef9a9a", style="rounded,filled", color="#b71c1c"];
    lg_green [label="FIXED",  fillcolor="#66bb6a", style="rounded,filled", color="#1b5e20", fontcolor="white"];
    lg_red -> lg_green [style=invis];
  }
}
