  H_L2   -> P1_2 -> P2_2 -> P3_2 -> P4_2 -> P5_2 -> P6_2 -> P7_2 -> P8_2 -> P9_2 -> P12_2 -> P16_2 -> P20_2 -> CC_2;
  H_L3   -> P1_3 -> P2_3 -> P3_3 -> P4_3 -> P5_3 -> P6_3 -> P7_3 -> P8_3 -> P9_3 -> P12_3 -> P16_3 -> P20_3 -> CC_3;
