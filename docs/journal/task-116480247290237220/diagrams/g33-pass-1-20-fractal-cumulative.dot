  H_L7   -> P1_7 -> P2_7 -> P3_7 -> P4_7 -> P5_7 -> P6_7 -> P7_7 -> P8_7 -> P9_7 -> P12_7 -> P16_7 -> P20_7 -> CC_7;

  subgraph cluster_legend {
