    fontcolor="#00d4aa"; style=dashed; color="#1e2a3a";
    LK1 [label="first",      fillcolor="#2c5e4a", fontcolor="#e0e6ed"];
    LK2 [label="reinforced", fillcolor="#3dd68c", fontcolor="#0a0e17"];
    LK3 [label="saturated",  fillcolor="#00d4aa", fontcolor="#0a0e17"];
    LK4 [label="P20 ★",      fillcolor="#ffd93d", fontcolor="#0a0e17"];
    LK1 -> LK2 -> LK3 -> LK4 [style=invis];
  }
