digraph G33_Pass1To20FractalCumulative {
  rankdir=TB;
  bgcolor="#0a0e17";
  node [shape=box, style="filled", fontname="Helvetica", fontsize=10, fontcolor="#0a0e17", width=0.85, height=0.42];
  edge [style=invis];
  labelloc=t;
  fontsize=14;
  fontcolor="#00d4aa";
  label="G33 — Pass 1 → Pass 20 × L0–L7 Fractal Cumulative Coverage Heatmap · 100% per layer by Pass 20";

  // header
  subgraph cluster_header {
    label=""; style=invis;
    H_pass [label="Pass", fillcolor="#00d4aa"];
    H_L0   [label="L0\nConst.", fillcolor="#00d4aa"];
    H_L1   [label="L1\nNIF",    fillcolor="#00d4aa"];
    H_L2   [label="L2\nCompo.", fillcolor="#00d4aa"];
    H_L3   [label="L3\nTrans.", fillcolor="#00d4aa"];
    H_L4   [label="L4\nSystem", fillcolor="#00d4aa"];
    H_L5   [label="L5\nCog.",   fillcolor="#00d4aa"];
    H_L6   [label="L6\nEcosys.",fillcolor="#00d4aa"];
    H_L7   [label="L7\nFed.",   fillcolor="#00d4aa"];
    rank=same; H_pass -> H_L0 -> H_L1 -> H_L2 -> H_L3 -> H_L4 -> H_L5 -> H_L6 -> H_L7;
  }

  // Color palette for cumulative depth:
  //   #1e2a3a = not yet touched
  //   #2c5e4a = first touch
  //   #3dd68c = reinforced (≥2)
  //   #00d4aa = saturated (≥3)
  //   #ffd93d = Pass-20 deliverable (★)

  // P1
  P1_T [label="Pass 1", fillcolor="#7a8fa6"];
  P1_0 [label=" ", fillcolor="#1e2a3a"]; P1_1 [label=" ", fillcolor="#1e2a3a"]; P1_2 [label=" ", fillcolor="#1e2a3a"];
  P1_3 [label=" ", fillcolor="#1e2a3a"]; P1_4 [label="✓", fillcolor="#2c5e4a"]; P1_5 [label="✓", fillcolor="#2c5e4a"];
  P1_6 [label=" ", fillcolor="#1e2a3a"]; P1_7 [label=" ", fillcolor="#1e2a3a"];
  { rank=same; P1_T; P1_0; P1_1; P1_2; P1_3; P1_4; P1_5; P1_6; P1_7; }

  // P2
  P2_T [label="Pass 2", fillcolor="#7a8fa6"];
