  CC_0 [label="100%", fillcolor="#3dd68c", fontcolor="#0a0e17"];
  CC_1 [label="100%", fillcolor="#3dd68c", fontcolor="#0a0e17"];
  CC_2 [label="100%", fillcolor="#3dd68c", fontcolor="#0a0e17"];
  CC_3 [label="100%", fillcolor="#3dd68c", fontcolor="#0a0e17"];
  CC_4 [label="100%", fillcolor="#3dd68c", fontcolor="#0a0e17"];
