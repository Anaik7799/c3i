// g14-controlflow-scheduler-tick.dot — Pass-12 control flow
digraph G14ControlFlowSchedulerTick {
  rankdir=TB;
  labelloc="t";
  label="G14 — Scheduler Tick Control Flow (Pass-9 join() + Pass-10 dispatch fix highlighted)";
  fontname="Helvetica";
  fontsize=16;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#e3f2fd", color="#1565c0"];
  edge [fontname="Helvetica", fontsize=9, color="#37474f"];

  start  [label="cron timer\nfires", shape=oval, fillcolor="#fff59d", color="#f57f17"];
  tick   [label="scheduler_tick()\nentry"];
  claim  [label="claim_next_jobs()\nSELECT executing<=now\nFOR UPDATE SKIP LOCKED", fillcolor="#a5d6a7", color="#1b5e20"];
  none   [label="0 jobs\nclaimed?", shape=diamond, fillcolor="#ffe0b2", color="#e65100"];
  ret    [label="tick returns\nidle", shape=oval, fillcolor="#eeeeee"];

  forloop [label="for-each-job\nspawn worker thread", shape=parallelogram, fillcolor="#e1bee7", color="#4a148c"];
  spawn  [label="thread::spawn(move || {\n  workers::dispatch(job)\n})", fillcolor="#ce93d8", color="#4a148c", penwidth=2];

  dispatch [label="workers::dispatch(job)\n★Pass-10 fix★\nmatch job.worker {\n  \"gleam_run\" => …\n  \"http_post\"  => …\n  …registry…\n}",
            fillcolor="#66bb6a", color="#1b5e20", fontcolor="white", penwidth=3];

  arm_known   [label="known\nworker", shape=diamond, fillcolor="#a5d6a7", color="#1b5e20"];
  arm_unknown [label="unknown\nworker", shape=diamond, fillcolor="#ef9a9a", color="#b71c1c"];

  run_pr  [label="process_runner::run(spec)\ntimeout/heartbeat", fillcolor="#ce93d8", color="#4a148c"];
  outcome [label="Outcome::{Ok, TimedOut,\n  Failed, Crashed}", fillcolor="#fff59d", color="#f57f17"];

  mark_ok  [label="mark_completed(job)\nUPDATE oban_jobs", fillcolor="#a5d6a7", color="#1b5e20"];
  mark_err [label="mark_failed(job, retryable)", fillcolor="#ef9a9a", color="#b71c1c"];

  join [label="JoinHandle::join()\n★Pass-9 add★\n(no orphan threads)",
        fillcolor="#ce93d8", color="#4a148c", penwidth=3];

  done [label="tick returns\nN handled", shape=oval, fillcolor="#eeeeee"];

  start -> tick -> claim -> none;
  none  -> ret      [label="yes"];
  none  -> forloop  [label="no"];
  forloop -> spawn  [label="thread N"];
  spawn -> dispatch;
  dispatch -> arm_known;
  dispatch -> arm_unknown;
  arm_known   -> run_pr -> outcome;
  arm_unknown -> mark_err [label="\"unknown_worker\"\nretryable=false"];
  outcome -> mark_ok  [label="Ok"];
  outcome -> mark_err [label="TimedOut|Failed|Crashed"];
  mark_ok  -> join;
  mark_err -> join;
  join -> done;

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled";
    fillcolor="#f5f5f5";
    color="#9e9e9e";
    fontsize=9;
    lg_p9 [label="Pass-9 (join orphan)", fillcolor="#ce93d8"];
    lg_p10[label="Pass-10 (dispatch registry)", fillcolor="#66bb6a", fontcolor="white"];
    lg_ok [label="success path",      fillcolor="#a5d6a7"];
    lg_err[label="failure path",      fillcolor="#ef9a9a"];
    lg_p9 -> lg_p10 -> lg_ok -> lg_err [style=invis];
  }
}
