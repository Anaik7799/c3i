// g18-uc-fluffychat-end-user-journey.dot — Pass-12 end-user UX journey
digraph G18UCFluffyChatEndUserJourney {
  rankdir=TB;
  labelloc="t";
  label="G18 — FluffyChat End-User UX Journey (7 screens, mapped to Marionette CATALOG.md T-IDs)";
  fontname="Helvetica";
  fontsize=15;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#e3f2fd", color="#1565c0"];
  edge [fontname="Helvetica", fontsize=9, color="#37474f"];

  s0 [label="0. Launch FluffyChat\n(cold start)\nT-FC-LAUNCH-001",
      fillcolor="#fff9c4", color="#f9a825"];
  s1 [label="1. Onboarding\n(welcome carousel)\nT-FC-ONB-002..004",
      fillcolor="#bbdefb"];
  s2 [label="2. Login / Sign-up\n(homeserver picker, SSO)\nT-FC-LOGIN-010..014",
      fillcolor="#bbdefb"];
  s3 [label="3. DM start\n(pick contact, send msg)\nT-FC-DM-020..025",
      fillcolor="#a5d6a7", color="#1b5e20"];
  s4 [label="4. Encrypted Chat\n(verify session, key backup)\nT-FC-E2EE-030..036",
      fillcolor="#a5d6a7", color="#1b5e20"];
  s5 [label="5. Voice / Video Call\n(WebRTC, push-to-talk)\nT-FC-CALL-040..044",
      fillcolor="#ce93d8", color="#4a148c"];
  s6 [label="6. Settings\n(notifications, theme, account)\nT-FC-SET-050..057",
      fillcolor="#bbdefb"];
  s7 [label="7. Logout / Wipe\n(clear session, key purge)\nT-FC-OUT-060..062",
      fillcolor="#fff9c4", color="#f9a825"];

  s0 -> s1 [label="first run"];
  s1 -> s2 [label="\"Get Started\""];
  s2 -> s3 [label="auth ok"];
  s3 -> s4 [label="encrypt\nroom"];
  s4 -> s5 [label="tap call"];
  s5 -> s4 [label="end call"];
  s4 -> s6 [label="cog icon"];
  s6 -> s7 [label="\"Logout\""];
  s7 -> s0 [label="re-launch", style=dashed];

  // Sub-screens cluster (visible Marionette interactives discovered)
  subgraph cluster_marionette {
    label="Marionette discovery — interactive elements per screen";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=10;
    m1 [label="2: TextField(homeserver)\n   FilledButton(continue)",
        shape=note, fillcolor="#fffde7"];
    m2 [label="3: ListTile(contact)\n   IconButton(send)",
        shape=note, fillcolor="#fffde7"];
    m3 [label="4: IconButton(verify)\n   Switch(key backup)",
        shape=note, fillcolor="#fffde7"];
    m4 [label="6: ListTile×8\n   Switch(theme)",
        shape=note, fillcolor="#fffde7"];
    m1 -> m2 -> m3 -> m4 [style=invis];
  }
  s2 -> m1 [style=dashed, color="#9e9e9e"];
  s3 -> m2 [style=dashed, color="#9e9e9e"];
  s4 -> m3 [style=dashed, color="#9e9e9e"];
  s6 -> m4 [style=dashed, color="#9e9e9e"];

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_y [label="entry/exit",  fillcolor="#fff9c4"];
    lg_b [label="onboarding/UI",fillcolor="#bbdefb"];
    lg_g [label="core value (chat)", fillcolor="#a5d6a7"];
    lg_v [label="real-time call",  fillcolor="#ce93d8"];
    lg_y -> lg_b -> lg_g -> lg_v [style=invis];
  }
}
