// g21-fractal-symbiosis-l0-l7.dot — Pass-12 fractal symbiosis matrix
digraph G21FractalSymbiosisL0L7 {
  rankdir=TB;
  labelloc="t";
  label="G21 — Fractal Symbiosis L0–L7 × Components (color-coded by Pass touched: 9 purple, 10 yellow, 11 green, 12 blue)";
  fontname="Helvetica";
  fontsize=15;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10];
  edge [style=invis];

  // Header
  hL [label="Layer",     fillcolor="#37474f", fontcolor="white", penwidth=2];
  hC1 [label="Component A", fillcolor="#37474f", fontcolor="white"];
  hC2 [label="Component B", fillcolor="#37474f", fontcolor="white"];
  hC3 [label="Component C", fillcolor="#37474f", fontcolor="white"];
  hC4 [label="Component D", fillcolor="#37474f", fontcolor="white"];
  hC5 [label="Component E", fillcolor="#37474f", fontcolor="white"];
  { rank=same; hL; hC1; hC2; hC3; hC4; hC5; }

  // Color: green=Pass-11 covered, yellow=Pass-10, purple=Pass-9, blue=Pass-12, grey=untouched

  // L0 Constitutional
  l0  [label="L0 Constitutional", fillcolor="#cfd8dc", penwidth=2];
  l0a [label="Guardian gate",     fillcolor="#a5d6a7"];
  l0b [label="Psi invariants",    fillcolor="#bbdefb"];
  l0c [label="audit log",         fillcolor="#a5d6a7"];
  l0d [label="tool_gate Zenoh",   fillcolor="#bbdefb"];
  l0e [label="2oo3 voting",       fillcolor="#eeeeee"];
  { rank=same; l0; l0a; l0b; l0c; l0d; l0e; }

  // L1 Atomic / NIF
  l1  [label="L1 Atomic/NIF", fillcolor="#cfd8dc", penwidth=2];
  l1a [label="spawn NIF",      fillcolor="#ce93d8"];
  l1b [label="OTel NIF",       fillcolor="#a5d6a7"];
  l1c [label="SQLite NIF",     fillcolor="#a5d6a7"];
  l1d [label="zenoh_nif",      fillcolor="#a5d6a7"];
  l1e [label="VM Service\n(dart)",fillcolor="#bbdefb"];
  { rank=same; l1; l1a; l1b; l1c; l1d; l1e; }

  // L2 Component
  l2  [label="L2 Component", fillcolor="#cfd8dc", penwidth=2];
  l2a [label="oban schema",   fillcolor="#fff59d"];
  l2b [label="RunSpec",       fillcolor="#ce93d8"];
  l2c [label="OTel envelope", fillcolor="#a5d6a7"];
  l2d [label="A2UI catalog",  fillcolor="#a5d6a7"];
  l2e [label="MarionetteCfg", fillcolor="#bbdefb"];
  { rank=same; l2; l2a; l2b; l2c; l2d; l2e; }

  // L3 Transaction
  l3  [label="L3 Transaction", fillcolor="#cfd8dc", penwidth=2];
  l3a [label="claim txn\n(SKIP LOCKED)", fillcolor="#fff59d"];
  l3b [label="state txn",     fillcolor="#a5d6a7"];
  l3c [label="WAL commit",    fillcolor="#a5d6a7"];
  l3d [label="span finish",   fillcolor="#a5d6a7"];
  l3e [label="trace persist", fillcolor="#a5d6a7"];
  { rank=same; l3; l3a; l3b; l3c; l3d; l3e; }

  // L4 System — most-touched
  l4  [label="L4 System ★Pass-9..12★", fillcolor="#fff59d", color="#f57f17", penwidth=3];
  l4a [label="scheduler-tick\n(Pass-11)",        fillcolor="#a5d6a7", penwidth=2];
  l4b [label="oban_jobs\n(Pass-11)",             fillcolor="#a5d6a7", penwidth=2];
  l4c [label="workers::dispatch\n★Pass-10★",
        fillcolor="#fff59d", color="#f57f17", penwidth=3];
  l4d [label="process_runner\n★Pass-9 join()★",
        fillcolor="#ce93d8", color="#4a148c", penwidth=3];
  l4e [label="Zenoh sched/**\n(Pass-11)",        fillcolor="#a5d6a7", penwidth=2];
  { rank=same; l4; l4a; l4b; l4c; l4d; l4e; }

  // L5 Cognitive
  l5  [label="L5 Cognitive", fillcolor="#cfd8dc", penwidth=2];
  l5a [label="cortex.rs",     fillcolor="#bbdefb"];
  l5b [label="RAG pipeline",  fillcolor="#bbdefb"];
  l5c [label="RETE-UL rules", fillcolor="#a5d6a7"];
  l5d [label="ruliology",     fillcolor="#bbdefb"];
  l5e [label="OODA classify", fillcolor="#a5d6a7"];
  { rank=same; l5; l5a; l5b; l5c; l5d; l5e; }

  // L6 Ecosystem
  l6  [label="L6 Ecosystem", fillcolor="#cfd8dc", penwidth=2];
  l6a [label="Marionette MCP",  fillcolor="#bbdefb"];
  l6b [label="Patrol MCP",      fillcolor="#bbdefb"];
  l6c [label="dart_mcp_server", fillcolor="#bbdefb"];
  l6d [label="prajna cockpit",  fillcolor="#a5d6a7"];
  l6e [label="gateway",         fillcolor="#a5d6a7"];
  { rank=same; l6; l6a; l6b; l6c; l6d; l6e; }

  // L7 Federation
  l7  [label="L7 Federation", fillcolor="#cfd8dc", penwidth=2];
  l7a [label="HA leader\nelection",     fillcolor="#a5d6a7"];
  l7b [label="federated\noban",         fillcolor="#eeeeee"];
  l7c [label="federated\ndispatch",     fillcolor="#eeeeee"];
  l7d [label="cross-realm\nMCP",        fillcolor="#bbdefb"];
  l7e [label="federated\nOTel",         fillcolor="#fff59d"];
  { rank=same; l7; l7a; l7b; l7c; l7d; l7e; }

  // Legend
  subgraph cluster_legend {
    label="Legend — color = which Pass primarily touched the cell";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_p9  [label="Pass-9 (process_runner join)",   fillcolor="#ce93d8"];
    lg_p10 [label="Pass-10 (dispatch registry)",     fillcolor="#fff59d"];
    lg_p11 [label="Pass-11 (scheduler / oban / Zenoh)", fillcolor="#a5d6a7"];
    lg_p12 [label="Pass-12 (this pass: docs/MCP/UX)", fillcolor="#bbdefb"];
    lg_n   [label="untouched / future",              fillcolor="#eeeeee"];
    lg_p9 -> lg_p10 -> lg_p11 -> lg_p12 -> lg_n [style=invis];
  }
}
