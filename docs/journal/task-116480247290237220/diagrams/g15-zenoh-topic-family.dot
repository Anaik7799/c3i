// g15-zenoh-topic-family.dot — Pass-12 Zenoh topic taxonomy
digraph G15ZenohTopicFamily {
  rankdir=LR;
  labelloc="t";
  label="G15 — Zenoh Topic Family (12 topics) with Publishers and Subscribers";
  fontname="Helvetica";
  fontsize=16;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=8, color="#37474f"];

  // Publishers (left)
  subgraph cluster_pub {
    label="Publishers";
    style="rounded,filled"; fillcolor="#fff9c4"; color="#f9a825";
    fontsize=11;
    pub_sap   [label="sa-plan-daemon",   fillcolor="#ffe082", color="#f57f17"];
    pub_cor   [label="cortex.rs",        fillcolor="#d1c4e9", color="#4527a0"];
    pub_pr    [label="process_runner",   fillcolor="#ce93d8", color="#4a148c"];
    pub_disp  [label="workers::dispatch",fillcolor="#66bb6a", color="#1b5e20", fontcolor="white"];
    pub_gw    [label="gateway",          fillcolor="#ffcc80", color="#e65100"];
    pub_grd   [label="Guardian",         fillcolor="#ef9a9a", color="#b71c1c"];
    pub_marn  [label="Marionette MCP",   fillcolor="#80deea", color="#006064"];
    pub_pat   [label="Patrol MCP",       fillcolor="#80deea", color="#006064"];
  }

  // Topics (middle)
  t1  [label="indrajaal/l4/sched/job/{id}/{phase}",  fillcolor="#bbdefb", color="#0d47a1"];
  t2  [label="indrajaal/l4/sched/run/{run_id}/{phase}", fillcolor="#bbdefb", color="#0d47a1"];
  t3  [label="indrajaal/l4/sched/proc/{pid}/{phase}", fillcolor="#bbdefb", color="#0d47a1"];
  t4  [label="indrajaal/l5/test/patrol/{run}/{phase}", fillcolor="#bbdefb", color="#0d47a1"];
  t5  [label="indrajaal/l5/test/marionette/{ses}/{op}", fillcolor="#bbdefb", color="#0d47a1"];
  t6  [label="indrajaal/l4/sre/ooda/snapshot",         fillcolor="#bbdefb", color="#0d47a1"];
  t7  [label="indrajaal/otel/spans/{page}/{op}",       fillcolor="#bbdefb", color="#0d47a1"];
  t8  [label="indrajaal/health/{node}",                fillcolor="#bbdefb", color="#0d47a1"];
  t9  [label="indrajaal/plan/spans/{tid}",             fillcolor="#bbdefb", color="#0d47a1"];
  t10 [label="indrajaal/l0/const/tool_gate",           fillcolor="#ef9a9a", color="#b71c1c"];
  t11 [label="indrajaal/l5/cog/trace/{id}",            fillcolor="#bbdefb", color="#0d47a1"];
  t12 [label="indrajaal/l5/scripts/evolution/{tid}/*", fillcolor="#bbdefb", color="#0d47a1"];

  // Subscribers (right)
  subgraph cluster_sub {
    label="Subscribers";
    style="rounded,filled"; fillcolor="#e8f5e9"; color="#2e7d32";
    fontsize=11;
    sub_dash  [label="Dashboard\n:4200/:8443", fillcolor="#a5d6a7", color="#1b5e20"];
    sub_pi    [label="Pi runtime\nbridge",     fillcolor="#a5d6a7", color="#1b5e20"];
    sub_obs   [label="zenoh_test_\nobserver",  fillcolor="#a5d6a7", color="#1b5e20"];
    sub_audit [label="audit_log",              fillcolor="#a5d6a7", color="#1b5e20"];
    sub_kpi   [label="OODA KPI\nrollup",       fillcolor="#a5d6a7", color="#1b5e20"];
  }

  // Pub -> topic
  pub_sap  -> t1; pub_sap -> t2; pub_sap -> t9;
  pub_pr   -> t3;
  pub_disp -> t1; pub_disp -> t2;
  pub_cor  -> t11; pub_cor -> t6; pub_cor -> t7;
  pub_gw   -> t8;
  pub_grd  -> t10;
  pub_marn -> t5;
  pub_pat  -> t4;
  pub_sap  -> t12;
  pub_sap  -> t8 [style=dashed];

  // Topic -> sub
  t1 -> sub_dash;  t1 -> sub_audit;
  t2 -> sub_dash;  t2 -> sub_kpi;
  t3 -> sub_dash;
  t4 -> sub_obs;   t4 -> sub_dash;
  t5 -> sub_obs;   t5 -> sub_dash;
  t6 -> sub_kpi;   t6 -> sub_dash;
  t7 -> sub_obs;   t7 -> sub_pi;
  t8 -> sub_dash;
  t9 -> sub_audit;
  t10 -> sub_audit; t10 -> sub_dash;
  t11 -> sub_pi;    t11 -> sub_audit;
  t12 -> sub_dash;

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_b [label="data topic", fillcolor="#bbdefb"];
    lg_r [label="L0 safety topic", fillcolor="#ef9a9a"];
    lg_b -> lg_r [style=invis];
  }
}
