// g13-dataflow-end-to-end.dot — Pass-12 end-to-end dataflow
digraph G13DataflowEndToEnd {
  rankdir=LR;
  labelloc="t";
  label="G13 — End-to-End Dataflow (operator → cortex → scheduler → workers → telemetry → dashboard)";
  fontname="Helvetica";
  fontsize=16;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#e3f2fd", color="#1565c0"];
  edge [fontname="Helvetica", fontsize=9, color="#37474f"];

  // Sources
  op   [label="Operator\n(SSH/CLI)", fillcolor="#fff9c4", color="#f9a825"];
  tg   [label="Telegram\nlong-poll", fillcolor="#fff9c4", color="#f9a825"];

  // Cortex
  cortex [label="cortex.rs\nintent classify\n(1567 LOC)", fillcolor="#d1c4e9", color="#4527a0"];
  rag    [label="rag.rs\nFTS5 + embeddings", fillcolor="#d1c4e9", color="#4527a0"];
  smriti [label="Smriti.db\n(SQLite WAL)", fillcolor="#a5d6a7", color="#1b5e20"];

  // Scheduler
  cron   [label="cron timer\nscheduler-tick", fillcolor="#fff59d", color="#f57f17", penwidth=2];
  wsched [label="workflow_schedules\n(table)", fillcolor="#a5d6a7", color="#1b5e20"];
  enq    [label="enqueue\nrow", fillcolor="#fff59d", color="#f57f17"];
  obanjobs [label="oban_jobs\n(executing/completed)", fillcolor="#a5d6a7", color="#1b5e20"];

  // Dispatch & runner
  disp [label="workers::dispatch\n★Pass-10 fix★\n(match-arm registry)", fillcolor="#66bb6a", color="#1b5e20", fontcolor="white", penwidth=3];
  pr   [label="process_runner\ntimeout / heartbeat\n★Pass-9 join()★", fillcolor="#ce93d8", color="#4a148c", penwidth=2];
  gleam [label="gleam build/test\n(subprocess)", fillcolor="#e1bee7", color="#4a148c"];

  // Telemetry & sink
  zenoh [label="Zenoh router\nindrajaal/l4/sched/**", fillcolor="#bbdefb", color="#0d47a1", penwidth=2];
  dash  [label="Dashboard\n:4200/:8443", fillcolor="#fff9c4", color="#f9a825"];

  // Edges with payload format
  op    -> cortex [label="text intent\n(JSON)"];
  tg    -> cortex [label="webhook\n(JSON)"];
  cortex -> rag    [label="query"];
  rag   -> smriti [label="FTS5 SELECT"];
  smriti -> rag   [label="rows"];
  rag   -> cortex [label="ranked\nholons"];
  cortex -> smriti [label="task INSERT\n(sqlite row)"];

  cron  -> wsched  [label="next_run<=now\n(SELECT)"];
  wsched -> enq    [label="schedule row"];
  enq   -> obanjobs [label="INSERT\n(JSONB args)"];
  obanjobs -> disp [label="claim\n(SELECT FOR UPDATE)"];
  disp  -> pr      [label="RunSpec\n(struct)"];
  pr    -> gleam   [label="spawn\n(stdin/stdout)"];
  gleam -> pr      [label="exit code\n+ stdout/stderr"];
  pr    -> obanjobs [label="UPDATE state\n(completed/failed)"];

  pr    -> zenoh   [label="JSONL envelope\n{at,urn,run_id,phase}", color="#1565c0", penwidth=2];
  disp  -> zenoh   [label="dispatch span\n(OTel)", color="#1565c0"];
  cortex -> zenoh  [label="trace span"];
  zenoh -> dash    [label="PUT subscribe\n(JSON)"];
  smriti -> dash   [label="HTTP /api\n(JSON)"];

  // Legend cluster
  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled";
    fillcolor="#f5f5f5";
    color="#9e9e9e";
    fontsize=9;
    lg_y [label="cron / scheduler",   fillcolor="#fff59d"];
    lg_p [label="cortex / cognitive", fillcolor="#d1c4e9"];
    lg_g [label="persistence (SQLite)", fillcolor="#a5d6a7"];
    lg_b [label="telemetry (Zenoh)", fillcolor="#bbdefb"];
    lg_v [label="process_runner / Pass-9", fillcolor="#ce93d8"];
    lg_y -> lg_p -> lg_g -> lg_b -> lg_v [style=invis];
  }
}
