digraph G12FractalL0L7Pass11 {
  rankdir=TB;
  labelloc="t";
  label="G12 — Pass-11 Fractal Coverage Matrix (L0–L7 × Components) with SC-DISP-REGISTRY-001..010";
  fontname="Helvetica";
  fontsize=16;
  bgcolor="#fafafa";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10];
  edge [style=invis];

  // Header row
  hdr_layer [label="Fractal Layer", fillcolor="#37474f", fontcolor="white", penwidth=2];
  hdr_sched [label="Scheduler",      fillcolor="#37474f", fontcolor="white"];
  hdr_oban  [label="OBAN",           fillcolor="#37474f", fontcolor="white"];
  hdr_disp  [label="Worker Dispatcher", fillcolor="#37474f", fontcolor="white"];
  hdr_pr    [label="Process Runner", fillcolor="#37474f", fontcolor="white"];
  hdr_tel   [label="Telemetry",      fillcolor="#37474f", fontcolor="white"];
  hdr_per   [label="Persistence",    fillcolor="#37474f", fontcolor="white"];

  { rank=same; hdr_layer; hdr_sched; hdr_oban; hdr_disp; hdr_pr; hdr_tel; hdr_per; }

  // Color palette: green covered, yellow partial, red gap
  // green=#a5d6a7, yellow=#fff59d, red=#ef9a9a

  // L0 Constitutional
  l0  [label="L0 Constitutional", fillcolor="#cfd8dc", penwidth=2];
  l0a [label="n/a",     fillcolor="#eeeeee"];
  l0b [label="n/a",     fillcolor="#eeeeee"];
  l0c [label="n/a",     fillcolor="#eeeeee"];
  l0d [label="n/a",     fillcolor="#eeeeee"];
  l0e [label="Guardian\nspans",  fillcolor="#a5d6a7"];
  l0f [label="audit log", fillcolor="#a5d6a7"];
  { rank=same; l0; l0a; l0b; l0c; l0d; l0e; l0f; }

  // L1 Atomic / NIF
  l1  [label="L1 Atomic/NIF", fillcolor="#cfd8dc", penwidth=2];
  l1a [label="n/a",     fillcolor="#eeeeee"];
  l1b [label="n/a",     fillcolor="#eeeeee"];
  l1c [label="n/a",     fillcolor="#eeeeee"];
  l1d [label="spawn\nNIF",   fillcolor="#a5d6a7"];
  l1e [label="OTel\nNIF",    fillcolor="#a5d6a7"];
  l1f [label="SQLite\nNIF",  fillcolor="#a5d6a7"];
  { rank=same; l1; l1a; l1b; l1c; l1d; l1e; l1f; }

  // L2 Component
  l2  [label="L2 Component", fillcolor="#cfd8dc", penwidth=2];
  l2a [label="tick",   fillcolor="#a5d6a7"];
  l2b [label="row\nschema", fillcolor="#a5d6a7"];
  l2c [label="match\narms",  fillcolor="#a5d6a7"];
  l2d [label="RunSpec", fillcolor="#a5d6a7"];
  l2e [label="envelope", fillcolor="#a5d6a7"];
  l2f [label="schema",  fillcolor="#a5d6a7"];
  { rank=same; l2; l2a; l2b; l2c; l2d; l2e; l2f; }

  // L3 Transaction
  l3  [label="L3 Transaction", fillcolor="#cfd8dc", penwidth=2];
  l3a [label="claim\ntxn",  fillcolor="#a5d6a7"];
  l3b [label="state\ntxn",  fillcolor="#a5d6a7"];
  l3c [label="dispatch\nresult", fillcolor="#a5d6a7"];
  l3d [label="exit\nrecord",fillcolor="#a5d6a7"];
  l3e [label="span\nfinish", fillcolor="#a5d6a7"];
  l3f [label="WAL\ncommit", fillcolor="#a5d6a7"];
  { rank=same; l3; l3a; l3b; l3c; l3d; l3e; l3f; }

  // L4 System (Pass-11 focus — SC-DISP-REGISTRY)
  l4  [label="L4 System ★Pass-11★", fillcolor="#fff59d", color="#f57f17", penwidth=3];
  l4a [label="scheduler-tick\nlifeline\nSC-DISP-REGISTRY\n-001..003", fillcolor="#a5d6a7", color="#1b5e20", penwidth=2];
  l4b [label="oban_jobs\ntable\nSC-DISP-REGISTRY\n-004", fillcolor="#a5d6a7", color="#1b5e20", penwidth=2];
  l4c [label="workers::dispatch\n★Pass-10 fix★\nSC-DISP-REGISTRY\n-005..007", fillcolor="#66bb6a", color="#1b5e20", fontcolor="white", penwidth=3];
  l4d [label="process_runner\ntimeout/heartbeat\nSC-DISP-REGISTRY\n-008", fillcolor="#a5d6a7", color="#1b5e20", penwidth=2];
  l4e [label="Zenoh\nindrajaal/l4/\nsched/**\nSC-DISP-REGISTRY\n-009", fillcolor="#a5d6a7", color="#1b5e20", penwidth=2];
  l4f [label="durable log\nSC-DISP-REGISTRY\n-010", fillcolor="#a5d6a7", color="#1b5e20", penwidth=2];
  { rank=same; l4; l4a; l4b; l4c; l4d; l4e; l4f; }

  // L5 Cognitive
  l5  [label="L5 Cognitive", fillcolor="#cfd8dc", penwidth=2];
  l5a [label="RETE\nrules",   fillcolor="#a5d6a7"];
  l5b [label="job\ncortex",   fillcolor="#fff59d"];
  l5c [label="OODA\nclassify", fillcolor="#a5d6a7"];
  l5d [label="ruliology",     fillcolor="#fff59d"];
  l5e [label="span\ncortex",  fillcolor="#a5d6a7"];
  l5f [label="ZK\ningest",    fillcolor="#a5d6a7"];
  { rank=same; l5; l5a; l5b; l5c; l5d; l5e; l5f; }

  // L6 Ecosystem
  l6  [label="L6 Ecosystem", fillcolor="#cfd8dc", penwidth=2];
  l6a [label="quorum\nfan-out", fillcolor="#fff59d"];
  l6b [label="multi-node\nclaim",  fillcolor="#ef9a9a", color="#b71c1c"];
  l6c [label="per-node\ndispatch", fillcolor="#fff59d"];
  l6d [label="cross-node\nspawn",  fillcolor="#ef9a9a", color="#b71c1c"];
  l6e [label="mesh\nspans", fillcolor="#a5d6a7"];
  l6f [label="CRDT\nlog",   fillcolor="#fff59d"];
  { rank=same; l6; l6a; l6b; l6c; l6d; l6e; l6f; }

  // L7 Federation
  l7  [label="L7 Federation", fillcolor="#cfd8dc", penwidth=2];
  l7a [label="leader\nelection", fillcolor="#fff59d"];
  l7b [label="federated\nqueue",  fillcolor="#ef9a9a", color="#b71c1c"];
  l7c [label="federated\ndispatch", fillcolor="#ef9a9a", color="#b71c1c"];
  l7d [label="cross-realm\nrunner",  fillcolor="#ef9a9a", color="#b71c1c"];
  l7e [label="federated\nOTel", fillcolor="#fff59d"];
  l7f [label="federated\naudit",fillcolor="#fff59d"];
  { rank=same; l7; l7a; l7b; l7c; l7d; l7e; l7f; }

  // Legend
  subgraph cluster_legend {
    label="Legend / Pass-11 STAMP family";
    style="rounded,filled";
    fillcolor="#f5f5f5";
    color="#9e9e9e";
    fontsize=10;
    lg_g [label="green = covered",  fillcolor="#a5d6a7"];
    lg_y [label="yellow = partial", fillcolor="#fff59d"];
    lg_r [label="red = gap",        fillcolor="#ef9a9a"];
    lg_n [label="grey = n/a",       fillcolor="#eeeeee"];
    lg_s [label="SC-DISP-REGISTRY-001..010\nnew family covering L4-System\ndispatch registry parity",
          fillcolor="#fff59d", color="#f57f17", shape=note, penwidth=2];
    lg_g -> lg_y -> lg_r -> lg_n -> lg_s [style=invis];
  }
}
