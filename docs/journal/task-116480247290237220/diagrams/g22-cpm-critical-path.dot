// g22-cpm-critical-path.dot — Pass-12 CPM critical-path analysis
digraph G22CPMCriticalPath {
  rankdir=LR;
  labelloc="t";
  label="G22 — CPM Critical Path: 12 use-case nodes, p95 = 1228 ms, slack = 172 ms (critical = red, slack = green)";
  fontname="Helvetica";
  fontsize=15;
  bgcolor="#fafafa";
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#e3f2fd", color="#1565c0"];
  edge [fontname="Helvetica", fontsize=9, color="#37474f"];

  // Format: { Name | EST/EFT | LST/LFT | dur }
  uc1 [label="{ UC-1 cron tick | EST 0 / EFT 5 | LST 0 / LFT 5 | 5 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc2 [label="{ UC-2 SELECT due | 5 / 18 | 5 / 18 | 13 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc3 [label="{ UC-3 INSERT job | 18 / 35 | 18 / 35 | 17 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc4 [label="{ UC-4 claim+lock | 35 / 60 | 35 / 60 | 25 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc5 [label="{ UC-5 dispatch ★Pass-10★ | 60 / 65 | 60 / 65 | 5 ms }",
       fillcolor="#fff59d", color="#f57f17", penwidth=3];
  uc6 [label="{ UC-6 process_runner spawn ★Pass-9★ | 65 / 90 | 65 / 90 | 25 ms }",
       fillcolor="#ce93d8", color="#4a148c", penwidth=3];
  uc7 [label="{ UC-7 gleam build/test (subprocess) | 90 / 1090 | 90 / 1090 | 1000 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc8 [label="{ UC-8 outcome capture | 1090 / 1110 | 1090 / 1110 | 20 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc9 [label="{ UC-9 Zenoh PUT proc/done | 1110 / 1118 | 1110 / 1118 | 8 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc10[label="{ UC-10 mark_completed | 1118 / 1140 | 1118 / 1140 | 22 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];
  uc11[label="{ UC-11 dashboard WS push | 1140 / 1180 | 1180 / 1220 | 40 ms slack=40 }",
       fillcolor="#a5d6a7", color="#1b5e20"];
  uc12[label="{ UC-12 ZK ingest (async) | 1140 / 1228 | 1140 / 1228 | 88 ms }",
       fillcolor="#ef9a9a", color="#b71c1c", penwidth=2];

  // Critical path edges
  uc1 -> uc2 [color="#b71c1c", penwidth=3, label="cp"];
  uc2 -> uc3 [color="#b71c1c", penwidth=3, label="cp"];
  uc3 -> uc4 [color="#b71c1c", penwidth=3, label="cp"];
  uc4 -> uc5 [color="#b71c1c", penwidth=3, label="cp"];
  uc5 -> uc6 [color="#b71c1c", penwidth=3, label="cp"];
  uc6 -> uc7 [color="#b71c1c", penwidth=3, label="cp"];
  uc7 -> uc8 [color="#b71c1c", penwidth=3, label="cp"];
  uc8 -> uc9 [color="#b71c1c", penwidth=3, label="cp"];
  uc9 -> uc10 [color="#b71c1c", penwidth=3, label="cp"];
  uc10 -> uc12 [color="#b71c1c", penwidth=3, label="cp"];
  // Non-critical (slack 40)
  uc10 -> uc11 [color="#1b5e20", penwidth=2, label="slack 40 ms", style=dashed];

  // Pass shifts annotation
  shift [label="Pass-9 + Pass-10 reduced UC-5/UC-6\nfrom (15ms+45ms broken) → (5ms+25ms healthy)\n→ p95 dropped from ~1268 to 1228 ms",
         shape=note, fillcolor="#fff9c4", color="#f57f17"];
  uc6 -> shift [style=dashed, color="#f57f17", arrowhead=none];

  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#f5f5f5"; color="#9e9e9e"; fontsize=9;
    lg_cp [label="CRITICAL PATH (zero slack)", fillcolor="#ef9a9a", color="#b71c1c"];
    lg_sl [label="non-critical (slack 40 ms)", fillcolor="#a5d6a7", color="#1b5e20"];
    lg_p9 [label="Pass-9 fix",  fillcolor="#ce93d8"];
    lg_p10[label="Pass-10 fix", fillcolor="#fff59d"];
    lg_cp -> lg_sl -> lg_p9 -> lg_p10 [style=invis];
  }
}
