digraph SecretStateMachine {
  rankdir=LR;
  bgcolor="#0a0e17";
  node [fontname="Inter", fontcolor="#e0e6ed", color="#1e2a3a", style="filled", fillcolor="#141922"];
  edge [color="#7a8fa6", fontcolor="#3dd68c", fontname="Inter", fontsize=10];

  born [label="Born\nput called\nfetched_at = now\nv = 1", shape=circle, fillcolor="#00d4aa", fontcolor="#0a0e17"];
  fresh [label="Fresh\nnow - fetched_at < ttl\nSecretFresh rule (sal 100)", fillcolor="#1a2a1a"];
  soft_stale_online [label="Soft-stale (online)\nttl ≤ age < max_ttl\nSecretSoftStale rule (sal 95)\n→ trigger background sync", fillcolor="#1a2530"];
  soft_stale_offline [label="Soft-stale (offline)\nttl ≤ age < max_ttl\nSecretSoftStaleOffline rule (sal 90)\n→ degraded mode, dashboard amber", fillcolor="#2a2418"];
  hard_stale [label="Hard-stale\nage ≥ max_ttl\nSecretHardStale rule (sal 100)\nFAIL-CLOSED\nP0 alarm", fillcolor="#ff4757", fontcolor="#ffffff"];
  destroyed [label="Destroyed\nvault_kv_destroy called\nor superseded by sync", shape=doublecircle, fillcolor="#7a8fa6", fontcolor="#0a0e17"];
  rotation_due [label="Rotation due\nnow - rotated_at ≥ rotation_days\nSecretRotationDue rule (sal 80)\n→ propose P1 task", fillcolor="#2a2418"];

  born -> fresh [label="vault.put returns ok"];
  fresh -> soft_stale_online [label="time advances + online"];
  fresh -> soft_stale_offline [label="time advances + offline"];
  soft_stale_online -> fresh [label="background sync ok"];
  soft_stale_offline -> fresh [label="reconnect + sync"];
  soft_stale_offline -> hard_stale [label="time advances\nnetwork still down"];
  soft_stale_online -> hard_stale [label="sync repeatedly fails"];
  hard_stale -> fresh [label="manual rotate via\nsa-plan vault put"];
  hard_stale -> destroyed [label="operator decides to abandon"];
  fresh -> rotation_due [label="rotation_days elapsed"];
  rotation_due -> fresh [label="auto/manual rotation"];

  born -> destroyed [label="vault.destroy(v=1)", style=dashed];
  fresh -> destroyed [label="vault.destroy", style=dashed];
}
