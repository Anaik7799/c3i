  Tailscale -> TLS;
  TLS -> Web; TLS -> Api;
  HTTP -> Web; HTTP -> Api;
  Api -> PlanningDB;
  Web -> PlanningDB;
  User -> App [label="4000-4004"];
  App -> DB;
  App -> Zenoh;
  Cortex -> Zenoh;
  Cortex -> Gemini [label="hedged"];
  Cortex -> Ollama [label="fallback"];
  App -> Obs [label="OTEL"];
  Cortex -> Obs;
  Zenoh -> Obs [label="span relay"];
  Zenoh -> App [label="sub/pub"];
}
