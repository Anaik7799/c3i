-- =============================================================================
-- §11. INVARIANTS (Evolution-Wide)
-- =============================================================================

invariant MonotonicEntropy {
    for all consecutive waves w_i, w_{i+1}:
        w_{i+1}.fitness_metric > w_i.fitness_metric
    note: "System NEVER regresses in coverage entropy."
}

invariant MonotonicRPNReduction {
    for all consecutive waves w_i, w_{i+1}:
        sum_rpn(w_{i+1}) <= sum_rpn(w_i)
    note: "Total risk NEVER increases across waves."
}

invariant MonotonicSIL6Compliance {
    for all consecutive waves w_i, w_{i+1}:
        w_{i+1}.sil6_compliance >= w_i.sil6_compliance
    note: "SIL-6 compliance NEVER regresses."
}

invariant CompilationNeverBreaks {
    -- SC-FUNC-001: System compiles at ALL times
    after every task completion:
        "gleam build" returns 0 errors
        "gleam test" returns 0 failures
    note: "Jidoka: halt if compilation breaks. Fix before proceeding."
}

invariant RollbackAlways {
    -- SC-FUNC-003: Rollback path exists for every change
    for every wave w:
        "git revert to wave entry commit restores functional state"
    note: "Each wave entry is a git tag: wave-0-entry, wave-1-entry, etc."
}

-- =============================================================================
-- §12. EXECUTION PROTOCOL
-- =============================================================================

rule "Wave Entry Protocol" {
    when starting wave W
    step1: "git tag wave-{W}-entry"
    step2: "gleam build && gleam test — verify green baseline"
    step3: "Verify all entry gate conditions met"
    step4: "Assign tasks to agents based on lane"
    step5: "Start parallel execution"
}

rule "Task Completion Protocol" {
    when completing task T
    step1: "gleam build — 0 errors, 0 warnings"
    step2: "gleam test — 0 failures"
    step3: "Task-specific verification (from task definition)"
    step4: "Domain supervisor sign-off"
    step5: "Update wave fitness_metric and sil6_compliance"
}

rule "Wave Exit Protocol" {
    when all tasks in wave W complete
    step1: "Verify ALL exit gate conditions"
    step2: "Run full regression suite (2677+ tests)"
    step3: "Safety supervisor verifies RPN decreased"
    step4: "Quality supervisor verifies entropy increased"
    step5: "Constitutional guardian verifies SIL-6 compliance increased"
    step6: "git tag wave-{W}-complete"
    step7: "Proceed to wave W+1"
}

rule "Jidoka Halt" {
    when any of:
        - gleam build fails
        - gleam test has failures
        - SIL-6 compliance decreases
        - RPN increases
        - Entry/exit gate condition violated
    then: "STOP all work. Fix before proceeding. Revert if necessary."
    @guidance This is the Toyota Production System Jidoka principle.
              Quality at the source. Never pass a defect forward.
}
