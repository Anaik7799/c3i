        "History: no list exceeds 100 entries after 1000 events",
        "Shutdown: SIGTERM → clean exit within 30 seconds",
        "gleam build: 0 warnings (SC-MUDA-001)",
        "gleam test: all pass including new integration tests"
    ]
    fitness_metric: 4.2      -- H ≥ 2.5 (gold standard threshold) with margin
    sil6_compliance: 0.95    -- Near-full SIL-6 compliance for WebUI control plane
}

-- =============================================================================
-- §6. SUPERVISORY LAYERS (4-Layer Biomorphic Hierarchy)
-- =============================================================================

-- Layer 0: Constitutional Guardian (veto authority, SIL-6 enforcement)
actor ConstitutionalGuardian {
    authority: "veto any task that violates Psi-0..5 or Omega-0"
    checks: [
        "Every wave exit gate includes SIL-6 compliance check",
        "Emergency stop pathway tested before Wave 2 can complete",
        "No mutation shipped without auth (GAP-007 before GAP-001)",
        "Rollback path exists for every wave (git revert to wave entry)"
    ]
    intervention: "HALT wave if sil6_compliance decreases"
}

-- Layer 1: Safety Supervisor (FMEA, RPN monitoring)
actor SafetySupervisor {
    authority: "reorder tasks within a wave based on RPN delta"
    checks: [
        "Total system RPN decreases monotonically across waves",
        "No RPN > 200 remains after Wave 2",
        "FMEA mitigations verified in exit gate tests"
    ]
    metrics: {
        rpn_before_session: 720   -- GAP-004 zenoh stub
        rpn_after_wave0: 0        -- zenoh stub eliminated
        rpn_after_wave1: 0        -- all mutation paths gated
        rpn_after_wave2: 0        -- safety + streaming complete
        rpn_after_wave3: 0        -- live data, no hardcoded
        rpn_after_wave4: 0        -- all mitigations verified
    }
}

-- Layer 2: Quality Supervisor (coverage, entropy, testing)
actor QualitySupervisor {
    authority: "block wave completion if coverage entropy < threshold"
    checks: [
        "Shannon entropy H monotonically increases per wave",
        "CCM (Cyclomatic Complexity Metric) >= 0.90 after Wave 4",
        "ITQS >= 0.85 after Wave 4",
        "All new code has gleeunit tests"
    ]
    metrics: {
        h_wave0: 1.5
        h_wave1: 2.0
        h_wave2: 3.0
        h_wave3: 3.8
        h_wave4: 4.2   -- target: >= 2.5 (gold standard)
    }
}

-- Layer 3: Domain Supervisors (per-lane coordination)
actor ZenohLaneSupervisor {
    scope: ["T001", "T002", "T003"]
    checks: ["NIF loads without segfault", "Subscribe callback fires within 100ms"]
}

actor MoZLaneSupervisor {
    scope: ["T007", "T008", "T009"]
    checks: ["JSON-RPC 2.0 format correct", "Circuit breaker threshold 5 failures"]
}

actor GuardianLaneSupervisor {
    scope: ["T010", "T011", "T012"]
    checks: ["2oo3 consensus evaluates correctly", "Emergency stop < 5s SLA"]
}

actor SSELaneSupervisor {
    scope: ["T013", "T014", "T015"]
    checks: ["Mist chunked response streams", "Heartbeat every 5s", "Ring buffer 100 events"]
}

actor StateLaneSupervisor {
    scope: ["T016", "T017", "T018"]
    checks: ["GenServer supervised", "Zenoh subscriptions active", "Cache TTL enforced"]
}

