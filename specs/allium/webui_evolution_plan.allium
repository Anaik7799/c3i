-- Synthesizes: 4 analysis passes, 184 modules / 30,930 LOC, 12 production gaps

-- =============================================================================
-- §1. MULTI-CRITERIA DECISION ANALYSIS (MCDA)
-- =============================================================================

-- Six optimization dimensions with AHP-derived weights.
-- Pairwise comparison matrix (Saaty scale 1-9):
--
--              Crit  FMEA  Robust  Usab  Stab  SIL6
-- Criticality   1     3      2      5     3     1/2
-- FMEA         1/3    1      1      3     2     1/3
-- Robustness   1/2    1      1      3     2     1/2
-- Usability    1/5   1/3    1/3     1    1/2    1/5
-- Stability    1/3   1/2    1/2     2     1     1/3
-- SIL-6         2     3      2      5     3      1
--
-- Eigenvector (normalized priority weights):
-- w = [0.22, 0.10, 0.12, 0.05, 0.08, 0.43]
-- Consistency Ratio CR = 0.03 < 0.10 (acceptable)

config {
    -- AHP-derived weights (sum = 1.0)
    w_criticality: Decimal = 0.22
    w_fmea: Decimal = 0.10
    w_robustness: Decimal = 0.12
    w_usability: Decimal = 0.05
    w_stability: Decimal = 0.08
    w_sil6: Decimal = 0.43

    -- Scoring scales (1-10)
    -- Criticality: 10 = system non-functional without it
    -- FMEA: normalized RPN / 100 (max 10)
    -- Robustness: 10 = prevents cascading failures
    -- Usability: 10 = operator can't function without it
    -- Stability: 10 = eliminates instability source
    -- SIL-6: 10 = directly satisfies SIL-6 constraint

    -- Resource constraints (RCPSP)
    max_parallel_tasks: Integer = 4      -- CPU governor: max concurrent heavy tasks
    agents_available: Integer = 3        -- Claude + Gemini + operator concurrent
    compile_slot_limit: Integer = 1      -- Only 1 gleam build at a time
    test_slot_limit: Integer = 1         -- Only 1 test suite at a time
}

-- =============================================================================
-- §2. TASK UNIVERSE — 28 Tasks from 12 GAPs, Scored on 6 Dimensions
-- =============================================================================

-- Composite Priority Score: CPS = Σ(w_i × score_i)
-- Higher CPS = higher priority (scheduled first)

-- Notation: [Crit, FMEA, Robust, Usab, Stab, SIL6] → CPS

entity Task {
    id: String
    gap: String
    description: String
    scores: List<Decimal>   -- [crit, fmea, robust, usab, stab, sil6]
    cps: Decimal            -- computed composite priority score
    effort_hours: Integer
    depends_on: Set<Task>
    wave: Integer           -- assigned wave (computed by scheduler)
    lane: String            -- parallel execution lane
}

