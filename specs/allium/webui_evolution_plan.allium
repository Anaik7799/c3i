-- =============================================================================
-- §4. DAG DEPENDENCY GRAPH (CPM / Critical Path Analysis)
-- =============================================================================

-- Nodes: 28 tasks. Edges: depends_on relationships.
-- Critical path: longest path through DAG (determines minimum completion time).
--
-- WAVE 0 (Foundation) — 2 parallel lanes, 18 hours
--
--   Lane zenoh:   T001(6h) → T002(4h) → T003(3h)     = 13h
--   Lane auth:    T004(5h)                              = 5h
--   Wave 0 gate:  max(13, 5) = 13 hours
--
-- WAVE 1 (Mutation) — 3 parallel lanes, 19 hours
--
--   Lane router:  T005(4h) → T009(4h)                  = 8h  [depends: T004]
--   Lane codecs:  T006(3h) ──────────→ T009             = 3h  [independent]
--   Lane moz:     T007(8h) → T008(3h) → T009            = 11h [depends: T001-T003]
--   Wave 1 gate:  max(8, 3, 11) = 11 hours (T007→T008 is critical)
--   T009 merge:   T005 + T006 + T007 must all complete = 4h
--   Wave 1 total: 11 + 4 = 15h
--
-- WAVE 2 (Safety + Real-Time) — 2 parallel lanes, 13 hours
--
--   Lane guardian: T010(3h) → T011(4h) → T012(5h)      = 12h
--   Lane sse:     T013(6h) → T014(4h)                  = 10h
--                 T013(6h) → T015(4h)                  = 10h (T014/T015 parallel)
--   Wave 2 gate:  max(12, 10) = 12 hours (guardian is critical)
--
-- WAVE 3 (Live Data) — 3 parallel lanes, 14 hours
--
--   Lane state:   T016(6h) → T017(8h)                  = 14h (critical)
--   Lane cockpit: T016(6h) → T018(3h) → T020(3h)       = 12h
--   Lane lustre:  T019(3h), T021(2h)                   = 3h
--   Wave 3 gate:  max(14, 12, 3) = 14 hours (state lane critical)
--
-- WAVE 4 (Hardening) — 4 parallel lanes, 8 hours
--
--   Lane hardening: T022(3h), T023(2h) [parallel]       = 3h
--   Lane server:    T024(3h)                            = 3h
--   Lane testing:   T025(4h), T026(4h), T027(4h), T028(3h) [pairwise parallel]
--   Wave 4 gate:    max(3, 3, 8) = 8 hours
--
-- TOTAL CRITICAL PATH:
--   Wave 0: 13h + Wave 1: 15h + Wave 2: 12h + Wave 3: 14h + Wave 4: 8h = 62 hours
--   At 6h/day effective work = 10.3 days ≈ 11 calendar days
--
-- WITH MAX PARALLELIZATION (4 agents, overlapping waves):
--   Wave 0+1 overlap: auth lane (T004) can run while zenoh lane executes
--   Wave 2+3 overlap: SSE lane independent of guardian if Zenoh ready
--   Compressed: ~8 calendar days with 3-4 parallel agents

-- =============================================================================
-- §5. BIOMORPHIC WAVE STRUCTURE (Evolutionary Generations)
-- =============================================================================

-- Each wave is a generation in the biomorphic evolution.
-- Fitness function: coverage entropy across C1-C8 gold standard categories.
-- Selection pressure: SIL-6 constraints eliminate unsafe mutations.
-- Crossover: integration tasks merge capabilities from parallel lanes.

enum WavePhase {
    genesis |        -- Wave 0: Create fundamental capabilities (Zenoh, Auth)
    differentiation | -- Wave 1: Specialize into mutation + control pathways
    integration |    -- Wave 2: Safety (Guardian) + delivery (SSE) merge
    maturation |     -- Wave 3: State coordination, live data, cross-page
    homeostasis      -- Wave 4: Hardening, bounds, testing, equilibrium
}

-- Biomorphic metaphor:
-- Wave 0 = Stem cell (Zenoh FFI) — totipotent, enables all downstream
-- Wave 1 = Tissue differentiation (MoZ, Router, Codecs) — specialized paths
-- Wave 2 = Organ formation (Guardian HITL, SSE streams) — functional units
-- Wave 3 = Nervous system (SharedMeshState, cross-page coordination) — integration
-- Wave 4 = Immune system (circuit breakers, chaos tests, bounds) — resilience

entity Wave {
    phase: WavePhase
    tasks: Set<Task>
    entry_gate: List<String>     -- conditions to start this wave
    exit_gate: List<String>      -- conditions to proceed to next wave
    fitness_metric: Decimal      -- Shannon entropy H after wave completion
    sil6_compliance: Decimal     -- percentage of SIL-6 constraints satisfied

    invariant MonotonicFitness {
        -- Each wave MUST increase system fitness (entropy)
        this.fitness_metric > previous_wave.fitness_metric
    }

    invariant MonotonicCompliance {
        -- Each wave MUST increase SIL-6 compliance
        this.sil6_compliance >= previous_wave.sil6_compliance
    }
}

-- Wave 0: Genesis
