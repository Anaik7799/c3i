-- =============================================================================
-- §12. FMEA FOR OPERATOR INTERFACE
-- =============================================================================

fmea "Operator clicks wrong container action" {
    severity: 7
    occurrence: 4
    detection: 2
    rpn: 56
    mitigation: "Confirmation dialog for stop/restart. Container name shown in dialog."
}

fmea "Dashboard shows stale data" {
    severity: 6
    occurrence: 5
    detection: 3
    rpn: 90
    mitigation: "Last-updated timestamp on every card. 'Stale' badge if > 30s old."
}

fmea "Operator misses critical alert" {
    severity: 9
    occurrence: 3
    detection: 2
    rpn: 54
    mitigation: "Dark cockpit mode ensures anomalies surface. Red banner for criticals."
}

fmea "Emergency stop button accidentally triggered" {
    severity: 10
    occurrence: 2
    detection: 1
    rpn: 20
    mitigation: "Typed confirmation 'EMERGENCY STOP'. Guardian 2oo3 consensus for P0."
}

fmea "HTML page fails to render" {
    severity: 5
    occurrence: 2
    detection: 1
    rpn: 10
    mitigation: "JSON API always available as fallback. /health endpoint for monitoring."
}
