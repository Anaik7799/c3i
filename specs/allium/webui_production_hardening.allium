--
-- Critical path: GAP-004 → GAP-001 → GAP-005 → Workflow 2
-- Estimated: 7-10 days for full production-grade WebUI control

-- =============================================================================
-- S5. MCP TOOL CATALOG ALIGNMENT (Rust ↔ Gleam)
-- =============================================================================

-- The Rust mcp_bridge.rs exposes these tools. Gleam MoZ client must match.

alignment McpToolCatalog {
    -- From mcp_bridge.rs tool_catalog() (line 51-120)
    rust_tools: [
        "ignition_status",      -- GET mesh status (containers, CPU, health)
        "ignition_preflight",   -- Run 18 preflight checks
        "ignition_ooda",        -- Run OODA supervisor cycle (params: {cycles: int})
        "ignition_rca",         -- Run 7-level RCA (params: {error: string})
        -- Additional tools from main.rs subcommands:
        "ignition_launch",      -- Boot SIL-6 mesh (params: {env: "prod"|"test"})
        "ignition_down",        -- Graceful mesh shutdown
        "ignition_emergency",   -- Apoptosis trigger
        "ignition_stabilize"    -- Halt mutations
    ]

    -- Gleam MoZ client must be able to call each tool
    gleam_client_methods: [
        "get_status()",
        "run_preflight()",
        "run_ooda(cycles: Int)",
        "run_rca(error: String)",
        "launch_mesh(env: String)",
        "shutdown_mesh()",
        "emergency_stop()",
        "stabilize()"
    ]

    -- Topic mapping
    request_topic: "indrajaal/l4/ignition/mcp/req/{tool_name}/{request_id}"
    response_topic: "indrajaal/l4/ignition/mcp/res/{request_id}"
    heartbeat_topic: "indrajaal/l4/ignition/{node_id}/heartbeat"

    -- JSON-RPC 2.0 format (from McpRequest struct)
    request_format: {
        jsonrpc: "2.0",
        method: "{tool_name}",
        params: {},
        id: "{request_id}"
    }
    response_format: {
        jsonrpc: "2.0",
        result: {} | null,
        error: {code: int, message: string, data: {} | null} | null,
        id: "{request_id}"
    }
}

-- =============================================================================
-- S6. ADDITIONAL FMEA (Beyond webui_operational_control.allium)
-- =============================================================================

fmea "Hardcoded API data served as real" {
    severity: 7        -- Operator makes decision on stale data
    occurrence: 9      -- Happens every request right now
    detection: 3       -- Not obvious — JSON looks valid
    rpn: 189
    mitigation: "Replace hardcoded JSON with Zenoh-sourced state (GAP-002)"
    note: "RPN 189 is near P1 threshold. Operators may think threat_level='nominal' when it's 'critical'."
}

fmea "Zenoh FFI stub silently succeeds" {
    severity: 9        -- All Zenoh features broken with no error
    occurrence: 10     -- Every Zenoh call right now
    detection: 8       -- Returns {ok, nil} — looks successful
    rpn: 720
    mitigation: "Wire FFI to real zenoh_nif.so (GAP-004). This is the #1 priority."
    note: "RPN 720 is CRITICAL. SC-ZMOF-001 is violated by the stub. Every feature
           that depends on Zenoh (SSE, mutations, real-time data) is non-functional."
}

fmea "No authentication on mutation endpoints" {
    severity: 9        -- Unauthenticated container control
    occurrence: 2      -- Mutation endpoints don't exist yet
    detection: 1       -- Easy to add before deployment
    rpn: 18
    mitigation: "Add bearer token auth when implementing POST endpoints"
}

fmea "SSE string concatenation under load" {
    severity: 5        -- Slow responses, memory spike
    occurrence: 6      -- Every SSE request
    detection: 4       -- Performance degradation visible
    rpn: 120
    mitigation: "Implement Mist chunked streaming (GAP-003)"
}

-- =============================================================================
-- S7. OPEN QUESTIONS (Updated)
-- =============================================================================

open_question "ETS vs OTP Actor for UI State" {
    -- How should the SSEBridge hold shared state?
    -- Option A: ETS table (fast reads, manual cleanup)
    -- Option B: OTP actor/GenServer (supervision, message passing)
    -- Option C: Gleam process dictionary (simple, single-process)
    status: proposed
    impact: high (affects all real-time features)
    recommendation: "OTP actor — Gleam's erlang/process.gleam supports this,
                     and supervisor restart handles crash recovery"
}

open_question "Proof Token Generation for WebUI" {
    -- The Rust MCP bridge validates Ed25519 proof tokens.
    -- Who generates the token for WebUI mutations?
    -- Option A: Server-side after HITL approval (Gleam generates)
    -- Option B: Client-side with hardware key (browser WebAuthn)
    -- Option C: Guardian service generates and signs
    status: proposed
    impact: high (security architecture for P0 mutations)
    recommendation: "Option C — Guardian is already the trust authority.
                     After HITL approval, Guardian signs the proof token,
                     Gleam includes it in MoZ request, Rust validates."
}

open_question "Catalog Handler Mismatch" {
    -- Rust publishes 6 tools in catalog, only handles 3 in dispatch
    -- See webui_full_system_robustness.allium S2 for details
    status: new
    impact: medium
}

open_question "Database for WebUI Session State" {
    -- Should WebUI sessions be tracked?
    -- Option A: Stateless (every request self-contained)
    -- Option B: SQLite session store
    -- Option C: Erlang ETS (ephemeral, lost on restart)
    status: proposed
    impact: medium
    recommendation: "Option A for MVP — stateless REST.
                     Option C for SSE connection tracking.
                     Option B only if persistent session history needed."
}
