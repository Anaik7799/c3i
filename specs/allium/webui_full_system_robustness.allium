-- =============================================================================
-- S2. RUST MCP PROTOCOL ALIGNMENT (Exact Wire Format)
-- =============================================================================

-- The Gleam MoZ client MUST speak this exact protocol to Rust mcp_bridge.rs.

contract RustMcpProtocol {
    -- JSON-RPC 2.0 over Zenoh pub/sub

    -- Request format (Gleam → Zenoh → Rust)
    value McpWireRequest {
        jsonrpc: String = "2.0"
        method: String          -- "launch" | "restart" | "drain"
        params: Json            -- tool-specific parameters
        id: String              -- unique request ID (UUID), echoed in response
    }

    -- Response format (Rust → Zenoh → Gleam)
    value McpWireResponse {
        jsonrpc: String = "2.0"
        result: Json?           -- present on success, null on error
        error: McpWireError?    -- present on error, null on success
        id: String              -- echo of request ID
    }

    value McpWireError {
        code: Integer           -- -32601 (method not found), -32602 (invalid params), -32000 (server error)
        message: String
        data: Json?
    }

    -- Topic patterns
    config {
        request_topic_template: String = "indrajaal/l4/ignition/mcp/req/{method}/{request_id}"
        response_topic_template: String = "indrajaal/l4/ignition/mcp/res/{request_id}"
        heartbeat_topic_template: String = "indrajaal/l4/ignition/{node_id}/heartbeat"
        catalog_topic_template: String = "indrajaal/l4/ignition/mcp/catalog/{node_id}"
        heartbeat_interval_ms: Integer = 1000
        heartbeat_payload: String = "ALIVE"
    }

    -- CRITICAL: Only 3 tools are actually handled by Rust (despite 6 in catalog)
    rule "Active Tool Set" {
        -- mcp_bridge.rs handle_request() match arms:
        supported_tools: ["launch", "restart", "drain"]
        -- The catalog publishes 6 tools but only these 3 have handlers
        -- Gleam client MUST only call these 3 until Rust adds more handlers
    }

    -- Tool: launch
    rule "Launch Mesh" {
        method: "launch"
        params: { mode: String = "prod" | "test" }
        success_result: { status: "success", mode: String }
        error_code: -32000
        calls: launch::launch_mesh()
    }

    -- Tool: restart (NOTE: only STOPS, does not restart)
    rule "Restart Container" {
        method: "restart"
        params: { container: String }  -- REQUIRED, error -32602 if missing
        success_result: { status: "stopped", container: String }
        error_code: -32000
        note: "Current Rust impl only calls podman::stop_container(). Restart not implemented."
    }

    -- Tool: drain (emergency stop)
    rule "Emergency Drain" {
        method: "drain"
        params: {}  -- none required
        success_result: Json  -- robust_launch::emergency_drain() result
        error_code: -32000
        calls: robust_launch::emergency_drain()
    }

    -- Node discovery: Gleam must subscribe to heartbeat topic to find active node_id
    rule "Node Discovery" {
        when Gleam MoZ client initializes
        then subscribe to "indrajaal/l4/ignition/*/heartbeat"
        then extract node_id from topic path segment
        then subscribe to "indrajaal/l4/ignition/mcp/catalog/{node_id}" for tool catalog
        @guidance Node ID is a random UUID generated on each Rust bridge startup.
                  Gleam cannot hardcode it — must discover via heartbeat.
    }
}

-- =============================================================================
-- S3. CROSS-CUTTING PRODUCTION GAPS (0/5 checklists)
-- =============================================================================

-- Authentication: 0/5 — NO session tokens, NO principal identity, NO RBAC
-- Error handling: 1/5 — Only planning/access_control uses Result
-- Graceful degradation: 0/5 — Circuit breaker exists but never invoked
-- Rate limiting: 0/5 — No middleware
-- Real-time subscriptions: 1/5 — Effects subscribe but never unsubscribe

-- GAP-007: Authentication completely missing (SIL-6 C2 Interface)
gap AuthenticationMissing {
    severity: P0
    description: "Port 4100 Wisp API has ZERO authentication. Any caller can invoke
                  any endpoint. As this evolves into a L5 Operator C2 interface (SC-UI-C2-001),
                  this becomes a severe container control vulnerability."
    files_affected: ["ui/wisp/router.gleam", "web/server.gleam"]
    remediation: {
        step1: "Add bearer token RBAC middleware to handle_request() for L5_Operator."
        step2: "Read-only GET: allow unauthenticated (monitoring L1-L4 telemetry)."
        step3: "Mutation POST: require valid bearer token."
        step4: "L0 P0 actions: require cryptographically signed ProofToken from L0_Guardian (SC-UI-C2-001)."
    }
    stamp: ["SC-SEC-001", "SC-SEC-002", "SC-UI-C2-001"]
}

-- GAP-008: Circuit breaker orphaned (FEMA L2_Immune integration needed)
gap CircuitBreakerOrphaned {
    severity: P1
    description: "prajna/circuit_breaker.gleam implements a correct circuit breaker but is orphaned.
                  It must act as the L2_Immune layer, governed by FEMA tensors (SC-SIL6-001).
                  If Severity x Occurrence > 100, the circuit must trip."
    files_affected: ["prajna/circuit_breaker.gleam"]
    remediation: {
        step1: "Integrate with Zenoh ingestor — evaluate FEMA tensors on telemetry."
        step2: "Open circuit when FEMA F > Threshold, preventing cascading failure to L1."
        step3: "Integrate with web/server.gleam — report L2_Immune state via SSE."
        step4: "Ensure Lyapunov stability derivative V_dot(x) < 0 when transitioning to HalfOpen."
    }
    stamp: ["SC-CIRCUIT-001", "SC-CIRCUIT-002", "SC-SIL6-001", "SC-MATH-001"]
}

-- GAP-009: Dark cockpit not connected to real alert sources
gap DarkCockpitOrphaned {
    severity: P1
    description: "prajna/dark_cockpit.gleam (85 lines) has correct 5-mode state machine
                  (Dark/Dim/Normal/Bright/Emergency) and alert filtering. But alert list
                  is never populated from real sources (Zenoh health, container status,
                  Guardian alerts). Cockpit is always Dark because no alerts arrive."
    files_affected: ["prajna/dark_cockpit.gleam", "ui/lustre/cockpit_view.gleam"]
    remediation: {
        step1: "Subscribe to indrajaal/safety/sentinel/** for threat alerts"
        step2: "Subscribe to indrajaal/health/* for container health changes"
        step3: "Map health degradations to DarkCockpitAlert with appropriate severity"
        step4: "Wire mode changes to Lustre cockpit_view rendering"
    }
    stamp: ["SC-DRK-001", "SC-HMI-010"]
}

-- GAP-010: Lustre pages have no-op update handlers
gap LustreUpdateNoOps {
    severity: P1
    description: "Multiple Lustre pages have Msg variants that do nothing in update():
                  - podman.gleam: StartContainer/StopContainer → model (no-op)
                  - cockpit_view.gleam: AcknowledgeAlarm/RefreshCockpit → model
                  - verification.gleam: RefreshVerification → model
                  - prajna.gleam: All *Updated handlers just reassign, no validation
                  These create buttons that appear clickable but do nothing."
    files_affected: [
        "ui/lustre/podman.gleam",
        "ui/lustre/cockpit_view.gleam",
        "ui/lustre/verification.gleam",
        "ui/lustre/prajna.gleam"
    ]
    remediation: {
        step1: "Wire StartContainer/StopContainer to MoZ mutation via effects"
        step2: "Wire RefreshCockpit/RefreshVerification to Zenoh subscription refresh"
        step3: "Wire AcknowledgeAlarm to dark_cockpit state + SSE notification"
        step4: "Add validation to Prajna *Updated handlers (bounds checking)"
    }
    stamp: ["SC-GLM-UI-002", "SC-AGUI-014"]
}

-- GAP-011: Subscription lifecycle leak
gap SubscriptionLeaks {
    severity: P2
    description: "ui/lustre/effects.gleam (155 lines) subscribes to Zenoh topics
                  but has NO unsubscribe on unmount. If user navigates between pages,
                  subscriptions accumulate. Over time this leaks memory and Zenoh handles."
    files_affected: ["ui/lustre/effects.gleam"]
    remediation: {
        step1: "Track subscription handles in page model"
        step2: "Unsubscribe on page unmount (if Lustre supports cleanup effects)"
        step3: "If Lustre has no cleanup: use reference counting in BEAM process"
        step4: "Set max subscriptions per session (circuit breaker)"
    }
    stamp: ["SC-ZENOH-005"]
}

-- GAP-012: Unbounded history growth in multiple modules
gap UnboundedHistory {
    severity: P2
    description: "Several modules accumulate history without bounds:
                  - verification.gleam: proof_history grows via prepend (no limit)
                  - dark_cockpit.gleam: alert list never evicted
                  - l6_ecosystem.gleam: message queue has max but agent list doesn't
                  - l7_federation.gleam: peer list never pruned"
    files_affected: [
        "ui/lustre/verification.gleam",
        "prajna/dark_cockpit.gleam",
        "fractal/l6_ecosystem.gleam",
        "fractal/l7_federation.gleam"
    ]
    remediation: {
        step1: "Add max_history parameter (default 100) to all history lists"
        step2: "Use list.take(max) after every prepend"
        step3: "Add TTL-based eviction for stale entries (alerts, peers)"
    }
    stamp: ["SC-MUDA-001"]
}

-- =============================================================================
-- S4. CROSS-PAGE STATE COORDINATION
-- =============================================================================

-- Currently each Lustre page has an independent model. No state flows between pages.
-- This means: cockpit_view doesn't know about prajna threat level.
-- podman doesn't know about verification compliance. federation doesn't know about mesh health.

contract CrossPageStateCoordination {
    -- All pages MUST share state via Zenoh subscriptions, not direct coupling.
    -- Pattern: Zenoh topic → BEAM GenServer (shared state holder) → Lustre page query

    rule "No Direct Page Coupling" {
        when PageA.model needs data from PageB.model
        reject "Direct import between page models"
        then "Both subscribe to same Zenoh topic independently"
        @guidance This prevents import cycles and keeps pages independently testable.
    }

    rule "Shared State via GenServer" {
        -- A single BEAM GenServer subscribes to Zenoh topics and holds latest state.
        -- Each Lustre page queries the GenServer on render, not its own subscription.
        entity SharedMeshState {
            container_statuses: Map<String, ContainerStatus>
            health_summary: Map<String, HealthStatus>
            threat_level: String
            ooda_phase: String
            dark_cockpit_mode: String
            quorum_status: Boolean
            last_updated: Timestamp
        }

        rule "GenServer Subscribes Once" {
            on server start
            then subscribe to ["indrajaal/health/*", "indrajaal/l4/system/**",
                              "indrajaal/l5/cog/ooda/**", "indrajaal/safety/sentinel/**"]
            then update SharedMeshState on each message
        }

        rule "Pages Query on Render" {
            when any Lustre page renders
            then call SharedMeshState.get(field)
            ensure "No page holds stale state"
        }
    }
}

-- =============================================================================
-- S5. GRACEFUL DEGRADATION MATRIX
-- =============================================================================

-- What happens when each subsystem fails?

contract GracefulDegradation {

    rule "Zenoh Mesh Down" {
        affected: ["SSE real-time", "MoZ mutations", "OTel spans", "AG-UI events"]
        degradation: {
            sse: "Heartbeat stops → browser auto-reconnects → gets cached last-known state"
            mutations: "Circuit breaker opens → mutation buttons disabled → show 'offline' badge"
            otel: "Spans drop silently (fire-and-forget) → no data loss, just gap"
            agui: "Events not delivered → agents work independently"
        }
        recovery: "Circuit breaker half-open after 30s → retry → close on success"
        ui_indicator: "Red banner: 'Zenoh mesh disconnected. Read-only mode.'"
    }

    rule "Database Down (indrajaal-db-prod)" {
        affected: ["Planning queries", "Oban jobs", "Session state"]
        degradation: {
            planning: "Return cached task list with 'stale' badge"
            oban: "Jobs queued in memory, flush when DB recovers"
            sessions: "Stateless REST unaffected; SSE connections maintained"
        }
        recovery: "Postgrex reconnection pool with exponential backoff"
        ui_indicator: "Yellow banner: 'Database connection degraded.'"
    }

    rule "Rust Ignition Daemon Down" {
        affected: ["MoZ mutations", "Container control", "OODA visualization"]
        degradation: {
            mutations: "No heartbeat → stale detection after 2s → circuit opens → buttons disabled"
            containers: "Last-known container state displayed with timestamp"
            ooda: "OODA ring stops animating → shows 'OODA offline'"
        }
        recovery: "Heartbeat resumes → circuit half-open → test request → close"
        ui_indicator: "Orange banner: 'Ignition daemon unreachable. Container control paused.'"
    }

    rule "Browser JavaScript Disabled" {
        affected: ["SSE real-time", "OODA animation", "Container action buttons"]
        degradation: {
            sse: "No EventSource → page is static HTML snapshot"
            animation: "No CSS animation → static diagram"
            buttons: "Form buttons work via POST (traditional HTML form submit)"
        }
        recovery: "Enable JavaScript → page auto-enhances"
        ui_indicator: "None needed — static HTML is complete and readable (SC-GLM-UI-001)"
    }

    rule "OTel Collector Down (obs-prod)" {
        affected: ["Telemetry page", "Span visualization"]
        degradation: {
            telemetry: "Empty span list with 'collector offline' message"
            spans: "Zenoh OTel publishing continues (buffered) → no data loss"
        }
        recovery: "Collector restart → buffered spans flushed"
        ui_indicator: "Yellow badge on Telemetry tab"
    }
}

