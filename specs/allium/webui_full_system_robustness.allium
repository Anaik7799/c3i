-- S6. EXPANDED FMEA (Full System)
-- =============================================================================

-- Previous specs covered 10 FMEA entries. Adding system-wide failure modes.

fmea "Authentication bypass on mutation endpoint" {
    severity: 10       -- Unauthorized container control
    occurrence: 1      -- Mutation endpoints don't exist yet
    detection: 1       -- Add auth BEFORE adding mutations
    rpn: 10
    mitigation: "GAP-007: Add bearer token auth as prerequisite for GAP-001"
    note: "RPN is low NOW but becomes 10x9x2=180 if mutations ship without auth"
}

fmea "Subscription memory leak on page navigation" {
    severity: 4        -- Gradual memory growth
    occurrence: 7      -- Every page navigation
    detection: 5       -- Not visible until hours of use
    rpn: 140
    mitigation: "GAP-011: Track and cleanup Zenoh subscriptions on page unmount"
}

fmea "Dark cockpit always Dark (no real alerts)" {
    severity: 6        -- Operator misses critical alerts
    occurrence: 10     -- Always (no alert sources wired)
    detection: 3       -- Easy to test once noticed
    rpn: 180
    mitigation: "GAP-009: Wire Zenoh health/sentinel topics to dark_cockpit alert list"
}

fmea "Lustre button clicks do nothing (no-op handlers)" {
    severity: 5        -- Operator frustration, loss of trust
    occurrence: 8      -- Every interaction with affected pages
    detection: 2       -- Immediately visible
    rpn: 80
    mitigation: "GAP-010: Wire Msg handlers to effects (MoZ, Zenoh refresh)"
}

fmea "Proof history grows unbounded in verification page" {
    severity: 3        -- Memory growth over weeks
    occurrence: 6      -- Each verification run
    detection: 6       -- Only visible with profiling
    rpn: 108
    mitigation: "GAP-012: Add max_history=100, list.take() after prepend"
}

fmea "Rust MCP 'restart' only stops, doesn't restart" {
    severity: 7        -- Operator expects restart, gets stop
    occurrence: 3      -- When restart is called
    detection: 2       -- Container status shows 'stopped' not 'running'
    rpn: 42
    mitigation: "Gleam client should call stop + start sequentially, not rely on 'restart' tool"
}

fmea "Catalog/handler mismatch: 6 tools published, 3 handled" {
    severity: 5        -- Client calls unhandled tool → -32601 error
    occurrence: 4      -- If client uses catalog as source of truth
    detection: 2       -- Error response is clear
    rpn: 40
    mitigation: "Gleam client MUST hardcode supported tools: launch, restart, drain"
}

fmea "web/server.gleam has no graceful shutdown" {
    severity: 6        -- Active connections dropped on restart
    occurrence: 3      -- Each deployment
    detection: 3       -- SSE clients notice disconnect
    rpn: 54
    mitigation: "Add SIGTERM handler with connection drain (30s timeout)"
}

