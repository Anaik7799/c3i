-- allium: 3
-- OpenClaw Chat Interaction System — Behavioral Specification
-- Covers: Telegram/GChat/WhatsApp multi-channel gateway, neuromorphic cortex intent routing,
--         simulator harness, OODA-driven intent classification, LLM inference fallback,
--         heartbeat service, rate limiting, task creation from chat, Zenoh backplane integration
-- STAMP: SC-COG-001..003, SC-OPENCLAW-001..004, SC-ZMOF-001, SC-SIM-001..007,
--        SC-API-001..010, SC-OODA-001..009, SC-ZENOH-001..008, SC-MCP-001..082
-- Date: 2026-04-09
-- Author: Claude Opus 4.6 (1M context)

-- =============================================================================
-- S1. EXTERNAL ENTITIES (systems not defined here)
-- =============================================================================

external entity TelegramBotAPI
external entity GoogleChatPubSub
external entity WhatsAppBusinessAPI
external entity ZenohRouter
external entity OllamaInferenceEngine
external entity SmritiDatabase
external entity ReteUlRuleEngine
external entity PlanningAuthority

-- =============================================================================
-- S2. ENUMERATIONS (domain value sets)
-- =============================================================================

enum MessageStatus { received | processing | responded | acknowledged | failed }

enum IntentType { command | query | ack | emergency | skill | greeting | status_query | health_check | broadcast }

enum SessionPhase { active | idle | draining }

enum OodaPhase { observe | orient | decide | act | verify }

enum ChannelType { telegram | gchat | whatsapp | simulator }

enum Priority { p0_critical | p1_high | p2_medium | p3_low }

enum InferenceStatus { queued | running | complete | failed | timed_out }

enum RuleOutcome { pending | evaluated | applied | rejected }

enum TaskStatus { pending | in_progress | completed | blocked }

enum HeartbeatPhase { tick | published }

enum SimEndpoint { get_updates | send_message | pull | acknowledge | webhook | inject | status | outbox | clear }

-- =============================================================================
-- S3. VALUE TYPES (structured data without identity, immutable)
-- =============================================================================

value ResponseLatencyMetric {
    message_id: String
    channel: ChannelType
    ingress_timestamp_ms: Integer
    ack_timestamp_ms: Integer?
    full_response_timestamp_ms: Integer?
    ack_latency_ms: Integer?
    full_latency_ms: Integer?
}

value ThroughputSample {
    window_start_ms: Integer
    window_end_ms: Integer
    message_count: Integer
    messages_per_second: Decimal
}

value StressClassification {
    raw_stress: Decimal
    priority: Priority
    -- Mapping: 0.0-0.5 = P2, 0.5-0.8 = P1, 0.8+ = P0
}

value ChannelCredentials {
    channel: ChannelType
    token: String?
    chat_id: String?
    webhook_url: String?
    phone: String?
    is_configured: Boolean
}

value RuleInput {
    cpu_percent: Decimal
    is_booting: Boolean
    restart_requested: Boolean
    health_critical_count: Integer
    stress_level: Decimal
}

value SimQueueStats {
    telegram_inbox: Integer
    telegram_outbox: Integer
    gchat_inbox: Integer
    gchat_outbox: Integer
}

-- =============================================================================
-- S4. CONFIG (parameterized thresholds, timeouts, limits)
-- =============================================================================

config {
    -- Polling intervals
    telegram_poll_timeout_secs: Integer = 10
    gchat_poll_interval_secs: Integer = 2
    telegram_inter_poll_delay_secs: Integer = 1

    -- Heartbeat cadence
    heartbeat_interval_secs: Integer = 600
    cortex_recalculate_interval_secs: Integer = 60

    -- LLM inference
    llm_inference_timeout_secs: Integer = 30
    llm_model_default: String = "tinyllama"

    -- Rate limiting
    rate_limit_max_msgs_per_minute: Integer = 10
    rate_limit_window_secs: Integer = 60

    -- Response latency SLAs
    ack_latency_max_ms: Integer = 2_000
    full_response_latency_max_ms: Integer = 30_000

    -- Stress thresholds
    stress_p0_threshold: Decimal = 0.8
    stress_p1_threshold: Decimal = 0.5
    -- Below 0.5 is P2

    -- Simulator
    simulator_port: Integer = 9876
    simulator_default_chat_id: String = "6249174059"
    simulator_gchat_space: String = "spaces/sim_space"

    -- Zenoh topics
    intent_topic: String = "indrajaal/l5/cog/intent/**"
    mcp_topic: String = "indrajaal/l5/cog/mcp/req/plan/**"
    cron_topic: String = "indrajaal/l5/cog/intent/cron"
    intent_req_topic: String = "indrajaal/l5/cog/intent/req"

    -- Smriti persistence keys
    telegram_offset_key: String = "telegram_poll_offset"
    telegram_token_key: String = "telegram_token"
    telegram_chat_id_key: String = "telegram_chat_id"
    gchat_webhook_key: String = "gchat_webhook"

    -- Task creation
    command_prefix: String = "/"
    min_text_length_for_task: Integer = 10

    -- Feature flags
    enable_llm_inference: Boolean = true
    enable_simulator_redirect: Boolean = true
    enable_gchat_polling: Boolean = true
    enable_whatsapp: Boolean = false
}

-- =============================================================================
-- S5. ENTITIES (domain objects with identity and lifecycle)
-- =============================================================================

entity ChatMessage {
    id: String
    raw_text: String
    source: ChannelType
    chat_id: String?
    timestamp_ms: Integer
    status: MessageStatus
    intent: IntentType?
    priority: Priority?
    response_text: String?
    swarm_stress_level: Decimal?

    -- Derived values
    is_ack: this.raw_text = "ACK"
    is_command: this.raw_text starts_with config.command_prefix
    is_substantive: length(this.raw_text) > config.min_text_length_for_task
    should_create_task: this.is_command or this.is_substantive

    -- State machine
    transitions status {
        received -> processing
        processing -> responded
        processing -> failed
        responded -> acknowledged
        terminal: acknowledged
        terminal: failed
    }

    -- Entity-level invariant
    invariant ValidTimestamp {
        this.timestamp_ms > 0
    }

    invariant SourceNotEmpty {
        this.source != null
    }
}

entity IntentClassification {
    message_id: String
    intent_type: IntentType
    confidence: Decimal
    stress_level: Decimal
    computed_priority: Priority

    -- Derived values
    is_emergency: this.intent_type = emergency or this.stress_level >= config.stress_p0_threshold
    is_high_priority: this.stress_level >= config.stress_p1_threshold

    -- Priority derivation from stress
    -- stress >= 0.8 -> P0, stress >= 0.5 -> P1, else -> P2
    derived_priority:
        if this.stress_level >= config.stress_p0_threshold then p0_critical
        else if this.stress_level >= config.stress_p1_threshold then p1_high
        else p2_medium

    invariant StressBounded {
        this.stress_level >= 0.0 and this.stress_level <= 1.0
    }
}

entity CortexSession {
    session_id: String
    phase: SessionPhase
    zenoh_session_active: Boolean
    intent_subscriber_active: Boolean
    mcp_subscriber_active: Boolean
    heartbeat_spawned: Boolean
    polling_spawned: Boolean
    gchat_polling_spawned: Boolean
    recalculate_timer_spawned: Boolean
    messages_processed: Integer
    last_intent_timestamp_ms: Integer?

    transitions phase {
        active -> idle
        idle -> active
        active -> draining
        idle -> draining
        terminal: draining
    }

    invariant ZenohRequired {
        this.zenoh_session_active = true
    }
}

entity OodaCycle {
    cycle_id: String
    phase: OodaPhase
    intent_id: String
    observation: String?
    orientation: String?
    decision: String?
    action_taken: String?
    duration_ms: Integer?

    transitions phase {
        observe -> orient
        orient -> decide
        decide -> act
        act -> verify
        terminal: verify
    }

    invariant CycleSla {
        this.duration_ms = null or this.duration_ms <= 100
    }

    @guidance
        -- The OODA cycle for chat intent processing is:
        -- OBSERVE: Receive raw message from channel ingress polling
        -- ORIENT: Parse intent type, compute stress classification
        -- DECIDE: Evaluate RETE-UL rules, determine priority and response strategy
        -- ACT: Execute response (LLM inference or rule-based), create task if needed
        -- VERIFY: Confirm response delivered, update Smriti state
}

entity GatewayChannel {
    channel_type: ChannelType
    is_configured: Boolean
    token: String?
    chat_id: String?
    webhook_url: String?
    is_simulated: Boolean
    messages_sent: Integer
    messages_received: Integer
    last_error: String?

    -- Derived
    is_operational: this.is_configured and this.last_error = null
    uses_simulator: this.is_simulated and config.enable_simulator_redirect

    invariant ConfiguredBeforeUse {
        this.messages_sent > 0 implies this.is_configured
    }
}

entity SimulatorState {
    telegram_inbox: List<SimMessage>
    telegram_outbox: List<SimMessage>
    gchat_inbox: List<SimMessage>
    gchat_outbox: List<SimMessage>
    next_update_id: Integer
    next_ack_id: Integer
    is_running: Boolean
    port: Integer

    -- Derived
    total_inbox_count: count(this.telegram_inbox) + count(this.gchat_inbox)
    total_outbox_count: count(this.telegram_outbox) + count(this.gchat_outbox)

    invariant PortValid {
        this.port > 0 and this.port < 65536
    }
}

entity RuleEvaluation {
    evaluation_id: String
    intent_id: String
    rule_input: RuleInput
    outcome: RuleOutcome
    decision: String?
    salience: Integer?
    evaluation_time_ms: Integer?

    transitions outcome {
        pending -> evaluated
        evaluated -> applied
        evaluated -> rejected
        terminal: applied
        terminal: rejected
    }

    @guidance
        -- Rule evaluation uses the RETE-UL engine from rule_engine.rs.
        -- The evaluate_decision() API is called with stress-derived inputs.
        -- High salience rules (Emergency Stop = 100) take priority.
}

entity TaskFromChat {
    task_id: String
    description: String
    priority: Priority
    source_message_id: String
    source_channel: ChannelType
    status: TaskStatus

    transitions status {
        pending -> in_progress
        in_progress -> completed
        in_progress -> blocked
        blocked -> in_progress
        terminal: completed
    }

    @guidance
        -- Tasks created from chat are persisted via db::add_task().
        -- Priority is dynamically computed from swarm stress level.
        -- Task ID is generated by Smriti.db (SQLite UUID).
}

entity LlmInference {
    inference_id: String
    prompt: String
    model: String
    status: InferenceStatus
    response: String?
    duration_ms: Integer?
    error: String?

    transitions status {
        queued -> running
        running -> complete
        running -> failed
        running -> timed_out
        terminal: complete
        terminal: failed
        terminal: timed_out
    }

    invariant TimeoutEnforced {
        this.status = timed_out implies this.duration_ms >= config.llm_inference_timeout_secs * 1000
    }

    @guidance
        -- LLM inference uses mcp_inference::handle_inference_request().
        -- Default model is "tinyllama" via local Ollama instance.
        -- On timeout or failure, falls back to rule-based classification.
}

entity HeartbeatCycle {
    tick_id: String
    phase: HeartbeatPhase
    timestamp_ms: Integer
    zenoh_topic: String
    published: Boolean

    transitions phase {
        tick -> published
        terminal: published
    }

    @guidance
        -- Heartbeat emits periodic cron intents to trigger Gleam OODA proactive cycles.
        -- Cadence: every 10 minutes (config.heartbeat_interval_secs = 600).
        -- Published to indrajaal/l5/cog/intent/cron.
}

entity IngressPoller {
    poller_id: String
    channel: ChannelType
    is_active: Boolean
    current_offset: Integer
    messages_ingested: Integer
    last_poll_timestamp_ms: Integer?
    consecutive_errors: Integer

    -- Derived
    is_healthy: this.consecutive_errors < 3
    offset_persisted: this.current_offset > 0

    invariant OffsetMonotonic {
        -- Offset must never decrease (prevents message replay)
        this.current_offset >= 0
    }
}

entity RateLimiter {
    channel: ChannelType
    chat_id: String
    window_start_ms: Integer
    message_count: Integer
    is_rate_limited: Boolean

    -- Derived
    rate_exceeded: this.message_count > config.rate_limit_max_msgs_per_minute

    invariant WindowPositive {
        this.window_start_ms > 0
    }
}

-- =============================================================================
-- S6. CONTRACTS (module boundaries -- demands/fulfils)
-- =============================================================================

contract TelegramAPI {
    get_updates: (token: String, offset: Integer, timeout: Integer) -> List<TelegramUpdate>
    send_message: (token: String, chat_id: String, text: String, needs_ack: Boolean) -> Boolean

    @invariant OffsetPersisted
        -- Polling offset is persisted to Smriti after each batch to survive restarts.
    @invariant LongPollTimeout
        -- getUpdates uses timeout=10s for efficient long-polling.
    @guidance
        -- When SIMULATOR_TELEGRAM_URL is set, all requests route to the local simulator.
        -- Mock tokens (empty or "INTERNAL_SIL6_TOKEN") skip real HTTP requests.
}

contract GChatPubSub {
    pull: (project_id: String, subscription_id: String, max_messages: Integer) -> List<PubSubMessage>
    acknowledge: (project_id: String, subscription_id: String, ack_ids: List<String>) -> Boolean
    send_webhook: (webhook_url: String, text: String, needs_ack: Boolean) -> Boolean

    @invariant PreflightCheck
        -- Before polling, verify the Pub/Sub subscription exists (404 = halt polling).
    @invariant Base64Decode
        -- Message data is Base64-encoded; decode before parsing chat event JSON.
    @guidance
        -- GCP auth token obtained via `gcloud auth application-default print-access-token`.
        -- When SIMULATOR_GCHAT_URL is set, all requests route to the local simulator.
}

contract CortexEngine {
    process_intent: (intent: ChatMessage) -> OodaCycle
    recalculate_priorities: () -> Void
    classify_intent: (text: String, stress: Decimal) -> IntentClassification

    @invariant NonBlockingSelect
        -- The tokio::select! loop in run_cortex_daemon MUST never block > 100ms.
        -- Intent processing is spawned as separate tokio tasks.
    @invariant SpawnedProcessing
        -- All intent processing MUST be spawned via tokio::spawn to prevent blocking.
    @guidance
        -- recalculate_priorities runs on a 60s timer, separate from the select loop.
        -- LLM inference is expensive (~10-20s per call), hence the 60s cadence.
}

contract GatewayDispatcher {
    broadcast_message: (text: String, needs_ack: Boolean) -> Void
    send_message: (channel: ChannelType, text: String, token: String?, chat_id: String?, phone: String?, needs_ack: Boolean) -> Boolean

    @invariant AllConfiguredChannels
        -- broadcast_message sends to ALL configured channels (Telegram + GChat).
    @invariant GracefulMockSkip
        -- Mock/empty tokens cause a skip, not an error.
    @guidance
        -- Channel dispatch is sequential (Telegram first, GChat second).
        -- WhatsApp requires explicit phone number parameter.
        -- needs_ack=true adds inline keyboard (Telegram) or cardsV2 (GChat).
}

contract SimulatorAPI {
    inject_telegram: (text: String) -> Boolean
    inject_gchat: (text: String) -> Boolean
    status: () -> SimQueueStats
    outbox: () -> SimOutbox
    clear: () -> Boolean

    @invariant FidelityMatch
        -- Simulator responses MUST match the structure of real API responses.
        -- Telegram: {"ok": true, "result": [...]} format preserved.
        -- GChat: {"receivedMessages": [...]} format preserved.
    @invariant SequentialIds
        -- update_id (Telegram) and ack_id (GChat) are monotonically increasing.
    @guidance
        -- Simulator runs on configurable port (default 9876).
        -- Supports: GET /bot{token}/getUpdates, POST /bot{token}/sendMessage,
        --           POST :pull, POST :acknowledge, POST /webhook,
        --           POST /sim/inject/telegram, POST /sim/inject/gchat,
        --           GET /sim/status, GET /sim/outbox, POST /sim/clear
}

-- =============================================================================
-- S7. ACTORS (parties at system boundaries)
-- =============================================================================

actor Operator {
    identified_by: User where channel in [telegram, gchat, whatsapp]
    -- The human operator who sends messages via chat channels.
}

actor AiAgent {
    identified_by: System where source = "heartbeat_daemon" or source = "cortex"
    -- Internal agents that produce intent events.
}

actor TestHarness {
    identified_by: System where channel = simulator
    -- E2E test runners that inject messages via the simulator API.
}

-- =============================================================================
-- S8. RULES (event-driven behavior: when/requires/ensures)
-- =============================================================================

rule AckImmediate {
    when: msg: ChatMessage where msg.raw_text = "ACK"
    requires: msg.status = received
    ensures: msg.status = acknowledged
    ensures: GatewayDispatcher.broadcast_message("Acknowledged.", false)
    ensures: no LlmInference created
    @guidance
        -- ACK messages get an immediate response with zero LLM overhead.
        -- Source: cortex.rs:116-119 — early return on ACK text.
}

rule CommandPrefix {
    when: msg: ChatMessage where msg.raw_text starts_with config.command_prefix
    requires: msg.status = processing
    ensures: TaskFromChat.created(description: msg.raw_text, priority: msg.priority, source_message_id: msg.id)
    ensures: PlanningAuthority.add_task(msg.raw_text, msg.priority)
    @guidance
        -- Slash-prefixed messages (e.g., "/deploy", "/status") are treated as commands.
        -- They are added as tasks via db::add_task() with dynamic priority.
        -- Source: cortex.rs:158 — raw_text.starts_with('/').
}

rule EmergencyClassification {
    when: intent: IntentClassification where intent.stress_level >= config.stress_p0_threshold
    requires: intent.intent_type != ack
    ensures: intent.computed_priority = p0_critical
    ensures: GatewayDispatcher.broadcast_message("P0 EMERGENCY: " + intent.message_id, true)
    @guidance
        -- Stress > 0.8 triggers P0 classification with immediate broadcast.
        -- The rule engine maps health_critical_count >= 3 when stress > 0.8.
        -- Source: cortex.rs:131-136 — rule input construction from stress level.
}

rule QueryWithLlm {
    when: msg: ChatMessage where msg.intent = query and config.enable_llm_inference
    requires: msg.status = processing
    requires: not exists RateLimiter{chat_id: msg.chat_id, is_rate_limited: true}
    ensures: LlmInference.created(prompt: msg.raw_text, model: config.llm_model_default, status: queued)
    ensures: msg.response_text set from LlmInference.response
    @guidance
        -- Queries go through LLM inference when available.
        -- If LLM fails or times out, falls back to rule-based classification.
        -- Source: cortex.rs:139-152 — handle_inference_request with fallback.
}

rule GreetingResponse {
    when: msg: ChatMessage where msg.intent = greeting
    requires: msg.status = processing
    ensures: GatewayDispatcher.send_message(msg.source, "Hello! C3I Cortex online. How can I help?", ...)
    ensures: msg.status = responded
    @guidance
        -- Simple greetings receive a friendly acknowledgment without LLM invocation.
}

rule StatusQuery {
    when: msg: ChatMessage where msg.intent = status_query
    requires: msg.status = processing
    ensures: response includes system metrics from SmritiDatabase.get_all_tasks()
    ensures: msg.status = responded
    @guidance
        -- Status queries return current task counts and system health metrics.
        -- Source: cortex.rs PlanningMethod::ListTasks handler.
}

rule HealthCheck {
    when: msg: ChatMessage where msg.intent = health_check
    requires: msg.status = processing
    ensures: response includes db.get_all_tasks() count
    ensures: response includes zenoh session status
    ensures: msg.status = responded
    @guidance
        -- Health checks perform TCP probe on key services and return DB stats.
}

rule StressEscalation {
    when: intent: IntentClassification where intent.stress_level > config.stress_p0_threshold
    requires: true
    ensures: intent.computed_priority = p0_critical
    ensures: RuleEvaluation.created(rule_input: {health_critical_count: 3, stress_level: intent.stress_level})
    @guidance
        -- Stress > 0.8 maps to health_critical_count >= 3 in the RETE-UL input.
        -- Source: cortex.rs:131-136.
}

rule LlmTimeoutFallback {
    when: inference: LlmInference.status transitions_to timed_out or failed
    requires: inference.duration_ms >= config.llm_inference_timeout_secs * 1000 or inference.status = failed
    ensures: msg.response_text = rule_based_classification(msg.raw_text, msg.swarm_stress_level)
    ensures: msg.status = responded
    @guidance
        -- When LLM is unreachable or times out, the system falls back to priority-based
        -- classification using stress level thresholds.
        -- Source: cortex.rs:148-151 — Err(_) branch produces rule-based response.
}

rule RapidFireRateLimit {
    when: msg: ChatMessage where count(ChatMessage{chat_id: msg.chat_id, timestamp_ms > now - config.rate_limit_window_secs * 1000}) > config.rate_limit_max_msgs_per_minute
    requires: msg.status = received
    ensures: RateLimiter.updated(chat_id: msg.chat_id, is_rate_limited: true)
    ensures: GatewayDispatcher.send_message(msg.source, "Rate limit exceeded. Please wait.", ...)
    ensures: msg.status = failed
    @guidance
        -- More than 10 messages per minute from a single chat_id triggers rate limiting.
        -- The message is rejected with a friendly notification.
}

rule SimulatorModeRedirect {
    when: GatewayChannel where channel.is_simulated = true
    requires: config.enable_simulator_redirect
    ensures: all API calls redirect to localhost:config.simulator_port
    @guidance
        -- When SIMULATOR_TELEGRAM_URL or SIMULATOR_GCHAT_URL is set, all HTTP requests
        -- are redirected to the local simulator.
        -- Source: gateway.rs:46-48 (Telegram), gateway.rs:108-109 (GChat).
}

rule BroadcastToAll {
    when: BroadcastRequested(text: String, needs_ack: Boolean)
    requires: true
    ensures: for channel in configured_channels: GatewayDispatcher.send_message(channel, text, ...)
    @guidance
        -- broadcast_message sends to all configured channels sequentially.
        -- Source: gateway.rs:7-22 — iterates Telegram then GChat.
}

rule OffsetPersistence {
    when: IngressPoller.current_offset changes
    requires: IngressPoller.channel = telegram
    ensures: SmritiDatabase.set_preference(config.telegram_offset_key, offset.to_string(), "infra_state")
    @guidance
        -- Telegram polling offset is persisted to Smriti after each batch.
        -- On restart, the offset is restored to avoid replaying old messages.
        -- Source: ingress_polling.rs:15-18 (restore), :51 (persist).
}

rule HeartbeatCron {
    when: HeartbeatCycle.phase = tick
    requires: CortexSession.phase = active
    ensures: zenoh_publish(config.cron_topic, {id: "cron-{timestamp}", source: "heartbeat_daemon", type: "periodic_triage"})
    ensures: HeartbeatCycle.phase = published
    @guidance
        -- Heartbeat cron runs every 10 minutes, emitting a proactive intent.
        -- Source: heartbeat.rs:12-29.
}

rule IntentPublishToZenoh {
    when: msg: ChatMessage where msg.status = received
    requires: CortexSession.zenoh_session_active = true
    ensures: zenoh_publish(config.intent_req_topic, {id: msg.id, raw_text: msg.raw_text, source: msg.source, chat_id: msg.chat_id, timestamp_ms: msg.timestamp_ms})
    @guidance
        -- Inbound messages from polling are published as Zenoh intents.
        -- Source: ingress_polling.rs:60-67 (Telegram), :154-161 (GChat).
}

-- =============================================================================
-- S9. INVARIANTS (always-true, pure, no side effects)
-- =============================================================================

invariant IntentNeverLost {
    for msg in ChatMessages where msg.status = received:
        eventually msg.status in [responded, acknowledged, failed]
    -- Every ingested message MUST eventually get a response or be marked failed.
    -- No message may remain in 'received' state indefinitely.
}

invariant NonBlockingSelect {
    for session in CortexSessions where session.phase = active:
        select_loop_latency_ms <= 100
    -- The tokio::select! loop in run_cortex_daemon MUST never block > 100ms.
    -- Intent processing is spawned as separate tokio tasks.
    -- Source: cortex.rs:74-102 — tokio::select! with tokio::spawn.
}

invariant OffsetPersisted {
    for poller in IngressPollers where poller.channel = telegram:
        poller.current_offset persisted to SmritiDatabase
    -- Telegram polling offset MUST survive daemon restarts.
    -- Prevents message replay on restart.
    -- Source: ingress_polling.rs:15-18.
}

invariant ResponseLatency {
    for msg in ChatMessages where msg.status = responded:
        msg.ack_latency_ms <= config.ack_latency_max_ms and
        msg.full_latency_ms <= config.full_response_latency_max_ms
    -- Acknowledgment within 2 seconds, full response within 30 seconds.
}

invariant SimulatorFidelity {
    for sim in SimulatorStates where sim.is_running:
        telegram_response_structure matches TelegramBotAPI.response_structure and
        gchat_response_structure matches GoogleChatPubSub.response_structure
    -- Simulator HTTP responses MUST match the structure of real API responses.
    -- Source: simulator.rs — all handlers produce API-compatible JSON.
}

invariant ZenohSessionAlive {
    for session in CortexSessions where session.phase = active:
        session.zenoh_session_active = true
    -- The Zenoh session MUST remain connected for the cortex to function.
}

invariant MonotonicOffset {
    for poller in IngressPollers where poller.channel = telegram:
        poller.current_offset is monotonically increasing
    -- Offset MUST only increase (offset = update_id + 1).
    -- Source: ingress_polling.rs:49 — offset = update_id + 1.
}

invariant NoOrphanedInferences {
    for inf in LlmInferences where inf.status = running:
        inf.duration_ms < config.llm_inference_timeout_secs * 1000
    -- No LLM inference may run indefinitely. Timeout is enforced.
}

-- =============================================================================
-- S10. SURFACES (actor-facing boundaries)
-- =============================================================================

surface TelegramChat {
    facing viewer: Operator
    context messages: ChatMessage where source = telegram

    exposes:
        messages.raw_text
        messages.status
        messages.response_text
        messages.priority

    provides:
        SendMessage(text: String)
            when viewer authenticated via telegram_token
        AcknowledgeAlert(message_id: String)
            when messages.status = responded

    contracts:
        demands TelegramAPI
        demands GatewayDispatcher
        demands CortexEngine

    timeout:
        PollTimeout when no messages received for config.telegram_poll_timeout_secs * 10

    @guarantee OperatorCanAlwaysSendACK
    @guarantee AllMessagesGetResponse
}

surface GChatSpace {
    facing viewer: Operator
    context messages: ChatMessage where source = gchat

    exposes:
        messages.raw_text
        messages.status
        messages.response_text
        messages.priority

    provides:
        SendMessage(text: String)
            when viewer authenticated via gchat_webhook
        AcknowledgeAlert(message_id: String)

    contracts:
        demands GChatPubSub
        demands GatewayDispatcher
        demands CortexEngine

    timeout:
        PollTimeout when no messages received for config.gchat_poll_interval_secs * 60

    @guarantee MessagesAcknowledgedInPubSub
    @guarantee WebhookDeliveryAtLeastOnce
}

surface SimulatorDashboard {
    facing viewer: TestHarness
    context sim: SimulatorState

    exposes:
        sim.telegram_inbox
        sim.telegram_outbox
        sim.gchat_inbox
        sim.gchat_outbox
        sim.next_update_id
        sim.is_running

    provides:
        InjectTelegram(text: String)
        InjectGChat(text: String)
        GetStatus()
        GetOutbox()
        ClearAll()

    contracts:
        demands SimulatorAPI

    @guarantee InjectionsAppearInPolling
    @guarantee OutboxCapturesSentMessages
    @guarantee ClearResetsAllQueues
}

