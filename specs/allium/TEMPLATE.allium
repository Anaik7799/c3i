-- allium: 3
-- [SYSTEM NAME] — Behavioral Specification
-- Covers: [list of major subsystems]
-- STAMP: [SC-XXX-NNN references]
-- Date: [YYYY-MM-DD]
-- Author: [human/agent]

-- =============================================================================
-- §1. EXTERNAL ENTITIES (systems not defined here)
-- =============================================================================

external entity ExternalSystem1
external entity ExternalSystem2

-- =============================================================================
-- §2. ENUMERATIONS (domain value sets)
-- =============================================================================

enum Status { pending | active | completed | failed }
enum Priority { p0_critical | p1_high | p2_medium | p3_low }

-- =============================================================================
-- §3. VALUE TYPES (structured data without identity, immutable)
-- =============================================================================

value Metric {
    name: String
    value: Decimal
    unit: String
    timestamp: Timestamp
}

-- =============================================================================
-- §4. CONFIG (parameterized thresholds, timeouts, limits)
-- =============================================================================

config {
    -- Timing
    operation_timeout_ms: Integer = 5_000
    cycle_sla_ms: Integer = 100

    -- Thresholds
    health_threshold: Decimal = 0.7
    max_retries: Integer = 3

    -- Feature flags
    enable_llm: Boolean = true
}

-- =============================================================================
-- §5. ENTITIES (domain objects with identity and lifecycle)
-- =============================================================================

entity Resource {
    name: String
    status: Status
    health: Decimal
    owner: String?

    -- Relationships
    depends_on: Set<Resource>

    -- Projections (filtered views)
    active_dependencies: depends_on where status = active

    -- Derived values (auto-computed)
    is_healthy: this.health >= config.health_threshold
    dependency_count: this.depends_on.count

    -- State machine
    transitions status {
        pending -> active
        active -> completed
        active -> failed
        failed -> pending
        terminal: completed
    }

    -- Entity-level invariant
    invariant HealthBounded {
        this.health >= 0.0 and this.health <= 1.0
    }
}

-- =============================================================================
-- §6. CONTRACTS (module boundaries — demands/fulfils)
-- =============================================================================

contract ResourceManager {
    create: (name: String) -> Resource
    delete: (resource: Resource) -> Boolean
    health_check: (resource: Resource) -> Decimal

    @invariant IdempotentCreate
        -- Creating same resource twice is a no-op.
    @invariant HealthNonNegative
        -- Health check always returns >= 0.0.
    @guidance
        -- Implementations should use connection pooling.
}

-- =============================================================================
-- §7. ACTORS (parties at system boundaries)
-- =============================================================================

actor Operator {
    identified_by: User where role = operator
}

actor AiAgent {
    identified_by: User where role = agent
}

-- =============================================================================
-- §8. RULES (event-driven behavior: when/requires/ensures)
-- =============================================================================

rule CreateResource {
    when: ResourceRequested(name, owner)
    requires: not exists Resource{name: name}
    requires: length(name) > 0
    ensures: Resource.created(name: name, status: pending, health: 1.0, owner: owner)
    @guidance
        -- Publish creation event to Zenoh after success.
}

rule ActivateResource {
    when: resource: Resource.status transitions_to active
    requires: resource.is_healthy
    ensures: resource.status = active
    @guidance
        -- Check all dependencies are active before activation.
}

rule HandleFailure {
    when: resource: Resource.health becomes 0.0
    requires: resource.status = active
    ensures: resource.status = failed
    ensures: FailureDetected(resource_name: resource.name)
    @guidance
        -- Trigger RCA and recovery playbook.
}

-- =============================================================================
-- §9. INVARIANTS (always-true, pure, no side effects)
-- =============================================================================

invariant AllResourcesTracked {
    for r in Resources:
        r.name != null and r.status != null
}

invariant NoOrphanDependencies {
    for r in Resources:
        for d in r.depends_on:
            exists d
}

-- =============================================================================
-- §10. SURFACES (actor-facing boundaries)
-- =============================================================================

surface Dashboard {
    facing viewer: Operator
    context resource: Resource where status != completed

    exposes:
        resource.name
        resource.status
        resource.health
        resource.dependency_count

    provides:
        ResourceRequested(name: String, owner: viewer.name)
            when resource.status = pending
        EmergencyStop(reason: String)

    contracts:
        demands ResourceManager

    timeout:
        OperationTimeout when resource.created_at + config.operation_timeout_ms.milliseconds <= now

    @guarantee OperatorCanAlwaysEmergencyStop
    @guarantee AllOperationsIdempotent
}

-- =============================================================================
-- §11. DEFAULTS (unconditional entity instances)
-- =============================================================================

default Resource system_health = {name: "system", status: active, health: 1.0}

-- =============================================================================
-- §12. DEFERRED SPECIFICATIONS (logic defined elsewhere)
-- =============================================================================

deferred RecoveryEngine.auto_recover
deferred AnalyticsEngine.compute_trend

-- =============================================================================
-- §13. OPEN QUESTIONS (unresolved design decisions)
-- =============================================================================

open question "Should failed resources auto-retry or require operator intervention?"
open question "What is the maximum dependency chain depth?"

-- =============================================================================
-- §14. FORMAL VERIFICATION (Agda / Quint / TLA+)
-- =============================================================================
--
-- Agda (type-level proofs):
--   1. Resource status monotonicity (pending → active → completed, no regression)
--   2. Dependency acyclicity (no circular dependencies)
--
-- Quint (state machine bounded model checking):
--   1. All resources eventually reach terminal state
--   2. Health transitions are monotonic within a check cycle
--
-- TLA+ (temporal logic):
--   1. Liveness: every pending resource eventually becomes active or failed
--   2. Safety: no two resources with same name exist simultaneously

-- =============================================================================
-- §15. STAMP CONSTRAINTS (cross-reference to SC-* registry)
-- =============================================================================
--
-- SC-XXX-001: [constraint description] → rule RuleName
-- SC-XXX-002: [constraint description] → invariant InvariantName
-- SC-XXX-003: [constraint description] → contract ContractName

-- =============================================================================
-- §16. AOR OPERATIONAL RULES (cross-reference to AOR-* registry)
-- =============================================================================
--
-- AOR-XXX-001: ALWAYS [action] → rule RuleName @guidance
-- AOR-XXX-002: NEVER [anti-pattern] → invariant / contract @invariant

-- =============================================================================
-- §17. FMEA (Failure Modes with RPN scoring)
-- =============================================================================
--
-- | # | Failure Mode | S | O | D | RPN | Rule | Playbook |
-- |---|-------------|---|---|---|-----|------|----------|
-- | 1 | [mode]      | N | N | N | NNN | rule | recovery |

